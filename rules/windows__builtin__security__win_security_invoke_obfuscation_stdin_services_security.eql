any where winlog.channel:"Security" and ((event.code:"4697" and (winlog.event_data.ServiceFileName:"*cmd*" and winlog.event_data.ServiceFileName:"*powershell*")) and (winlog.event_data.ServiceFileName like~ ("*${input}*", "*noexit*")) and (winlog.event_data.ServiceFileName like~ ("* /c *", "* /r *")))
