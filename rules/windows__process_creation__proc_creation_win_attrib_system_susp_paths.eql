any where ((process.executable:"*\\attrib.exe" or process.pe.original_file_name:"ATTRIB.EXE") and process.command_line:"* +s*" and (process.command_line like~ ("* %*", "*\\Users\\Public\*", "*\\AppData\\Local\*", "*\\ProgramData\*", "*\\Downloads\*", "*\\Windows\\Temp\*")) and (process.command_line like~ ("*.bat*", "*.dll*", "*.exe*", "*.hta*", "*.ps1*", "*.vbe*", "*.vbs*"))) and (not (process.command_line:"*\\Windows\\TEMP\*" and process.command_line:"*.exe*"))
