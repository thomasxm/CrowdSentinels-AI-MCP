any where process.parent.executable:"*\\provlaunch.exe" and (not ((process.executable like~ ("*\\calc.exe", "*\\cmd.exe", "*\\cscript.exe", "*\\mshta.exe", "*\\notepad.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\regsvr32.exe", "*\\rundll32.exe", "*\\wscript.exe")) or (process.executable like~ ("*:\\PerfLogs\*", "*:\\Temp\*", "*:\\Users\\Public\*", "*\\AppData\\Temp\*", "*\\Windows\\System32\\Tasks\*", "*\\Windows\\Tasks\*", "*\\Windows\\Temp\*"))))
