any where ((process.executable:"*\\fltMC.exe" or process.pe.original_file_name:"fltMC.exe") and process.command_line:"*unload*") and (not (((process.parent.executable like~ ("*\\AppData\\Local\\Temp\*", "*:\\Windows\\Temp\*")) and process.parent.executable:"*\\endpoint-protection-installer-x64.tmp" and (process.command_line like~ ("*unload rtp_filesystem_filter", "*unload rtp_filter"))) or (process.parent.executable:"C:\\Program Files (x86)\\ManageEngine\\uems_agent\\bin\\dcfaservice64.exe" and process.command_line:"*unload DFMFilter")))
