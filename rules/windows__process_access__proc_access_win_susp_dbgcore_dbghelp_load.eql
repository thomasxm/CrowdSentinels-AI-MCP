any where (winlog.event_data.TargetImage:"*\\lsass.exe" and (winlog.event_data.CallTrace like~ ("*dbgcore.dll*", "*dbghelp.dll*"))) and (process.executable like~ ("*:\\Perflogs\*", "*:\\Temp\*", "*:\\Users\\Public\*", "*\\$Recycle.Bin\*", "*\\AppData\\Roaming\*", "*\\Contacts\*", "*\\Desktop\*", "*\\Documents\*", "*\\Downloads\*", "*\\Favorites\*", "*\\Favourites\*", "*\\inetpub\\wwwroot\*", "*\\Music\*", "*\\Pictures\*", "*\\Start Menu\\Programs\\Startup\*", "*\\Users\\Default\*", "*\\Videos\*", "*\\Windows\\Temp\*"))
