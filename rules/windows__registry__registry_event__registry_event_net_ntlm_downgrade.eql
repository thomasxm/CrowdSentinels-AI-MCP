any where (registry.path:"*SYSTEM\*" and registry.path:"*ControlSet*" and registry.path:"*\\Control\\Lsa*") and ((registry.path:"*\\lmcompatibilitylevel" and (winlog.event_data.Details like~ ("DWORD (0x00000000)", "DWORD (0x00000001)", "DWORD (0x00000002)"))) or (registry.path:"*\\NtlmMinClientSec" and (winlog.event_data.Details like~ ("DWORD (0x00000000)", "DWORD (0x00000010)", "DWORD (0x00000020)", "DWORD (0x00000030)"))) or registry.path:"*\\RestrictSendingNTLMTraffic")
