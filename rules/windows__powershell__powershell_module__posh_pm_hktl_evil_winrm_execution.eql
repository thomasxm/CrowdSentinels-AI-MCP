any where (winlog.event_data.ContextInfo like~ ("*:\\Windows\\System32\\wsmprovhost.exe*", "*:\\Windows\\SysWOW64\\wsmprovhost.exe*")) and ((powershell.file.script_block_text like~ ("*value=\"(get-location).path*", "*value=\"(get-item*).length*", "*Invoke-Binary *", "*Donut-Loader -process_id*-donutfile*", "*Bypass-4MSI*", "*IEX ([System.Text.Encoding]::ASCII.GetString([System.Convert]::FromBase64String($a))).replace('???','')*")) or (powershell.file.script_block_text:"*$servicios = Get-ItemProperty \"registry::HKLM\\System\\CurrentControlSet\\Services\\\"*" and powershell.file.script_block_text:"*Where-Object {$_.imagepath -notmatch \"system\" -and $_.imagepath -ne $null } | Select-Object pschildname,imagepath*") or (powershell.file.script_block_text:"*$a +=  \\\"$($_.FullName.Replace('\\','/'))/\\\"}else{  $a += \\\"$($_.FullName.Replace('\\', '/'))\\\" }*" and powershell.file.script_block_text:"*$a=@();$*"))
