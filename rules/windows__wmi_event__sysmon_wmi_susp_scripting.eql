any where (process.executable:"*new-object*" and process.executable:"*net.webclient*" and process.executable:"*.downloadstring*") or (process.executable:"*new-object*" and process.executable:"*net.webclient*" and process.executable:"*.downloadfile*") or (process.executable like~ ("* iex(*", "* -nop *", "* -noprofile *", "* -decode *", "* -enc *", "*WScript.Shell*", "*System.Security.Cryptography.FromBase64Transform*"))
