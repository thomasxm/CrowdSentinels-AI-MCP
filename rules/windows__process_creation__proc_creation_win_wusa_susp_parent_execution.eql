any where process.executable:"*\\wusa.exe" and ((process.parent.executable like~ ("*:\\Perflogs\*", "*:\\Users\\Public\*", "*:\\Windows\\Temp\*", "*\\Appdata\\Local\\Temp\*", "*\\Temporary Internet*")) or ((process.parent.executable:"*:\\Users\*" and process.parent.executable:"*\\Favorites\*") or (process.parent.executable:"*:\\Users\*" and process.parent.executable:"*\\Favourites\*") or (process.parent.executable:"*:\\Users\*" and process.parent.executable:"*\\Contacts\*") or (process.parent.executable:"*:\\Users\*" and process.parent.executable:"*\\Pictures\*"))) and (not process.command_line:"*.msu*")
