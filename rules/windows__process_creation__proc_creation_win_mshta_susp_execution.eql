any where (process.executable:"*\\mshta.exe" or process.pe.original_file_name:"mshta.exe") and (process.command_line like~ ("*.7z*", "*.avi*", "*.bat*", "*.bmp*", "*.conf*", "*.csv*", "*.dll*", "*.doc*", "*.gif*", "*.gz*", "*.ini*", "*.jpe*", "*.jpg*", "*.json*", "*.lnk*", "*.log*", "*.mkv*", "*.mp3*", "*.mp4*", "*.pdf*", "*.png*", "*.ppt*", "*.rar*", "*.rtf*", "*.svg*", "*.tar*", "*.tmp*", "*.txt*", "*.xls*", "*.xml*", "*.yaml*", "*.yml*", "*.zip*", "*vbscript*"))
