any where ((process.executable like~ ("*\\powershell.exe", "*\\pwsh.exe")) or (process.pe.original_file_name like~ ("PowerShell.EXE", "pwsh.dll"))) and ((process.command_line:"* -e*" and (process.command_line like~ ("* JAB*", "* SUVYI*", "* SQBFAFgA*", "* aQBlAHgA*", "* aWV4I*", "* IAA*", "* IAB*", "* UwB*", "* cwB*"))) or (process.command_line like~ ("*.exe -ENCOD *", "* BA^J e-*"))) and (not process.command_line:"* -ExecutionPolicy remotesigned *")
