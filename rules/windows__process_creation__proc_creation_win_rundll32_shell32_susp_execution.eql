any where (process.executable:"*\\rundll32.exe" or process.pe.original_file_name:"RUNDLL32.EXE") and ((process.command_line:"*shell32.dll*" and process.command_line:"*Control_RunDLL*") and (process.command_line like~ ("*%AppData%*", "*%LocalAppData%*", "*%Temp%*", "*%tmp%*", "*\\AppData\*", "*\\Temp\*", "*\\Users\\Public\*")))
