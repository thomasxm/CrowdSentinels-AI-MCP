any where process.parent.executable:"*\\wbem\\WmiPrvSE.exe" and ((process.executable like~ ("*\\certutil.exe", "*\\cscript.exe", "*\\mshta.exe", "*\\msiexec.exe", "*\\regsvr32.exe", "*\\rundll32.exe", "*\\verclsid.exe", "*\\wscript.exe")) or (process.executable:"*\\cmd.exe" and (process.command_line like~ ("*cscript*", "*mshta*", "*powershell*", "*pwsh*", "*regsvr32*", "*rundll32*", "*wscript*")))) and (not (process.executable:"*\\WerFault.exe" or process.executable:"*\\WmiPrvSE.exe" or (process.executable:"*\\msiexec.exe" and process.command_line:"*/i *")))
