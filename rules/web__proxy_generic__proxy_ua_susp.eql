any where ((c-useragent like~ ("user-agent*", "Mozilla/3.0 *", "Mozilla/2.0 *", "Mozilla/1.0 *", "Mozilla *", " Mozilla/*", "Mozila/*", "Mozilla/4.0 (compatible; MSIE 6.0; MS Web Services Client Protocol*")) or (c-useragent like~ ("* (compatible;MSIE *", "*.0;Windows NT *", "*loader*")) or (c-useragent like~ ("_", "CertUtil URL Agent", "Mozilla/5.0 (Windows NT 10.0; Win64; x64; rv:60.0)", "Mozilla/5.0 (Windows NT 6.3; WOW64; rv:28.0) Gecko/20100101 Firefox/28.0", "HTTPS", "Erbium-UA-4ce7c27cb4be9d32e333bf032c88235a", "x", "xxx"))) and (not (c-useragent:"Mozilla/3.0 * Acrobat *" or (cs-host like~ ("*.acrobat.com", "*.adobe.com", "*.adobe.io"))))
