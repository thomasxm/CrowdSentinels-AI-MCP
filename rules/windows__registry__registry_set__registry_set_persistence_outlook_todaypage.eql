any where (registry.path:"*Software\\Microsoft\\Office\*" and registry.path:"*\\Outlook\\Today\*") and ((registry.path:"*\\Stamp" and winlog.event_data.Details:"DWORD (0x00000001)") or (registry.path like~ ("*\\URL", "*\\UserDefinedUrl"))) and (not ((process.executable like~ ("C:\\Program Files\\Common Files\\Microsoft Shared\\ClickToRun\*", "C:\\Program Files\\Common Files\\Microsoft Shared\\ClickToRun\\Updates\*")) and process.executable:"*\\OfficeClickToRun.exe"))
