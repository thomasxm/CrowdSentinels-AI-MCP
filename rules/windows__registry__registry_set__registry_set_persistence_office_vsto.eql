any where (registry.path like~ ("*\\Software\\Microsoft\\Office\\Outlook\\Addins\*", "*\\Software\\Microsoft\\Office\\Word\\Addins\*", "*\\Software\\Microsoft\\Office\\Excel\\Addins\*", "*\\Software\\Microsoft\\Office\\Powerpoint\\Addins\*", "*\\Software\\Microsoft\\VSTO\\Security\\Inclusion\*")) and (not ((process.executable like~ ("C:\\Windows\\System32\\msiexec.exe", "C:\\Windows\\SysWOW64\\msiexec.exe", "C:\\Windows\\System32\\regsvr32.exe", "C:\\Windows\\SysWOW64\\regsvr32.exe")) or ((process.executable like~ ("C:\\Program Files\\Common Files (x86)\\Microsoft Shared\\ClickToRun\*", "C:\\Program Files\\Common Files\\Microsoft Shared\\ClickToRun\*")) and process.executable:"*\\OfficeClickToRun.exe") or (process.executable like~ ("C:\\Program Files (x86)\\Microsoft Office\\root\\integration\\integrator.exe", "C:\\Program Files\\Microsoft Office\\root\\integration\\integrator.exe")) or ((process.executable like~ ("C:\\Program Files\\Microsoft Office\\OFFICE*", "C:\\Program Files (x86)\\Microsoft Office\\OFFICE*", "C:\\Program Files\\Microsoft Office\\Root\\OFFICE*", "C:\\Program Files (x86)\\Microsoft Office\\Root\\OFFICE*")) and (process.executable like~ ("*\\excel.exe", "*\\Integrator.exe", "*\\outlook.exe", "*\\powerpnt.exe", "*\\Teams.exe", "*\\visio.exe", "*\\winword.exe"))))) and (not (((process.executable like~ ("C:\\Program Files\\AVG\\Antivirus\\RegSvr.exe", "C:\\Program Files (x86)\\AVG\\Antivirus\\RegSvr.exe")) and registry.path:"*\\Microsoft\\Office\\Outlook\\Addins\\Antivirus.AsOutExt\*") or ((process.executable like~ ("C:\\Program Files\\Avast Software\\Avast\\RegSvr.exe", "C:\\Program Files (x86)\\Avast Software\\Avast\\RegSvr.exe")) and registry.path:"*\\Microsoft\\Office\\Outlook\\Addins\\Avast.AsOutExt\*")))
