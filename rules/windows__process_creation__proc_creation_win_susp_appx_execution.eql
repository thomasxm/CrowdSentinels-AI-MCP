any where process.parent.executable:"*C:\\Program Files\\WindowsApps\*" and ((process.executable like~ ("*\\cmd.exe", "*\\cscript.exe", "*\\mshta.exe", "*\\powershell.exe", "*\\powershell_ise.exe", "*\\pwsh.exe", "*\\regsvr32.exe", "*\\rundll32.exe", "*\\wscript.exe")) or (process.command_line like~ ("*cmd /c*", "*Invoke-*", "*Base64*"))) and (not ((process.parent.executable:"*:\\Program Files\\WindowsApps\\Microsoft.WindowsTerminal*" and process.parent.executable:"*\\WindowsTerminal.exe" and (process.executable like~ ("*\\powershell.exe", "*\\cmd.exe", "*\\pwsh.exe"))) or (process.parent.executable:"C:\\Program Files\\WindowsApps\\Microsoft.SysinternalsSuite*" and process.executable:"*\\cmd.exe")))
