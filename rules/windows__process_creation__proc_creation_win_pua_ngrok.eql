any where (process.command_line like~ ("* tcp 139*", "* tcp 445*", "* tcp 3389*", "* tcp 5985*", "* tcp 5986*")) or (process.command_line:"* start *" and process.command_line:"*--all*" and process.command_line:"*--config*" and process.command_line:"*.yml*") or (process.executable:"*ngrok.exe" and (process.command_line like~ ("* tcp *", "* http *", "* authtoken *"))) or (process.command_line like~ ("*.exe authtoken *", "*.exe start --all*"))
