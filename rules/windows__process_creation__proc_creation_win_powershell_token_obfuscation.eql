any where (process.command_line like~ ("SigmaRegularExpression(regexp=SigmaString(['\\w+`(\\w+|-|.)`[\\w+|\\s]']), flags=set())", "SigmaRegularExpression(regexp=SigmaString(['\"(\\{\\d\\})+\"\\s', <SpecialChars.WILDCARD_MULTI: 1>, '-f']), flags=set())", "SigmaRegularExpression(regexp=SigmaString(['(', <SpecialChars.WILDCARD_SINGLE: 2>, 'i)\\$\\{`', <SpecialChars.WILDCARD_SINGLE: 2>, 'e`', <SpecialChars.WILDCARD_SINGLE: 2>, 'n`', <SpecialChars.WILDCARD_SINGLE: 2>, 'v`', <SpecialChars.WILDCARD_SINGLE: 2>, ':`', <SpecialChars.WILDCARD_SINGLE: 2>, 'p`', <SpecialChars.WILDCARD_SINGLE: 2>, 'a`', <SpecialChars.WILDCARD_SINGLE: 2>, 't`', <SpecialChars.WILDCARD_SINGLE: 2>, 'h`', <SpecialChars.WILDCARD_SINGLE: 2>, '\\}']), flags=set())")) and (not process.command_line:"*${env:path}*")
