any where ((ParentImage like~ ("*com.apple.WebKit.WebContent*", "*firefox*", "*Google Chrome Helper*", "*Google Chrome*", "*Microsoft Edge*", "*Opera*", "*Safari*", "*Tor Browser*")) and (Image like~ ("*/bash", "*/curl", "*/dash", "*/ksh", "*/osascript", "*/perl", "*/php", "*/pwsh", "*/python", "*/sh", "*/tcsh", "*/wget", "*/zsh"))) and (not (CommandLine:"*--defaults-torrc*" or CommandLine:"*/Library/Application Support/Microsoft/MAU*/Microsoft AutoUpdate.app/Contents/MacOS/msupdate*" or ((ParentImage like~ ("*Google Chrome Helper*", "*Google Chrome*")) and (CommandLine like~ ("*/Volumes/Google Chrome/Google Chrome.app/Contents/Frameworks/*/Resources/install.sh*", "*/Applications/Google Chrome.app/Contents/Frameworks/Google Chrome Framework.framework/*/Resources/keystone_promote_preflight.sh*", "*/Applications/Google Chrome.app/Contents/Frameworks/Google Chrome Framework.framework/*/Resources/keystone_promote_postflight.sh*"))) or (ParentImage:"*Microsoft Edge*" and (CommandLine like~ ("*IOPlatformExpertDevice*", "*hw.model*"))) or ((ParentImage like~ ("*Google Chrome Helper*", "*Google Chrome*")) and (CommandLine:"*/Users/*" and CommandLine:"*/Library/Application Support/Google/Chrome/recovery/*" and CommandLine:"*/ChromeRecovery*")))) and (not ((?CommandLine == null) or CommandLine==""))
