any where (process.executable:"*\\pwsh.exe" or process.pe.original_file_name:"pwsh.dll") and (process.command_line like~ ("*-SecurityDescriptorSddl *", "*-sd *")) and ((process.command_line:"*Set-Service *" and process.command_line:"*D;;*") and (process.command_line like~ ("*;;;IU*", "*;;;SU*", "*;;;BA*", "*;;;SY*", "*;;;WD*")))
