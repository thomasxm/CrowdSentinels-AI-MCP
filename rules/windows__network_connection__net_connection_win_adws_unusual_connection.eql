any where (network.direction:"egress" and destination.port:9389) and (not (process.executable:"C:\\Windows\\system32\\dsac.exe" or process.executable:"C:\\Program Files\\Microsoft Monitoring Agent\\" or (process.executable like~ ("C:\\Program Files\\PowerShell\\7\\pwsh.exe*", "C:\\Program Files\\PowerShell\\7-preview\\pwsh.ex*", "C:\\Windows\\System32\\WindowsPowerShell\*", "C:\\Windows\\SysWOW64\\WindowsPowerShell\*"))))
