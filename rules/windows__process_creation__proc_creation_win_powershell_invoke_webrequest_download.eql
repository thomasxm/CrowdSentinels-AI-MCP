any where ((process.executable like~ ("*\\powershell_ise.exe", "*\\powershell.exe", "*\\pwsh.exe")) or (process.pe.original_file_name like~ ("powershell_ise.EXE", "PowerShell.EXE", "pwsh.dll"))) and (process.command_line like~ ("*curl *", "*Invoke-WebRequest*", "*iwr *", "*wget *")) and (process.command_line like~ ("* -ur*", "* -o*")) and (process.command_line like~ ("*\\AppData\*", "*\\Desktop\*", "*\\Temp\*", "*\\Users\\Public\*", "*%AppData%*", "*%Public%*", "*%Temp%*", "*%tmp%*", "*:\\Windows\*"))
