any where ((process.executable like~ ("*\\powershell.exe", "*\\powershell_ise.exe", "*\\pwsh.exe")) or (process.pe.original_file_name like~ ("PowerShell.Exe", "pwsh.dll"))) and (process.command_line like~ ("*Add-AADInt*", "*ConvertTo-AADInt*", "*Disable-AADInt*", "*Enable-AADInt*", "*Export-AADInt*", "*Find-AADInt*", "*Get-AADInt*", "*Grant-AADInt*", "*Initialize-AADInt*", "*Install-AADInt*", "*Invoke-AADInt*", "*Join-AADInt*", "*New-AADInt*", "*Open-AADInt*", "*Read-AADInt*", "*Register-AADInt*", "*Remove-AADInt*", "*Reset-AADInt*", "*Resolve-AADInt*", "*Restore-AADInt*", "*Save-AADInt*", "*Search-AADInt*", "*Send-AADInt*", "*Set-AADInt*", "*Start-AADInt*", "*Unprotect-AADInt*", "*Update-AADInt*"))
