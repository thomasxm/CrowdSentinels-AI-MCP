any where ((process.executable like~ ("*\\cmd.exe", "*\\cscript.exe", "*\\powershell.exe", "*\\powershell_ise.exe", "*\\pwsh.exe", "*\\wscript.exe")) and (process.pe.original_file_name like~ ("Cmd.EXE", "cscript.exe", "PowerShell.EXE", "PowerShell_ISE.EXE", "pwsh.dll", "wscript.exe"))) and (process.command_line like~ ("*ˣ*", "*˪*", "*ˢ*", "*∕*", "*⁄*", "*―*", "*—*", "* *", "*¯*", "*®*", "*¶*", "*⠀*"))
