any where (((process.parent.executable like~ ("*\\winlogon.exe", "*\\services.exe", "*\\lsass.exe", "*\\csrss.exe", "*\\smss.exe", "*\\wininit.exe", "*\\spoolsv.exe", "*\\searchindexer.exe")) and (user.name like~ ("*AUTHORI*", "*AUTORI*"))) and ((process.executable like~ ("*\\powershell.exe", "*\\pwsh.exe", "*\\cmd.exe")) or (process.pe.original_file_name like~ ("PowerShell.EXE", "pwsh.dll", "Cmd.Exe")))) and (not (process.command_line:"* route *" and process.command_line:"* ADD *"))
