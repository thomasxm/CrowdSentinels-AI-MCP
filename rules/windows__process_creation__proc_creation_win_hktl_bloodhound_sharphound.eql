any where (process.pe.product:"*SharpHound*" or process.pe.description:"*SharpHound*" or (process.pe.company like~ ("*SpecterOps*", "*evil corp*")) or (process.executable like~ ("*\\Bloodhound.exe*", "*\\SharpHound.exe*"))) or (process.command_line like~ ("* -CollectionMethod All *", "* --CollectionMethods Session *", "* --Loop --Loopduration *", "* --PortScanTimeout *", "*.exe -c All -d *", "*Invoke-Bloodhound*", "*Get-BloodHoundData*")) or (process.command_line:"* -JsonFolder *" and process.command_line:"* -ZipFileName *") or (process.command_line:"* DCOnly *" and process.command_line:"* --NoSaveCache *")
