any where (process.command_line like~ ("* -ma *", "* /ma *", "* –ma *", "* —ma *", "* ―ma *") or process.command_line like~ ("* -mm *", "* /mm *", "* –mm *", "* —mm *", "* ―mm *") or process.command_line like~ ("* -mp *", "* /mp *", "* –mp *", "* —mp *", "* ―mp *")) and (process.command_line like~ ("* ls*", "* keyiso*", "* samss*"))
