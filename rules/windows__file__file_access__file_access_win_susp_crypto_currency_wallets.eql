any where ((file.path like~ ("*\\AppData\\Roaming\\Ethereum\\keystore\*", "*\\AppData\\Roaming\\EthereumClassic\\keystore\*", "*\\AppData\\Roaming\\monero\\wallets\*")) or (file.path like~ ("*\\AppData\\Roaming\\Bitcoin\\wallet.dat", "*\\AppData\\Roaming\\BitcoinABC\\wallet.dat", "*\\AppData\\Roaming\\BitcoinSV\\wallet.dat", "*\\AppData\\Roaming\\DashCore\\wallet.dat", "*\\AppData\\Roaming\\DogeCoin\\wallet.dat", "*\\AppData\\Roaming\\Litecoin\\wallet.dat", "*\\AppData\\Roaming\\Ripple\\wallet.dat", "*\\AppData\\Roaming\\Zcash\\wallet.dat"))) and (not (process.executable:"System" or (process.executable like~ ("C:\\Program Files (x86)\*", "C:\\Program Files\*", "C:\\Windows\\system32\*", "C:\\Windows\\SysWOW64\*")))) and (not (process.executable:"C:\\ProgramData\\Microsoft\\Windows Defender\*" and (process.executable like~ ("*\\MpCopyAccelerator.exe", "*\\MsMpEng.exe"))))
