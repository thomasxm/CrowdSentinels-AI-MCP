any where (process.command_line:"*REG*" and process.command_line:"*ADD*" and process.command_line:"*\\SOFTWARE\\Policies\\Microsoft\\FVE*" and process.command_line:"*/v*" and process.command_line:"*/f*") and (process.command_line like~ ("*EnableBDEWithNoTPM*", "*UseAdvancedStartup*", "*UseTPM*", "*UseTPMKey*", "*UseTPMKeyPIN*", "*RecoveryKeyMessageSource*", "*UseTPMPIN*", "*RecoveryKeyMessage*"))
