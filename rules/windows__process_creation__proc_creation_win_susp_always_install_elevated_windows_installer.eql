any where (((process.executable:"*\\Windows\\Installer\*" and process.executable:"*msi*") and process.executable:"*tmp") or (process.executable:"*\\msiexec.exe" and (winlog.event_data.IntegrityLevel like~ ("System", "S-1-16-16384")))) and (user.name like~ ("*AUTHORI*", "*AUTORI*")) and (not (process.parent.executable:"C:\\Windows\\System32\\services.exe" or (process.command_line:"*\\system32\\msiexec.exe /V" or process.parent.command_line:"*\\system32\\msiexec.exe /V") or process.parent.executable:"C:\\ProgramData\\Sophos\*" or process.parent.executable:"C:\\ProgramData\\Avira\*" or (process.parent.executable like~ ("C:\\Program Files\\Avast Software\*", "C:\\Program Files (x86)\\Avast Software\*")) or (process.parent.executable like~ ("C:\\Program Files\\Google\\Update\*", "C:\\Program Files (x86)\\Google\\Update\*"))))
