any where ((process.executable like~ ("*\\cscript.exe", "*\\mshta.exe", "*\\wscript.exe")) or (process.command_line like~ ("* -ep bypass *", "* -ExecutionPolicy bypass *", "* -w hidden *", "*/e:javascript *", "*/e:Jscript *", "*/e:vbscript *")) or (process.pe.original_file_name like~ ("cscript.exe", "mshta.exe", "wscript.exe"))) and ((process.command_line like~ ("*:\\Perflogs\*", "*:\\Users\\Public\*", "*\\AppData\\Local\\Temp*", "*\\AppData\\Roaming\\Temp*", "*\\Temporary Internet*", "*\\Windows\\Temp*")) or ((process.command_line:"*:\\Users\*" and process.command_line:"*\\Favorites\*") or (process.command_line:"*:\\Users\*" and process.command_line:"*\\Favourites\*") or (process.command_line:"*:\\Users\*" and process.command_line:"*\\Contacts\*")))
