any where ((registry.path like~ ("*\\SOFTWARE\\Microsoft\\Cryptography\\Providers\*", "*\\SOFTWARE\\Microsoft\\Cryptography\\OID\\EncodingType*", "*\\SOFTWARE\\WOW6432Node\\Microsoft\\Cryptography\\Providers\*", "*\\SOFTWARE\\WOW6432Node\\Microsoft\\Cryptography\\OID\\EncodingType*")) and (registry.path like~ ("*\\Dll*", "*\\$DLL*"))) and (not ((winlog.event_data.Details like~ ("WINTRUST.DLL", "mso.dll")) or (process.executable:"C:\\Windows\\System32\\poqexec.exe" and registry.path:"*\\CryptSIPDll*" and winlog.event_data.Details:"C:\\Windows\\System32\\PsfSip.dll")))
