any where ((process.executable like~ ("*\\powershell.exe", "*\\pwsh.exe")) or (process.pe.original_file_name like~ ("PowerShell.EXE", "pwsh.dll")) or process.pe.description:"Windows PowerShell" or process.pe.product:"PowerShell Core 6") and process.command_line:"*bxor*" and (process.command_line like~ ("*ForEach*", "*for(*", "*for *", "*-join *", "*-join'*", "*-join\"*", "*-join`*", "*::Join*", "*[char]*"))
