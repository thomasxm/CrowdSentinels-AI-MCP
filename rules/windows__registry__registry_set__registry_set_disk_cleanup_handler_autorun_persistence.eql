any where registry.path:"*\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Explorer\\VolumeCaches\*" and ((registry.path:"*\\Autorun*" and winlog.event_data.Details:"DWORD (0x00000001)") or ((registry.path like~ ("*\\CleanupString*", "*\\PreCleanupString*")) and (winlog.event_data.Details like~ ("*cmd*", "*powershell*", "*rundll32*", "*mshta*", "*cscript*", "*wscript*", "*wsl*", "*\\Users\\Public\*", "*\\Windows\\TEMP\*", "*\\Microsoft\\Windows\\Start Menu\\Programs\\Startup\*"))))
