any where ((process.executable like~ ("*\\AnyDesk.exe", "*\\AnyDeskMSI.exe")) or process.pe.description:"AnyDesk" or process.pe.product:"AnyDesk" or process.pe.company:"AnyDesk Software GmbH") and (not (process.executable like~ ("*\\AppData\*", "*Program Files (x86)\\AnyDesk*", "*Program Files\\AnyDesk*")))
