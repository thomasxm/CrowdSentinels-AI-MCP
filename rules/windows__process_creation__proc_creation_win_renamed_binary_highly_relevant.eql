any where (process.pe.description:"Execute processes remotely" or process.pe.product:"Sysinternals PsExec" or (process.pe.description like~ ("Windows PowerShell*", "pwsh*")) or (process.pe.original_file_name like~ ("certutil.exe", "cmstp.exe", "cscript.exe", "IE4UINIT.EXE", "mshta.exe", "msiexec.exe", "msxsl.exe", "powershell_ise.exe", "powershell.exe", "psexec.c", "psexec.exe", "psexesvc.exe", "pwsh.dll", "reg.exe", "regsvr32.exe", "rundll32.exe", "WerMgr", "wmic.exe", "wscript.exe"))) and (not (process.executable like~ ("*\\certutil.exe", "*\\cmstp.exe", "*\\cscript.exe", "*\\ie4uinit.exe", "*\\mshta.exe", "*\\msiexec.exe", "*\\msxsl.exe", "*\\powershell_ise.exe", "*\\powershell.exe", "*\\psexec.exe", "*\\psexec64.exe", "*\\PSEXESVC.exe", "*\\pwsh.exe", "*\\reg.exe", "*\\regsvr32.exe", "*\\rundll32.exe", "*\\wermgr.exe", "*\\wmic.exe", "*\\wscript.exe")))
