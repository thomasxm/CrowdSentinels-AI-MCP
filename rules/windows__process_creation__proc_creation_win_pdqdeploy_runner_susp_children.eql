any where process.parent.executable:"*\\PDQDeployRunner-*" and ((process.executable like~ ("*\\bash.exe", "*\\certutil.exe", "*\\cmd.exe", "*\\csc.exe", "*\\cscript.exe", "*\\dllhost.exe", "*\\mshta.exe", "*\\msiexec.exe", "*\\regsvr32.exe", "*\\rundll32.exe", "*\\scriptrunner.exe", "*\\wmic.exe", "*\\wscript.exe", "*\\wsl.exe")) or (process.executable like~ ("*:\\ProgramData\*", "*:\\Users\\Public\*", "*:\\Windows\\TEMP\*", "*\\AppData\\Local\\Temp*")) or (process.command_line like~ ("* -decode *", "* -enc *", "* -encodedcommand *", "* -w hidden*", "*DownloadString*", "*FromBase64String*", "*http*", "*iex *", "*Invoke-*")))
