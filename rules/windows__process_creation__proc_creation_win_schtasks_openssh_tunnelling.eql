any where (process.executable:"*\\schtasks.exe" or process.pe.original_file_name:"schtasks.exe") and ((process.command_line:"* /create *" and process.command_line:"*sshd.exe*" and process.command_line:"*-f*") or (process.command_line:"* /create *" and process.command_line:"*ssh.exe*" and process.command_line:"*-i*"))
