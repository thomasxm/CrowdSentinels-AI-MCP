any where (process.pe.original_file_name:"winPEAS.exe" or (process.executable like~ ("*\\winPEASany_ofs.exe", "*\\winPEASany.exe", "*\\winPEASx64_ofs.exe", "*\\winPEASx64.exe", "*\\winPEASx86_ofs.exe", "*\\winPEASx86.exe"))) or (process.command_line like~ ("* applicationsinfo*", "* browserinfo*", "* eventsinfo*", "* fileanalysis*", "* filesinfo*", "* processinfo*", "* servicesinfo*", "* windowscreds*")) or process.command_line:"*https://github.com/carlospolop/PEASS-ng/releases/latest/download/*" or (process.parent.command_line:"* -linpeas" or process.command_line:"* -linpeas")
