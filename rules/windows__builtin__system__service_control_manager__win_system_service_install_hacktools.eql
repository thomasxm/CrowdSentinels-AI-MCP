any where winlog.channel:"System" and ((winlog.provider_name:"Service Control Manager" and (event.code like~ ("7045", "7036"))) and ((winlog.event_data.ServiceName like~ ("*cachedump*", "*DumpSvc*", "*gsecdump*", "*pwdump*", "*UACBypassedService*", "*WCE SERVICE*", "*WCESERVICE*", "*winexesvc*")) or winlog.event_data.ImagePath:"*bypass*"))
