any where (process.executable:"*driverquery.exe" or process.pe.original_file_name:"drvqry.exe") and ((process.parent.executable like~ ("*\\cscript.exe", "*\\mshta.exe", "*\\regsvr32.exe", "*\\rundll32.exe", "*\\wscript.exe")) or (process.parent.executable like~ ("*\\AppData\\Local\*", "*\\Users\\Public\*", "*\\Windows\\Temp\*")))
