any where winlog.channel:"Security" and (event.code:"4625" and (not (source.ip:"*-*" or (cidrMatch(source.ip, "::1/128") or cidrMatch(source.ip, "10.0.0.0/8") or cidrMatch(source.ip, "127.0.0.0/8") or cidrMatch(source.ip, "172.16.0.0/12") or cidrMatch(source.ip, "192.168.0.0/16") or cidrMatch(source.ip, "169.254.0.0/16") or cidrMatch(source.ip, "fc00::/7") or cidrMatch(source.ip, "fe80::/10")))))
