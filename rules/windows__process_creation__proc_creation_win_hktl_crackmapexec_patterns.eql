any where ((process.command_line:"*tasklist /fi *" and process.command_line:"*Imagename eq lsass.exe*") and (process.command_line like~ ("*cmd.exe /c *", "*cmd.exe /r *", "*cmd.exe /k *", "*cmd /c *", "*cmd /r *", "*cmd /k *")) and (user.name like~ ("*AUTHORI*", "*AUTORI*"))) or (process.command_line:"*do rundll32.exe C:\\windows\\System32\\comsvcs.dll, MiniDump*" and process.command_line:"*\\Windows\\Temp\*" and process.command_line:"* full*" and process.command_line:"*%%B*") or (process.command_line:"*tasklist /v /fo csv*" and process.command_line:"*findstr /i \"lsass\"*")
