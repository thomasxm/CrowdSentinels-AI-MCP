any where ((process.pe.original_file_name like~ ("Excel.exe", "MSACCESS.EXE", "MSPUB.EXE", "OneNote.exe", "OneNoteM.exe", "OUTLOOK.EXE", "POWERPNT.EXE", "WinWord.exe", "Olk.exe")) or (process.pe.description like~ ("Microsoft Access", "Microsoft Excel", "Microsoft OneNote", "Microsoft Outlook", "Microsoft PowerPoint", "Microsoft Publisher", "Microsoft Word", "Sent to OneNote Tool"))) and (not (process.executable like~ ("*\\EXCEL.exe", "*\\excelcnv.exe", "*\\MSACCESS.exe", "*\\MSPUB.EXE", "*\\ONENOTE.EXE", "*\\ONENOTEM.EXE", "*\\OUTLOOK.EXE", "*\\POWERPNT.EXE", "*\\WINWORD.exe", "*\\OLK.EXE")))
