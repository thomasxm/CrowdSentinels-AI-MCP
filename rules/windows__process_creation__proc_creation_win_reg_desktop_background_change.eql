any where ((process.executable:"*\\reg.exe" or process.pe.original_file_name:"reg.exe") and process.command_line:"*add*") and (process.command_line like~ ("*Control Panel\\Desktop*", "*CurrentVersion\\Policies\\ActiveDesktop*", "*CurrentVersion\\Policies\\System*")) and ((process.command_line:"*/v NoChangingWallpaper*" and process.command_line:"*/d 1*") or (process.command_line:"*/v Wallpaper*" and process.command_line:"*/t REG_SZ*") or (process.command_line:"*/v WallpaperStyle*" and process.command_line:"*/d 2*"))
