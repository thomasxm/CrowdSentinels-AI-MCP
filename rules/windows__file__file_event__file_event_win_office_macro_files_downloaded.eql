any where (process.executable like~ ("*\\RuntimeBroker.exe", "*\\outlook.exe", "*\\thunderbird.exe", "*\\brave.exe", "*\\chrome.exe", "*\\firefox.exe", "*\\iexplore.exe", "*\\maxthon.exe", "*\\MicrosoftEdge.exe", "*\\msedge.exe", "*\\msedgewebview2.exe", "*\\opera.exe", "*\\safari.exe", "*\\seamonkey.exe", "*\\vivaldi.exe", "*\\whale.exe")) and ((file.path like~ ("*.docm", "*.dotm", "*.xlsm", "*.xltm", "*.potm", "*.pptm")) or (file.path like~ ("*.docm:Zone*", "*.dotm:Zone*", "*.xlsm:Zone*", "*.xltm:Zone*", "*.potm:Zone*", "*.pptm:Zone*")))
