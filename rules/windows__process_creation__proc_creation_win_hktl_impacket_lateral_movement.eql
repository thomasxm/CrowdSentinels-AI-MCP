any where ((process.parent.executable like~ ("*\\wmiprvse.exe", "*\\mmc.exe", "*\\explorer.exe", "*\\services.exe")) and (process.command_line:"*cmd.exe*" and process.command_line:"*/Q*" and process.command_line:"*/c*" and process.command_line:"*\\127.0.0.1\*" and process.command_line:"*&1*")) or ((process.parent.command_line like~ ("*svchost.exe -k netsvcs*", "*taskeng.exe*")) and (process.command_line:"*cmd.exe*" and process.command_line:"*/C*" and process.command_line:"*Windows\\Temp\*" and process.command_line:"*&1*"))
