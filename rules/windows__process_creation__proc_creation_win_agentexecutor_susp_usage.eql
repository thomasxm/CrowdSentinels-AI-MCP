any where ((process.executable:"*\\AgentExecutor.exe" or process.pe.original_file_name:"AgentExecutor.exe") and (process.command_line like~ ("* -powershell*", "* -remediationScript*"))) and (not ((process.command_line like~ ("*C:\\Windows\\System32\\WindowsPowerShell\\v1.0\*", "*C:\\Windows\\SysWOW64\\WindowsPowerShell\\v1.0\*")) or process.parent.executable:"*\\Microsoft.Management.Services.IntuneWindowsAgent.exe"))
