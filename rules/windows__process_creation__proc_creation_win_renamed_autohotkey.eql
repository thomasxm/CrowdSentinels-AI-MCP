any where (process.pe.product:"*AutoHotkey*" or process.pe.description:"*AutoHotkey*" or (process.pe.original_file_name like~ ("AutoHotkey.exe", "AutoHotkey.rc"))) and (not ((process.executable like~ ("*\\AutoHotkey.exe", "*\\AutoHotkey32.exe", "*\\AutoHotkey32_UIA.exe", "*\\AutoHotkey64.exe", "*\\AutoHotkey64_UIA.exe", "*\\AutoHotkeyA32.exe", "*\\AutoHotkeyA32_UIA.exe", "*\\AutoHotkeyU32.exe", "*\\AutoHotkeyU32_UIA.exe", "*\\AutoHotkeyU64.exe", "*\\AutoHotkeyU64_UIA.exe")) or process.executable:"*\\AutoHotkey*"))
