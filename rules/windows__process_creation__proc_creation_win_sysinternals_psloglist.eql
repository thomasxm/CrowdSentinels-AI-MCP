any where (process.pe.original_file_name:"psloglist.exe" or (process.executable like~ ("*\\psloglist.exe", "*\\psloglist64.exe"))) and (process.command_line like~ ("* security*", "* application*", "* system*")) and (process.command_line like~ ("* -d*", "* /d*", "* –d*", "* —d*", "* ―d*") or process.command_line like~ ("* -x*", "* /x*", "* –x*", "* —x*", "* ―x*") or process.command_line like~ ("* -s*", "* /s*", "* –s*", "* —s*", "* ―s*") or process.command_line like~ ("* -c*", "* /c*", "* –c*", "* —c*", "* ―c*") or process.command_line like~ ("* -g*", "* /g*", "* –g*", "* —g*", "* ―g*"))
