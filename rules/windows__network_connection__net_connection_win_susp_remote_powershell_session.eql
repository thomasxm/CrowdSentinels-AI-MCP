any where ((destination.port like~ (5985, 5986)) and network.direction:"true" and winlog.event_data.SourceIsIpv6:"false") and (not (((user.name like~ ("*NETWORK SERVICE*", "*NETZWERKDIENST*", "*SERVICIO DE RED*", "*SERVIZIO DI RETE*")) or (user.name:"*SERVICE R*" and user.name:"*SEAU*")) or ((source.ip like~ ("::1", "127.0.0.1")) and (destination.ip like~ ("::1", "127.0.0.1"))))) and (not (process.executable like~ ("C:\\Program Files\\Avast Software\\Avast\\AvastSvc.exe", "C:\\Program Files (x86)\\Avast Software\\Avast\\AvastSvc.exe")))
