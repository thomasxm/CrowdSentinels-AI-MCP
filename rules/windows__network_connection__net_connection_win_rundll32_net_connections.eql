any where (process.executable:"*\\rundll32.exe" and network.direction:"true") and (not ((cidrMatch(destination.ip, "127.0.0.0/8") or cidrMatch(destination.ip, "10.0.0.0/8") or cidrMatch(destination.ip, "172.16.0.0/12") or cidrMatch(destination.ip, "192.168.0.0/16") or cidrMatch(destination.ip, "169.254.0.0/16") or cidrMatch(destination.ip, "::1/128") or cidrMatch(destination.ip, "fe80::/10") or cidrMatch(destination.ip, "fc00::/7")) or (cidrMatch(destination.ip, "20.0.0.0/8") or cidrMatch(destination.ip, "51.103.0.0/16") or cidrMatch(destination.ip, "51.104.0.0/16") or cidrMatch(destination.ip, "51.105.0.0/16")) or winlog.event_data.CommandLine:"*\\system32\\PcaSvc.dll,PcaPatchSdbTask" or source.domain:"*.internal.cloudapp.net" or (process.parent.executable:"C:\\Windows\\System32\\svchost.exe" and destination.port:443)))
