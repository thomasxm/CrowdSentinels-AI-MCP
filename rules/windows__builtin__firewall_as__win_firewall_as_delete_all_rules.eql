any where winlog.channel:"Microsoft-Windows-Windows Firewall With Advanced Security/Firewall" and ((event.code like~ ("2033", "2059")) and (not winlog.event_data.ModifyingApplication:"*:\\Windows\\System32\\svchost.exe") and (not (winlog.event_data.ModifyingApplication:"*:\\ProgramData\\Microsoft\\Windows Defender\\Platform\*" and winlog.event_data.ModifyingApplication:"*\\MsMpEng.exe*")))
