any where ((process.executable like~ ("*\\cscript.exe", "*\\mshta.exe", "*\\regsvr32.exe", "*\\rundll32.exe", "*\\wscript.exe")) or (process.parent.executable like~ ("*\\cscript.exe", "*\\mshta.exe", "*\\regsvr32.exe", "*\\rundll32.exe", "*\\wscript.exe"))) and (file.path like~ ("*.docm", "*.dotm", "*.xlsm", "*.xltm", "*.potm", "*.pptm"))
