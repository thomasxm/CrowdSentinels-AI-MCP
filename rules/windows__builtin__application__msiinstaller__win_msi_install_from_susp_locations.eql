any where winlog.channel:"Application" and ((winlog.provider_name:"MsiInstaller" and (event.code like~ ("1040", "1042")) and (winlog.event_data.Data like~ ("*:\\Windows\\TEMP\*", "*\\*", "*\\Desktop\*", "*\\PerfLogs\*", "*\\Users\\Public\*"))) and (not (winlog.event_data.Data like~ ("*\\AppData\\Local\\Temp\\WinGet\*", "*C:\\Windows\\TEMP\\UpdHealthTools.msi*"))))
