any where ((process.executable like~ ("*\\powershell.exe", "*\\powershell_ise.exe", "*\\pwsh.exe")) and (file.path like~ ("*.bat", "*.chm", "*.cmd", "*.com", "*.dll", "*.exe", "*.hta", "*.jar", "*.js", "*.ocx", "*.scr", "*.sys", "*.vbe", "*.vbs", "*.wsf"))) and (not ((file.path:"C:\\Users\*" and file.path:"*\\AppData\\Local\\Temp\*" and (file.path like~ ("*.dll", "*.exe"))) or ((file.path like~ ("C:\\Windows\\Temp\*", "C:\\Windows\\SystemTemp\*")) and (file.path like~ ("*.dll", "*.exe"))) or (file.path:"C:\\Users\*" and file.path:"*\\WindowsPowerShell\\Modules\*" and file.path:"*.dll") or (file.path:"C:\\Program Files\\PackageManagement\\ProviderAssemblies\\nuget\*" and file.path:"*\\Microsoft.PackageManagement.NuGetProvider.dll")))
