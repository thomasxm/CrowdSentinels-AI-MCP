any where powershell.file.script_block_text:"*\\SOFTWARE\\Policies\\Microsoft\\Windows\\System*" and (powershell.file.script_block_text like~ ("*GroupPolicyRefreshTimeDC*", "*GroupPolicyRefreshTimeOffsetDC*", "*GroupPolicyRefreshTime*", "*GroupPolicyRefreshTimeOffset*", "*EnableSmartScreen*", "*ShellSmartScreenLevel*"))
