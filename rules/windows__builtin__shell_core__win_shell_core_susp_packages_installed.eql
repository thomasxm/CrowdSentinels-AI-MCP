any where winlog.channel:"Microsoft-Windows-Shell-Core/Operational" and ((event.code:"28115" and (winlog.event_data.Name like~ ("*Zenmap*", "*AnyDesk*", "*wireshark*", "*openvpn*"))) or (event.code:"28115" and (winlog.event_data.AppID like~ ("*zenmap.exe*", "*prokzult ad*", "*wireshark*", "*openvpn*"))))
