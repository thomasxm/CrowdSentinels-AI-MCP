any where (file.path:"\*" and (file.path:"*\\sysvol\*" and file.path:"*\\Policies\*") and (file.path like~ ("*audit.csv", "*Files.xml", "*GptTmpl.inf", "*groups.xml", "*Registry.pol", "*Registry.xml", "*scheduledtasks.xml", "*scripts.ini", "*services.xml"))) and (not ((process.executable like~ ("C:\\Program Files (x86)\*", "C:\\Program Files\*", "C:\\Windows\\system32\*", "C:\\Windows\\SysWOW64\*")) or process.executable:"C:\\Windows\\explorer.exe"))
