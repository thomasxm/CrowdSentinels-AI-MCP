((process.executable:(*\\chrome.exe OR *\\code.exe OR *\\discord.exe OR *\\GitHubDesktop.exe OR *\\keybase.exe OR *\\msedge_proxy.exe OR *\\msedge.exe OR *\\msedgewebview2.exe OR *\\msteams.exe OR *\\slack.exe OR *\\Teams.exe)) OR (process.pe.original_file_name:(chrome.exe OR code.exe OR discord.exe OR GitHubDesktop.exe OR keybase.exe OR msedge_proxy.exe OR msedge.exe OR msedgewebview2.exe OR msteams.exe OR slack.exe OR Teams.exe))) AND (process.command_line:(*\-\-browser\-subprocess\-path* OR *\-\-gpu\-launcher* OR *\-\-renderer\-cmd\-prefix* OR *\-\-utility\-cmd\-prefix*))
