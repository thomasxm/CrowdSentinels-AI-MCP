any where (winlog.event_data.TargetImage:"*:\\Windows\\System32\\svchost.exe" and winlog.event_data.GrantedAccess:"0x1F3FFF" and winlog.event_data.CallTrace:"*UNKNOWN*") and (not (process.executable:"*:\\Program Files\\Microsoft Visual Studio\*" and process.executable:"*\\MSBuild\\Current\\Bin\\MSBuild.exe" and (winlog.event_data.CallTrace like~ ("*Microsoft.Build.ni.dll*", "*System.ni.dll*"))))
