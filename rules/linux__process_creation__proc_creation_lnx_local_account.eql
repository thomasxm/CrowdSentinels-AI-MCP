any where Image:"*/lastlog" or CommandLine:"*'x:0:'*" or ((Image like~ ("*/cat", "*/ed", "*/head", "*/more", "*/nano", "*/tail", "*/vi", "*/vim", "*/less", "*/emacs", "*/sqlite3", "*/makemap")) and (CommandLine like~ ("*/etc/passwd*", "*/etc/shadow*", "*/etc/sudoers*", "*/etc/spwd.db*", "*/etc/pwd.db*", "*/etc/master.passwd*"))) or Image:"*/id" or (Image:"*/lsof" and CommandLine:"*-u*")
