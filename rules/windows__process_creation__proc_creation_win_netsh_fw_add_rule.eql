any where ((process.executable:"*\\netsh.exe" or process.pe.original_file_name:"netsh.exe") and (process.command_line:"* firewall *" and process.command_line:"* add *")) and (not (process.command_line like~ ("*advfirewall firewall add rule name=Dropbox dir=in action=allow \"program=?:\\Program Files (x86)\\Dropbox\\Client\\Dropbox.exe\" enable=yes profile=Any*", "*advfirewall firewall add rule name=Dropbox dir=in action=allow \"program=?:\\Program Files\\Dropbox\\Client\\Dropbox.exe\" enable=yes profile=Any*")))
