any where (winlog.event_data.TargetImage like~ ("*\\calc.exe", "*\\calculator.exe", "*\\mspaint.exe", "*\\notepad.exe", "*\\ping.exe", "*\\sethc.exe", "*\\spoolsv.exe", "*\\wordpad.exe", "*\\write.exe")) and (not (process.executable:"C:\\Windows\\System32\\csrss.exe" or ((process.executable like~ ("C:\\Windows\\System32\\explorer.exe", "C:\\Windows\\System32\\OpenWith.exe")) and winlog.event_data.TargetImage:"C:\\Windows\\System32\\notepad.exe") or (process.executable:"C:\\Windows\\System32\\AtBroker.exe" and winlog.event_data.TargetImage:"C:\\Windows\\System32\\Sethc.exe"))) and (not (winlog.event_data.StartFunction:"EtwpNotificationThread" or process.executable:"*unknown process*" or (process.executable:"C:\\Program Files\\VMware\\VMware Tools\\vmtoolsd.exe" and winlog.event_data.StartFunction:"GetCommandLineW" and (winlog.event_data.TargetImage like~ ("C:\\Windows\\System32\\notepad.exe", "C:\\Windows\\System32\\spoolsv.exe"))) or (process.executable:"C:\\Program Files\\Xerox\\XeroxPrintExperience\\CommonFiles\\XeroxPrintJobEventManagerService.exe" and winlog.event_data.StartFunction:"LoadLibraryW" and winlog.event_data.TargetImage:"C:\\Windows\\System32\\spoolsv.exe")))
