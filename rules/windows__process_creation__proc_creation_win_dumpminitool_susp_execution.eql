any where ((process.executable like~ ("*\\DumpMinitool.exe", "*\\DumpMinitool.x86.exe", "*\\DumpMinitool.arm64.exe")) or (process.pe.original_file_name like~ ("DumpMinitool.exe", "DumpMinitool.x86.exe", "DumpMinitool.arm64.exe"))) and ((not (process.executable like~ ("*\\Microsoft Visual Studio\*", "*\\Extensions\*"))) or process.command_line:"*.txt*" or ((process.command_line like~ ("* Full*", "* Mini*", "* WithHeap*")) and (not process.command_line:"*--dumpType*")))
