any where (((process.executable like~ ("*\\csrss.exe", "*\\lsass.exe", "*\\RuntimeBroker.exe", "*\\sihost.exe", "*\\smss.exe", "*\\wininit.exe", "*\\winlogon.exe")) and (file.path like~ ("*.bat", "*.dll", "*.exe", "*.hta", "*.iso", "*.ps1", "*.txt", "*.vbe", "*.vbs"))) or ((process.executable like~ ("*\\dllhost.exe", "*\\rundll32.exe", "*\\svchost.exe")) and (file.path like~ ("*.bat", "*.hta", "*.iso", "*.ps1", "*.vbe", "*.vbs")))) and (not ((process.executable:"C:\\Windows\\System32\\dllhost.exe" and (file.path:"*:\\Users\*" and file.path:"*\\AppData\\Local\\Temp\\__PSScriptPolicyTest_*") and file.path:"*.ps1") or (process.executable:"C:\\Windows\\system32\\svchost.exe" and (file.path:"*C:\\Windows\\System32\\GroupPolicy\\DataStore\*" and file.path:"*\\sysvol\*" and file.path:"*\\Policies\*" and file.path:"*\\Machine\\Scripts\\Startup\*") and (file.path like~ ("*.ps1", "*.bat"))) or (process.executable:"C:\\Windows\\system32\\svchost.exe" and (file.path:"*C:\\Program Files\\WindowsApps\\Clipchamp*" and file.path:"*.ps1*")) or ((process.executable like~ ("C:\\Windows\\system32\\svchost.exe", "C:\\Windows\\SysWOW64\\svchost.exe")) and (file.path like~ ("C:\\Program Files\\WindowsApps\\Microsoft.PowerShellPreview*", "C:\\Program Files (x86)\\WindowsApps\\Microsoft.PowerShellPreview*")) and file.path:"*.ps1")))
