any where (((process.executable like~ ("*\\powershell.exe", "*\\pwsh.exe")) or (process.pe.original_file_name like~ ("PowerShell.EXE", "pwsh.dll"))) and process.command_line:"*Add-PSSnapin*" and (process.command_line like~ ("*Microsoft.Exchange.Powershell.Snapin*", "*Microsoft.Exchange.Management.PowerShell.SnapIn*"))) and (not (process.parent.executable:"C:\\Windows\\System32\\msiexec.exe" and process.command_line:"*$exserver=Get-ExchangeServer ([Environment]::MachineName) -ErrorVariable exerr 2> $null*"))
