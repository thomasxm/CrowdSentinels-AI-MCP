any where (process.executable:"*\\KrbRelayUp.exe" or process.pe.original_file_name:"KrbRelayUp.exe") or (process.command_line:"* relay *" and process.command_line:"* -Domain *" and process.command_line:"* -ComputerName *") or (process.command_line:"* krbscm *" and process.command_line:"* -sc *") or (process.command_line:"* spawn *" and process.command_line:"* -d *" and process.command_line:"* -cn *" and process.command_line:"* -cp *")
