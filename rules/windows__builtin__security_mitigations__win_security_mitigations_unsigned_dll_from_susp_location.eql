any where (winlog.channel like~ ("Microsoft-Windows-Security-Mitigations/Kernel Mode", "Microsoft-Windows-Security-Mitigations/User Mode")) and ((event.code like~ ("11", "12")) and (winlog.event_data.ImageName like~ ("*\\Users\\Public\*", "*\\PerfLogs\*", "*\\Desktop\*", "*\\Downloads\*", "*\\AppData\\Local\\Temp\*", "*C:\\Windows\\TEMP\*")))
