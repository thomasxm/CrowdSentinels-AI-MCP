any where ((process.executable:"*\\regedit.exe" or process.pe.original_file_name:"REGEDIT.EXE") and ((process.command_line like~ ("* /i *", "*.reg*")) and process.command_line:"SigmaRegularExpression(regexp=SigmaString([':[^ \\\\]']), flags=set())")) and (not (process.command_line like~ ("* -e *", "* /e *", "* –e *", "* —e *", "* ―e *") or process.command_line like~ ("* -a *", "* /a *", "* –a *", "* —a *", "* ―a *") or process.command_line like~ ("* -c *", "* /c *", "* –c *", "* —c *", "* ―c *")))
