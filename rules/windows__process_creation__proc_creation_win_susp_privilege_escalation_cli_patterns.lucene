(process.command_line:(*\ \-u\ system\ * OR *\ \-\-user\ system\ * OR *\ \-u\ NT* OR *\ \-u\ \"NT* OR *\ \-u\ 'NT* OR *\ \-\-system\ * OR *\ \-u\ administrator\ *)) AND (process.command_line:(*\ \-c\ cmd* OR *\ \-c\ \"cmd* OR *\ \-c\ powershell* OR *\ \-c\ \"powershell* OR *\ \-\-command\ cmd* OR *\ \-\-command\ powershell* OR *\ \-c\ whoami* OR *\ \-c\ wscript* OR *\ \-c\ cscript*))
