any where process.executable:"*\\SelectMyParent.exe" or (process.command_line like~ ("*PPID-spoof*", "*ppid_spoof*", "*spoof-ppid*", "*spoof_ppid*", "*ppidspoof*", "*spoofppid*", "*spoofedppid*", "* -spawnto *")) or (process.pe.original_file_name like~ ("*PPID-spoof*", "*ppid_spoof*", "*spoof-ppid*", "*spoof_ppid*", "*ppidspoof*", "*spoofppid*", "*spoofedppid*")) or process.pe.description:"SelectMyParent" or (winlog.event_data.Hashes like~ ("*IMPHASH=04D974875BD225F00902B4CAD9AF3FBC*", "*IMPHASH=A782AF154C9E743DDF3F3EB2B8F3D16E*", "*IMPHASH=89059503D7FBF470E68F7E63313DA3AD*", "*IMPHASH=CA28337632625C8281AB8A130B3D6BAD*"))
