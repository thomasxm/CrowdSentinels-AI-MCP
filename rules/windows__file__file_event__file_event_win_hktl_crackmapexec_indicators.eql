any where file.path:"C:\\Windows\\Temp\*" and ((file.path like~ ("*\\temp.ps1", "*\\msol.ps1")) or (file.path like~ ("SigmaRegularExpression(regexp=SigmaString(['\\\\[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}\\.txt$']), flags=set())", "SigmaRegularExpression(regexp=SigmaString(['\\\\[a-zA-Z]{8}\\.tmp$']), flags=set())")))
