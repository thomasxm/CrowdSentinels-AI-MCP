any where (process.executable:"*\\SharpMove.exe" or process.pe.original_file_name:"SharpMove.exe") or (process.command_line:"*computername=*" and (process.command_line like~ ("*action=create*", "*action=dcom*", "*action=executevbs*", "*action=hijackdcom*", "*action=modschtask*", "*action=modsvc*", "*action=query*", "*action=scm*", "*action=startservice*", "*action=taskscheduler*")))
