any where ((process.parent.executable like~ ("*\\brave.exe", "*\\chrome.exe", "*\\firefox.exe", "*\\msedge.exe")) and process.command_line:"*#*") and ((process.command_line like~ ("*%comspec%*", "*bitsadmin*", "*certutil*", "*cmd*", "*cscript*", "*curl*", "*finger*", "*mshta*", "*powershell*", "*pwsh*", "*regsvr32*", "*rundll32*", "*schtasks*", "*wget*", "*wscript*")) or (process.command_line like~ ("*account*", "*anti-bot*", "*botcheck*", "*captcha*", "*challenge*", "*confirmation*", "*fraud*", "*human*", "*identification*", "*identificator*", "*identity*", "*robot*", "*validation*", "*verification*", "*verify*")))
