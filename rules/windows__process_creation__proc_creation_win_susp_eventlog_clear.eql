any where ((process.executable:"*\\wevtutil.exe" or process.pe.original_file_name:"wevtutil.exe") and (process.command_line like~ ("*clear-log *", "* cl *", "*set-log *", "* sl *", "*lfn:*"))) or ((process.executable like~ ("*\\powershell.exe", "*\\powershell_ise.exe", "*\\pwsh.exe")) and ((process.command_line like~ ("*Clear-EventLog *", "*Remove-EventLog *", "*Limit-EventLog *", "*Clear-WinEvent *")) or (process.command_line:"*Eventing.Reader.EventLogSession*" and process.command_line:"*ClearLog*") or (process.command_line:"*Diagnostics.EventLog*" and process.command_line:"*Clear*"))) or (((process.executable like~ ("*\\powershell.exe", "*\\powershell_ise.exe", "*\\pwsh.exe", "*\\wmic.exe")) and process.command_line:"*ClearEventLog*") and (not ((process.parent.executable like~ ("C:\\Windows\\SysWOW64\\msiexec.exe", "C:\\Windows\\System32\\msiexec.exe")) and process.command_line:"* sl *")))
