any where (((process.executable like~ ("*\\powershell_ise.exe", "*\\powershell.exe", "*\\pwsh.exe")) or (process.pe.original_file_name like~ ("PowerShell_ISE.EXE", "PowerShell.EXE", "pwsh.dll"))) and (process.command_line:"*-ComObject*" and process.command_line:"*InstallProduct(*") and (process.command_line like~ ("*http*", "*\\*"))) and (not (process.command_line like~ ("*://127.0.0.1*", "*://localhost*")))
