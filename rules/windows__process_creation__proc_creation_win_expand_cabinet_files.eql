any where (process.executable:"*\\expand.exe" and process.command_line like~ ("*-F:*", "*/F:*", "*–F:*", "*—F:*", "*―F:*")) and ((process.command_line like~ ("*:\\Perflogs\*", "*:\\ProgramData*", "*:\\Users\\Public\*", "*:\\Windows\\Temp\*", "*\\Admin$\*", "*\\AppData\\Local\\Temp\*", "*\\AppData\\Roaming\*", "*\\C$\*", "*\\Temporary Internet*")) or ((process.command_line:"*:\\Users\*" and process.command_line:"*\\Favorites\*") or (process.command_line:"*:\\Users\*" and process.command_line:"*\\Favourites\*") or (process.command_line:"*:\\Users\*" and process.command_line:"*\\Contacts\*"))) and (not (process.parent.executable:"C:\\Program Files (x86)\\Dell\\UpdateService\\ServiceShell.exe" and process.command_line:"*C:\\ProgramData\\Dell\\UpdateService\\Temp\*"))
