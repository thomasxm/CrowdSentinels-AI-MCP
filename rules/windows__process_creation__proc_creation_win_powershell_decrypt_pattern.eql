any where ((process.executable like~ ("*\\powershell.exe", "*\\pwsh.exe")) and (process.pe.original_file_name like~ ("PowerShell.EXE", "pwsh.dll"))) and (process.command_line like~ ("*Get-ChildItem *", "*dir *", "*gci *", "*ls *")) and (process.command_line like~ ("*Get-Content *", "*gc *", "*cat *", "*type *", "*ReadAllBytes*")) and ((process.command_line:"* ^| *" and process.command_line:"*\*.lnk*" and process.command_line:"*-Recurse*" and process.command_line:"*-Skip *") or (process.command_line:"* -ExpandProperty *" and process.command_line:"*\*.lnk*" and process.command_line:"*WriteAllBytes*" and process.command_line:"* .length *"))
