any where (process.pe.description:"PAExec Application" or process.pe.original_file_name:"PAExec.exe" or process.pe.product:"*PAExec*" or (winlog.event_data.Hashes like~ ("*IMPHASH=11D40A7B7876288F919AB819CC2D9802*", "*IMPHASH=6444f8a34e99b8f7d9647de66aabe516*", "*IMPHASH=dfd6aa3f7b2b1035b76b718f1ddc689f*", "*IMPHASH=1a6cca4d5460b1710a12dea39e4a592c*"))) and (not (process.executable like~ ("*\\paexec.exe", "C:\\Windows\\PAExec-*")))
