any where (process.parent.executable:"*tomcat*" or (process.parent.executable like~ ("*\\amigo.exe", "*\\browser.exe", "*\\chrome.exe", "*\\firefox.exe", "*\\httpd.exe", "*\\iexplore.exe", "*\\jbosssvc.exe", "*\\microsoftedge.exe", "*\\microsoftedgecp.exe", "*\\MicrosoftEdgeSH.exe", "*\\mshta.exe", "*\\nginx.exe", "*\\outlook.exe", "*\\php-cgi.exe", "*\\regsvr32.exe", "*\\rundll32.exe", "*\\safari.exe", "*\\services.exe", "*\\sqlagent.exe", "*\\sqlserver.exe", "*\\sqlservr.exe", "*\\vivaldi.exe", "*\\w3wp.exe"))) and ((process.executable like~ ("*\\powershell.exe", "*\\pwsh.exe")) or (process.command_line like~ ("*/c powershell*", "*/c pwsh*")) or process.pe.description:"Windows PowerShell" or process.pe.product:"PowerShell Core 6" or (process.pe.original_file_name like~ ("PowerShell.EXE", "pwsh.dll")))
