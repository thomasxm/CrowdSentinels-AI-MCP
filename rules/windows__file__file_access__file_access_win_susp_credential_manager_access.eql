any where (file.path like~ ("*\\AppData\\Local\\Microsoft\\Credentials\*", "*\\AppData\\Roaming\\Microsoft\\Credentials\*", "*\\AppData\\Local\\Microsoft\\Vault\*", "*\\ProgramData\\Microsoft\\Vault\*")) and (not (process.executable like~ ("C:\\Program Files\*", "C:\\Program Files (x86)\*", "C:\\Windows\\system32\*", "C:\\Windows\\SysWOW64\*")))
