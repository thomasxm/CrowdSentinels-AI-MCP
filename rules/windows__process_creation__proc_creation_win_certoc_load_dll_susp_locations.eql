any where (process.executable:"*\\certoc.exe" or process.pe.original_file_name:"CertOC.exe") and process.command_line like~ ("* -LoadDLL *", "* /LoadDLL *", "* –LoadDLL *", "* —LoadDLL *", "* ―LoadDLL *") and (process.command_line like~ ("*\\Appdata\\Local\\Temp\*", "*\\Desktop\*", "*\\Downloads\*", "*\\Users\\Public\*", "*C:\\Windows\\Tasks\*", "*C:\\Windows\\Temp\*"))
