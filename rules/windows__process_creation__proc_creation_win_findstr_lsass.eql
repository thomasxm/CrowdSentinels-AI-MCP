any where (((process.executable like~ ("*\\find.exe", "*\\findstr.exe")) or (process.pe.original_file_name like~ ("FIND.EXE", "FINDSTR.EXE"))) and process.command_line:"*lsass*") or (process.command_line like~ ("* -i \"lsass*", "* /i \"lsass*", "* –i \"lsass*", "* —i \"lsass*", "* ―i \"lsass*") or process.command_line like~ ("* -i lsass.exe*", "* /i lsass.exe*", "* –i lsass.exe*", "* —i lsass.exe*", "* ―i lsass.exe*") or process.command_line like~ ("*findstr \"lsass*") or process.command_line like~ ("*findstr lsass*") or process.command_line like~ ("*findstr.exe \"lsass*") or process.command_line like~ ("*findstr.exe lsass*"))
