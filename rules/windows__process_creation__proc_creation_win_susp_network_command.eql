any where process.command_line like~ ("SigmaRegularExpression(regexp=SigmaString(['ipconfig\\s+/all']), flags=set())", "SigmaRegularExpression(regexp=SigmaString(['netsh\\s+interface show interface']), flags=set())", "SigmaRegularExpression(regexp=SigmaString(['arp\\s+-a']), flags=set())", "SigmaRegularExpression(regexp=SigmaString(['nbtstat\\s+-n']), flags=set())", "SigmaRegularExpression(regexp=SigmaString(['net\\s+config']), flags=set())", "SigmaRegularExpression(regexp=SigmaString(['route\\s+print']), flags=set())")
