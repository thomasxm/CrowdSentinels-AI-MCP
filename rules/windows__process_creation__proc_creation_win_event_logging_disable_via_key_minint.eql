any where ((process.executable:"*\\reg.exe" or process.pe.original_file_name:"reg.exe") and (process.command_line:"* add *" and process.command_line:"*\\SYSTEM\\CurrentControlSet\\Control\\MiniNt*")) or (((process.executable like~ ("*\\powershell.exe", "*\\pwsh.exe", "*\\powershell_ise.exe")) or (process.pe.original_file_name like~ ("PowerShell.EXE", "pwsh.dll"))) and (process.command_line like~ ("*New-Item *", "*ni *")) and process.command_line:"*\\SYSTEM\\CurrentControlSet\\Control\\MiniNt*")
