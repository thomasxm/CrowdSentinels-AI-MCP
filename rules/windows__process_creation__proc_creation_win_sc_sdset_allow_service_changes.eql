any where ((process.executable:"*\\sc.exe" or process.pe.original_file_name:"sc.exe") and (process.command_line:"*sdset*" and process.command_line:"*A;*") and (process.command_line like~ ("*;IU*", "*;SU*", "*;BA*", "*;SY*", "*;WD*"))) and (not process.parent.executable:"C:\\Hexnode\\Hexnode Agent\\Current\\HexnodeAgent.exe")
