any where (((winlog.event_data.TargetImage like~ ("*:\\Windows\\Sysmon.exe*", "*:\\Windows\\Sysmon64.exe*")) and winlog.event_data.GrantedAccess:"0x1400") and (not ((process.executable like~ ("*:\\Program Files (x86)\*", "*:\\Program Files\*", "*:\\Windows\\System32\*", "*:\\Windows\\SysWOW64\*")) or (process.executable:"*:\\ProgramData\\Microsoft\\Windows Defender\\Platform\*" and process.executable:"*\\MsMpEng.exe")))) or winlog.event_data.CallTrace:"Ente"
