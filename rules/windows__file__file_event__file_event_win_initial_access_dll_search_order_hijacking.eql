any where ((process.executable like~ ("*\\winword.exe", "*\\excel.exe", "*\\powerpnt.exe", "*\\MSACCESS.EXE", "*\\MSPUB.EXE", "*\\fltldr.exe", "*\\cmd.exe", "*\\certutil.exe", "*\\mshta.exe", "*\\cscript.exe", "*\\wscript.exe", "*\\curl.exe", "*\\powershell.exe", "*\\pwsh.exe")) and file.path:"*.dll" and (file.path:"*\\Users\*" and file.path:"*\\AppData\*") and (file.path like~ ("*\\Microsoft\\OneDrive\*", "*\\Microsoft OneDrive\*", "*\\Microsoft\\Teams\*", "*\\Local\\slack\\app-*", "*\\Local\\Programs\\Microsoft VS Code\*"))) and (not (process.executable:"*\\cmd.exe" and (file.path:"*\\Users\*" and file.path:"*\\AppData\*" and file.path:"*\\Microsoft\\OneDrive\*" and file.path:"*\\api-ms-win-core-*")))
