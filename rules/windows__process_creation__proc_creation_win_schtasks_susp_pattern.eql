any where (process.executable:"*\\schtasks.exe" and process.command_line:"*/Create *") and (((process.command_line like~ ("*/sc minute *", "*/ru system *")) and (process.command_line like~ ("*cmd /c*", "*cmd /k*", "*cmd /r*", "*cmd.exe /c *", "*cmd.exe /k *", "*cmd.exe /r *"))) or (process.command_line like~ ("* -decode *", "* -enc *", "* -w hidden *", "* bypass *", "* IEX*", "*.DownloadData*", "*.DownloadFile*", "*.DownloadString*", "*/c start /min *", "*FromBase64String*", "*mshta http*", "*mshta.exe http*")) or ((process.command_line like~ ("*:\\ProgramData\*", "*:\\Temp\*", "*:\\Tmp\*", "*:\\Users\\Public\*", "*:\\Windows\\Temp\*", "*\\AppData\*", "*%AppData%*", "*%Temp%*", "*%tmp%*")) and (process.command_line like~ ("*cscript*", "*curl*", "*wscript*"))))
