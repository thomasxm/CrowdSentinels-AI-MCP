any where (process.executable:"*\\curl.exe" or process.pe.product:"The curl executable") and ((process.command_line like~ ("*%AppData%*", "*%Public%*", "*%Temp%*", "*%tmp%*", "*\\AppData\*", "*\\Desktop\*", "*\\Temp\*", "*\\Users\\Public\*", "*C:\\PerfLogs\*", "*C:\\ProgramData\*", "*C:\\Windows\\Temp\*")) or (process.command_line like~ ("*.dll", "*.gif", "*.jpeg", "*.jpg", "*.png", "*.temp", "*.tmp", "*.txt", "*.vbe", "*.vbs"))) and (not (process.parent.executable:"C:\\Program Files\\Git\\usr\\bin\\sh.exe" and process.executable:"C:\\Program Files\\Git\\mingw64\\bin\\curl.exe" and (process.command_line:"*--silent --show-error --output *" and process.command_line:"*gfw-httpget-*" and process.command_line:"*AppData*")))
