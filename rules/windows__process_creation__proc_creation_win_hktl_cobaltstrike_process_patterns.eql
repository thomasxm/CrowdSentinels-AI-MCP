any where (process.command_line:"*cmd.exe /C whoami" and process.parent.executable:"C:\\Temp\*") or ((process.parent.executable like~ ("*\\runonce.exe", "*\\dllhost.exe")) and (process.command_line:"*cmd.exe /c echo*" and process.command_line:"*> \\.\\pipe*")) or ((process.parent.command_line:"*cmd.exe /C echo*" and process.parent.command_line:"* > \\.\\pipe*") and process.command_line:"*conhost.exe 0xffffffff -ForceV1") or (process.parent.command_line:"*/C whoami" and process.command_line:"*conhost.exe 0xffffffff -ForceV1")
