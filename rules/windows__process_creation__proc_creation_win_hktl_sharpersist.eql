any where (process.executable:"*\\SharPersist.exe" or process.pe.product:"SharPersist") or (process.command_line like~ ("* -t schtask -c *", "* -t startupfolder -c *")) or (process.command_line:"* -t reg -c *" and process.command_line:"* -m add*") or (process.command_line:"* -t service -c *" and process.command_line:"* -m add*") or (process.command_line:"* -t schtask -c *" and process.command_line:"* -m add*")
