any where process.parent.executable:"*\\Velociraptor.exe" and ((process.command_line:"*code.exe*" and process.command_line:"*tunnel*" and process.command_line:"*--accept-server-license-terms*") or (process.command_line:"*msiexec*" and process.command_line:"*/i*" and process.command_line:"*http*") or ((process.executable like~ ("*\\powershell.exe", "*\\powershell_ise.exe", "*\\pwsh.exe")) and (process.command_line like~ ("*Invoke-WebRequest *", "*IWR *", "*.DownloadFile*", "*.DownloadString*"))))
