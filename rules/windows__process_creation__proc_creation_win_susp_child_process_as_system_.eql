any where ((winlog.event_data.ParentUser like~ ("*AUTHORI*", "*AUTORI*")) and (winlog.event_data.ParentUser like~ ("*\\NETWORK SERVICE", "*\\LOCAL SERVICE")) and (user.name like~ ("*AUTHORI*", "*AUTORI*")) and (user.name like~ ("*\\SYSTEM", "*\\Système", "*\\СИСТЕМА")) and (winlog.event_data.IntegrityLevel like~ ("System", "S-1-16-16384"))) and (not (process.executable:"*\\rundll32.exe" and process.command_line:"*DavSetCookie*"))
