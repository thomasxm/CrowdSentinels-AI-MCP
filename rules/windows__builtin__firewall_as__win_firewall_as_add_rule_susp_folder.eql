any where winlog.channel:"Microsoft-Windows-Windows Firewall With Advanced Security/Firewall" and (((event.code like~ ("2004", "2071", "2097")) and (winlog.event_data.ApplicationPath like~ ("*:\\PerfLogs\*", "*:\\Temp\*", "*:\\Tmp\*", "*:\\Users\\Public\*", "*:\\Windows\\Tasks\*", "*:\\Windows\\Temp\*", "*\\AppData\\Local\\Temp\*"))) and (not winlog.event_data.Action:"2"))
