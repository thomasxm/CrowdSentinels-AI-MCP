any where ((process.executable:"*\\odbcconf.exe" or process.pe.original_file_name:"odbcconf.exe") and process.command_line like~ ("* -f *", "* /f *", "* –f *", "* —f *", "* ―f *")) and (not (process.command_line:"*.rsp*" or (process.parent.executable:"C:\\Windows\\System32\\runonce.exe" and process.executable:"C:\\Windows\\System32\\odbcconf.exe" and process.command_line:"*.exe /E /F \"C:\\WINDOWS\\system32\\odbcconf.tmp\"*")))
