any where (registry.path:"*\\Microsoft\\Internet Explorer\\Main\\DisableFirstRunCustomize" and (winlog.event_data.Details like~ ("DWORD (0x00000001)", "DWORD (0x00000002)"))) and (not (process.executable like~ ("C:\\Windows\\explorer.exe", "C:\\Windows\\System32\\ie4uinit.exe"))) and (not (((process.executable:"*\\Temp\*" and process.executable:"*\\.cr\\avira_*") and winlog.event_data.Details:"*DWORD (0x00000001)*") or ((process.executable like~ ("C:\\Program Files (x86)\\Foxit Software\\Foxit PDF Reader\\FoxitPDFReader.exe", "C:\\Program Files\\Foxit Software\\Foxit PDF Reader\\FoxitPDFReader.exe")) and winlog.event_data.Details:"*DWORD (0x00000001)*")))
