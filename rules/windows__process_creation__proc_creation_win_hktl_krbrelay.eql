any where (process.executable:"*\\KrbRelay.exe" or process.pe.original_file_name:"KrbRelay.exe") or (process.command_line:"* -spn *" and process.command_line:"* -clsid *" and process.command_line:"* -rbcd *") or (process.command_line:"*shadowcred*" and process.command_line:"*clsid*" and process.command_line:"*spn*") or (process.command_line:"*spn *" and process.command_line:"*session *" and process.command_line:"*clsid *")
