any where ((file.path like~ ("*\\credui.dll", "*\\wincredui.dll")) or (file.pe.original_file_name like~ ("credui.dll", "wincredui.dll"))) and (not ((process.executable like~ ("C:\\Program Files (x86)\*", "C:\\Program Files\*", "C:\\Windows\\System32\*", "C:\\Windows\\SysWOW64\*", "C:\\Windows\\SystemApps\*")) or (process.executable like~ ("C:\\Windows\\explorer.exe", "C:\\Windows\\ImmersiveControlPanel\\SystemSettings.exe", "C:\\Windows\\regedit.exe")))) and (not (process.executable:"*\\opera_autoupdate.exe" or (process.executable like~ ("*\\procexp64.exe", "*\\procexp.exe")) or (process.executable:"C:\\Users\*" and process.executable:"*\\AppData\\Local\\Microsoft\\Teams\*" and process.executable:"*\\Teams.exe") or (process.executable:"C:\\Users\*" and process.executable:"*\\AppData\\Local\\Microsoft\\OneDrive\*")))
