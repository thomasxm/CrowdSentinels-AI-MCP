any where (process.executable:"*\\netsh.exe" or process.pe.original_file_name:"netsh.exe") and ((process.command_line:"*interface*" and process.command_line:"*portproxy*" and process.command_line:"*add*" and process.command_line:"*v4tov4*") or (process.command_line:"*i *" and process.command_line:"*p *" and process.command_line:"*a *" and process.command_line:"*v *") or (process.command_line:"*connectp*" and process.command_line:"*listena*" and process.command_line:"*c=*"))
