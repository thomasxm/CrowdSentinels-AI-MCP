any where ((process.executable:"*\\msiexec.exe" or process.pe.original_file_name:"msiexec.exe") and (process.command_line like~ ("*-i*", "*/i*", "*–i*", "*—i*", "*―i*") or process.command_line like~ ("*-package*", "*/package*", "*–package*", "*—package*", "*―package*") or process.command_line like~ ("*-a*", "*/a*", "*–a*", "*—a*", "*―a*") or process.command_line like~ ("*-j*", "*/j*", "*–j*", "*—j*", "*―j*")) and process.command_line like~ ("*-q*", "*/q*", "*–q*", "*—q*", "*―q*")) and (not ((process.parent.executable:"C:\\Users\*" and process.parent.executable:"*\\AppData\\Local\\Temp\*") or process.parent.executable:"C:\\Windows\\Temp\*" or (process.parent.executable:"C:\\Windows\\CCM\\Ccm32BitLauncher.exe" and (winlog.event_data.IntegrityLevel like~ ("System", "S-1-16-16384")))))
