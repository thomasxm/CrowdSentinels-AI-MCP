any where winlog.channel:"Security" and (event.code:"4697" and (winlog.event_data.ServiceFileName like~ ("SigmaRegularExpression(regexp=SigmaString(['\\$PSHome\\[\\s', <SpecialChars.WILDCARD_MULTI: 1>, '\\d{1,3}\\s', <SpecialChars.WILDCARD_MULTI: 1>, '\\]\\s', <SpecialChars.WILDCARD_MULTI: 1>, '\\+\\s', <SpecialChars.WILDCARD_MULTI: 1>, '\\$PSHome\\[']), flags=set())", "SigmaRegularExpression(regexp=SigmaString(['\\$ShellId\\[\\s', <SpecialChars.WILDCARD_MULTI: 1>, '\\d{1,3}\\s', <SpecialChars.WILDCARD_MULTI: 1>, '\\]\\s', <SpecialChars.WILDCARD_MULTI: 1>, '\\+\\s', <SpecialChars.WILDCARD_MULTI: 1>, '\\$ShellId\\[']), flags=set())", "SigmaRegularExpression(regexp=SigmaString(['\\$env:Public\\[\\s', <SpecialChars.WILDCARD_MULTI: 1>, '\\d{1,3}\\s', <SpecialChars.WILDCARD_MULTI: 1>, '\\]\\s', <SpecialChars.WILDCARD_MULTI: 1>, '\\+\\s', <SpecialChars.WILDCARD_MULTI: 1>, '\\$env:Public\\[']), flags=set())", "SigmaRegularExpression(regexp=SigmaString(['\\$env:ComSpec\\[(\\s', <SpecialChars.WILDCARD_MULTI: 1>, '\\d{1,3}\\s', <SpecialChars.WILDCARD_MULTI: 1>, ',){2}']), flags=set())", "SigmaRegularExpression(regexp=SigmaString(['\\\\', <SpecialChars.WILDCARD_MULTI: 1>, 'mdr\\', <SpecialChars.WILDCARD_MULTI: 1>, '\\W\\s', <SpecialChars.WILDCARD_MULTI: 1>, '\\)\\.Name']), flags=set())", "SigmaRegularExpression(regexp=SigmaString(['\\$VerbosePreference\\.ToString\\(']), flags=set())", "SigmaRegularExpression(regexp=SigmaString(['\\String\\]\\s', <SpecialChars.WILDCARD_MULTI: 1>, '\\$VerbosePreference']), flags=set())")))
