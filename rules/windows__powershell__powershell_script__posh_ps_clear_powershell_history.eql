any where ((powershell.file.script_block_text:"*Set-PSReadlineOption*" and powershell.file.script_block_text:"*–HistorySaveStyle*" and powershell.file.script_block_text:"*SaveNothing*") or (powershell.file.script_block_text:"*Set-PSReadlineOption*" and powershell.file.script_block_text:"*-HistorySaveStyle*" and powershell.file.script_block_text:"*SaveNothing*")) or ((powershell.file.script_block_text like~ ("*del*", "*Remove-Item*", "*rm*")) and powershell.file.script_block_text:"*(Get-PSReadlineOption).HistorySavePath*")
