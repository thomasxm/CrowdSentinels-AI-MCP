any where (((registry.path like~ ("*\\Control\\Terminal Server\*", "*\\Windows NT\\Terminal Services\*")) and registry.path:"*\\Shadow" and (winlog.event_data.Details like~ ("DWORD (0x00000001)", "DWORD (0x00000002)", "DWORD (0x00000003)", "DWORD (0x00000004)"))) or ((registry.path like~ ("*\\Control\\Terminal Server\*", "*\\Windows NT\\Terminal Services\*")) and (registry.path like~ ("*\\DisableRemoteDesktopAntiAlias", "*\\DisableSecuritySettings", "*\\fAllowUnsolicited", "*\\fAllowUnsolicitedFullControl")) and winlog.event_data.Details:"DWORD (0x00000001)") or (registry.path like~ ("*\\Control\\Terminal Server\\InitialProgram*", "*\\Control\\Terminal Server\\WinStations\\RDP-Tcp\\InitialProgram*", "*\\services\\TermService\\Parameters\\ServiceDll*", "*\\Terminal Server\\WinStations\\RDP-Tcp\\SecurityLayer*", "*\\Windows NT\\Terminal Services\\InitialProgram*"))) and (not (registry.path:"*\\SecurityLayer" and winlog.event_data.Details:"DWORD (0x00000002)"))
