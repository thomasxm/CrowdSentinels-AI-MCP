any where (process.executable:"*\\whoami.exe" or process.pe.original_file_name:"whoami.exe") and (not ((process.parent.executable like~ ("*\\cmd.exe", "*\\powershell_ise.exe", "*\\powershell.exe", "*\\pwsh.exe")) or process.parent.executable:"<sigma.types.SigmaNull object at 0x7f315fee5160>" or (process.parent.executable like~ ("", "-")))) and (not process.parent.executable:"*:\\Program Files\\Microsoft Monitoring Agent\\Agent\\MonitoringHost.exe")
