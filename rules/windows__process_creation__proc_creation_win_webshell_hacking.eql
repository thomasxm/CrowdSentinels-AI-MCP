any where ((process.parent.executable like~ ("*\\caddy.exe", "*\\httpd.exe", "*\\nginx.exe", "*\\php-cgi.exe", "*\\w3wp.exe", "*\\ws_tomcatservice.exe")) or ((process.parent.executable like~ ("*\\java.exe", "*\\javaw.exe")) and (process.parent.executable like~ ("*-tomcat-*", "*\\tomcat*"))) or ((process.parent.executable like~ ("*\\java.exe", "*\\javaw.exe")) and (process.command_line like~ ("*catalina.jar*", "*CATALINA_HOME*")))) and ((process.command_line:"*rundll32*" and process.command_line:"*comsvcs*") or (process.command_line:"* -hp*" and process.command_line:"* a *" and process.command_line:"* -m*") or (process.command_line:"*net*" and process.command_line:"* user *" and process.command_line:"* /add*") or (process.command_line:"*net*" and process.command_line:"* localgroup *" and process.command_line:"* administrators *" and process.command_line:"*/add*") or (process.executable like~ ("*\\ntdsutil.exe", "*\\ldifde.exe", "*\\adfind.exe", "*\\procdump.exe", "*\\Nanodump.exe", "*\\vssadmin.exe", "*\\fsutil.exe")) or (process.command_line like~ ("* -decode *", "* -NoP *", "* -W Hidden *", "* /decode *", "* /ticket:*", "* sekurlsa*", "*.dmp full*", "*.downloadfile(*", "*.downloadstring(*", "*FromBase64String*", "*process call create*", "*reg save *", "*whoami /priv*")))
