any where (registry.path:"*\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\AppCompatFlags\\TelemetryController\*" and registry.path:"*\\Command" and (winlog.event_data.Details like~ ("*.bat*", "*.bin*", "*.cmd*", "*.dat*", "*.dll*", "*.exe*", "*.hta*", "*.jar*", "*.js*", "*.msi*", "*.ps*", "*.sh*", "*.vb*"))) and (not (winlog.event_data.Details like~ ("*\\system32\\CompatTelRunner.exe*", "*\\system32\\DeviceCensus.exe*")))
