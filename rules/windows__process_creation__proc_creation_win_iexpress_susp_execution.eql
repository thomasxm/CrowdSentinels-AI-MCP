any where (process.executable:"*\\iexpress.exe" or process.pe.original_file_name:"IEXPRESS.exe") and process.command_line like~ ("* -n *", "* /n *", "* –n *", "* —n *", "* ―n *") and (process.command_line like~ ("*:\\ProgramData\*", "*:\\Temp\*", "*:\\Windows\\System32\\Tasks\*", "*:\\Windows\\Tasks\*", "*:\\Windows\\Temp\*", "*\\AppData\\Local\\Temp\*"))
