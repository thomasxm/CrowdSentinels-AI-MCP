any where (process.executable like~ ("*~1\*", "*~2\*")) and (not ((process.parent.executable like~ ("C:\\Windows\\System32\\Dism.exe", "C:\\Windows\\System32\\cleanmgr.exe")) or ((process.executable:"*\\AppData\*" and process.executable:"*\\Temp\*") or (process.executable like~ ("*~1\\unzip.exe", "*~1\\7zG.exe"))))) and (not (process.parent.executable:"*\\WebEx\\WebexHost.exe" or process.parent.executable:"*\\thor\\thor64.exe" or (process.pe.product:"InstallShield (R)" or process.pe.description:"InstallShield (R) Setup Engine" or process.pe.company:"InstallShield Software Corporation")))
