any where (process.command_line:"*Import-Certificate*" and process.command_line:"* -FilePath *" and process.command_line:"*Cert:\\LocalMachine\\Root*") and (process.command_line like~ ("*\\AppData\\Local\\Temp\*", "*:\\Windows\\TEMP\*", "*\\Desktop\*", "*\\Downloads\*", "*\\Perflogs\*", "*:\\Users\\Public\*"))
