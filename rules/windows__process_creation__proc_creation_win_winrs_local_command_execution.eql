any where ((process.executable:"*\\winrs.exe" or process.pe.original_file_name:"winrs.exe") and (process.command_line like~ ("*-r:localhost*", "*/r:localhost*", "*–r:localhost*", "*—r:localhost*", "*―r:localhost*") or process.command_line like~ ("*-r:127.0.0.1*", "*/r:127.0.0.1*", "*–r:127.0.0.1*", "*—r:127.0.0.1*", "*―r:127.0.0.1*") or process.command_line like~ ("*-r:[::1]*", "*/r:[::1]*", "*–r:[::1]*", "*—r:[::1]*", "*―r:[::1]*") or process.command_line like~ ("*-remote:localhost*", "*/remote:localhost*", "*–remote:localhost*", "*—remote:localhost*", "*―remote:localhost*") or process.command_line like~ ("*-remote:127.0.0.1*", "*/remote:127.0.0.1*", "*–remote:127.0.0.1*", "*—remote:127.0.0.1*", "*―remote:127.0.0.1*") or process.command_line like~ ("*-remote:[::1]*", "*/remote:[::1]*", "*–remote:[::1]*", "*—remote:[::1]*", "*―remote:[::1]*"))) or ((process.executable:"*\\winrs.exe" or process.pe.original_file_name:"winrs.exe") and (not (process.command_line like~ ("*-r:*", "*/r:*", "*–r:*", "*—r:*", "*―r:*") or process.command_line like~ ("*-remote:*", "*/remote:*", "*–remote:*", "*—remote:*", "*―remote:*"))))
