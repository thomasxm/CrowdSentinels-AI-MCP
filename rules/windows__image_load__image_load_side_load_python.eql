any where (file.path like~ ("*\\python39.dll", "*\\python310.dll", "*\\python311.dll", "*\\python312.dll")) and (not (((file.path like~ ("C:\\Program Files\\Python3*", "C:\\Program Files (x86)\\Python3*")) or file.path:"*\\AppData\\Local\\Programs\\Python\\Python3*") or (file.pe.product:"Python" and file.code_signature.signed:"true" and file.pe.description:"Python" and file.pe.company:"Python Software Foundation"))) and (not (file.path:"C:\\Program Files\\Microsoft Visual Studio\*" or file.path:"C:\\ProgramData\\Anaconda3\*" or (file.path like~ ("*\\cpython\\externals\*", "*\\cpython\\PCbuild\*")) or (file.path:"C:\\Users*" and file.path:"*\\AppData\\Local\\Temp\\_MEI*")))
