any where process.parent.executable:"*\\cmd.exe" and (process.parent.command_line like~ ("* -c *", "* /c *", "* –c *", "* —c *", "* ―c *") or process.parent.command_line like~ ("* -r *", "* /r *", "* –r *", "* —r *", "* ―r *") or process.parent.command_line like~ ("* -k *", "* /k *", "* –k *", "* —k *", "* ―k *")) and process.executable:"*\\chcp.com" and (process.command_line like~ ("*chcp", "*chcp ", "*chcp  "))
