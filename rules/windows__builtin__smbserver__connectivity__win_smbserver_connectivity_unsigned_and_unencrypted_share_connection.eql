any where ((event.code:"4000" and (winlog.event_data.ShareName like~ ("*IPC$*", "*ADMIN$*", "*C$*"))) and (winlog.event_data.SigningUsed:"false" or winlog.event_data.EncyptionUsed:"false")) and (not ((cidrMatch(source.ip, "127.0.0.0/8") or cidrMatch(source.ip, "169.254.0.0/16") or cidrMatch(source.ip, "::1/128") or cidrMatch(source.ip, "fe80::/10") or cidrMatch(source.ip, "fc00::/7")) or (source.ip like~ ("*00000000000000000000000000000001*", "*FE80000000000000*", "*FC00000000000000*", "*0200????7F*", "*0200????A9FE*"))))
