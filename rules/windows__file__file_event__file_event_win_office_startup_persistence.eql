any where (((file.path:"*\\Microsoft\\Word\\STARTUP*" or (file.path:"*\\Office*" and file.path:"*\\Program Files*" and file.path:"*\\STARTUP*")) and (file.path like~ ("*.doc", "*.docm", "*.docx", "*.dot", "*.dotm", "*.rtf"))) or ((file.path:"*\\Microsoft\\Excel\\XLSTART*" or (file.path:"*\\Office*" and file.path:"*\\Program Files*" and file.path:"*\\XLSTART*")) and (file.path like~ ("*.xls", "*.xlsm", "*.xlsx", "*.xlt", "*.xltm")))) and (not (process.executable like~ ("*\\WINWORD.exe", "*\\EXCEL.exe")))
