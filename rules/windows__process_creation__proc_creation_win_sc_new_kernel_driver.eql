any where (process.executable:"*\\sc.exe" and (process.command_line like~ ("*create*", "*config*")) and (process.command_line:"*binPath*" and process.command_line:"*type*" and process.command_line:"*kernel*")) and (not ((process.command_line:"*create netprotection_network_filter*" and process.command_line:"*type= kernel start= *" and process.command_line:"*binPath= System32\\drivers\\netprotection_network_filter*" and process.command_line:"*DisplayName= netprotection_network_filter*" and process.command_line:"*group= PNP_TDI tag= yes*") or (process.command_line:"*create avelam binpath=C:\\Windows\\system32\\drivers\\avelam.sys*" and process.command_line:"*type=kernel start=boot error=critical group=Early-Launch*")))
