any where (((process.executable like~ ("*\\powershell.exe", "*\\pwsh.exe")) or (process.pe.original_file_name like~ ("PowerShell.EXE", "pwsh.dll"))) and (process.command_line like~ ("*hctac*", "*kaerb*", "*dnammoc*", "*ekovn*", "*eliFd*", "*rahc*", "*etirw*", "*golon*", "*tninon*", "*eddih*", "*tpircS*", "*ssecorp*", "*llehsrewop*", "*esnopser*", "*daolnwod*", "*tneilCbeW*", "*tneilc*", "*ptth*", "*elifotevas*", "*46esab*", "*htaPpmeTteG*", "*tcejbO*", "*maerts*", "*hcaerof*", "*retupmoc*"))) and (not (process.command_line like~ ("* -EncodedCommand *", "* -enc *")))
