any where (file.path like~ ("*BloodHound.zip", "*_computers.json", "*_containers.json", "*_domains.json", "*_gpos.json", "*_groups.json", "*_ous.json", "*_users.json")) and (not (process.executable:"*\\svchost.exe" and file.path:"C:\\Program Files\\WindowsApps\\Microsoft.*" and file.path:"*\\pocket_containers.json"))
