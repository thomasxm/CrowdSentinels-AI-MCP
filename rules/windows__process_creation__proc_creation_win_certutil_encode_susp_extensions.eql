any where (process.executable:"*\\certutil.exe" or process.pe.original_file_name:"CertUtil.exe") and process.command_line like~ ("*-encode*", "*/encode*", "*–encode*", "*—encode*", "*―encode*") and (process.command_line like~ ("*.acl*", "*.bat*", "*.doc*", "*.gif*", "*.jpeg*", "*.jpg*", "*.mp3*", "*.pdf*", "*.png*", "*.ppt*", "*.tmp*", "*.xls*", "*.xml*"))
