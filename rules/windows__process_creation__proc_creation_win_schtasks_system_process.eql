any where (process.executable:"*\\schtasks.exe" or process.pe.original_file_name:"schtasks.exe") and (process.command_line like~ ("* -create *", "* /create *", "* –create *", "* —create *", "* ―create *") and (process.command_line like~ ("* audiodg*", "* conhost*", "* dwm.exe*", "* explorer*", "* lsass*", "* lsm*", "* mmc*", "* msiexec*", "* regsvr32*", "* rundll32*", "* services*", "* spoolsv*", "* svchost*", "* taskeng*", "* taskhost*", "* wininit*", "* winlogon*")))
