any where ((registry.path:"HKLM\\System\\CurrentControlSet\\Services\*" and registry.path:"*\\Start" and (process.executable like~ ("*\\Users\\Public\*", "*\\Perflogs\*", "*\\ADMIN$\*", "*\\Temp\*")) and (winlog.event_data.Details like~ ("DWORD (0x00000000)", "DWORD (0x00000001)", "DWORD (0x00000002)"))) or (registry.path:"HKLM\\System\\CurrentControlSet\\Services\*" and registry.path:"*\\ImagePath" and (winlog.event_data.Details like~ ("*\\Users\\Public\*", "*\\Perflogs\*", "*\\ADMIN$\*", "*\\Temp\*")))) and (not ((process.executable:"*\\Common Files\*" and process.executable:"*\\Temp\*") or (registry.path:"*\\CurrentControlSet\\Services\\MBAMInstallerService\\ImagePath" and winlog.event_data.Details:"*\\AppData\\Local\\Temp\\MBAMInstallerService.exe\"" and process.executable:"C:\\Windows\\system32\\services.exe")))
