any where ((process.executable:"*\\appcmd.exe" or process.pe.original_file_name:"appcmd.exe") and process.command_line:"*list *") and ((process.command_line like~ ("* /config*", "* /xml*", "* -config*", "* -xml*")) or ((process.command_line like~ ("* /@t*", "* /text*", "* /show*", "* -@t*", "* -text*", "* -show*")) and (process.command_line like~ ("*:\**", "*password*"))))
