any where ((winlog.event_data.SourceFilename like~ ("*.doc", "*.docx", "*.jpeg", "*.jpg", "*.lnk", "*.pdf", "*.png", "*.pst", "*.rtf", "*.xls", "*.xlsx")) and (file.path like~ ("*.doc.*", "*.docx.*", "*.jpeg.*", "*.jpg.*", "*.lnk.*", "*.pdf.*", "*.png.*", "*.pst.*", "*.rtf.*", "*.xls.*", "*.xlsx.*"))) and (not (file.path like~ ("*.backup", "*.bak", "*.old", "*.orig", "*.temp", "*.tmp"))) and (not (file.path:"*:\\ProgramData\\Anaconda3\*" and file.path:"*.c~"))
