any where ((process.command_line:"*wmic*" and process.command_line:"*product where *" and process.command_line:"*call*" and process.command_line:"*uninstall*" and process.command_line:"*/nointeractive*") or ((process.command_line:"*wmic*" and process.command_line:"*caption like *") and (process.command_line like~ ("*call delete*", "*call terminate*"))) or (process.command_line:"*process *" and process.command_line:"*where *" and process.command_line:"*delete*")) and (process.command_line like~ ("*%carbon%*", "*%cylance%*", "*%endpoint%*", "*%eset%*", "*%malware%*", "*%Sophos%*", "*%symantec%*", "*Antivirus*", "*AVG *", "*Carbon Black*", "*CarbonBlack*", "*Cb Defense Sensor 64-bit*", "*Crowdstrike Sensor*", "*Cylance *", "*Dell Threat Defense*", "*DLP Endpoint*", "*Endpoint Detection*", "*Endpoint Protection*", "*Endpoint Security*", "*Endpoint Sensor*", "*ESET File Security*", "*LogRhythm System Monitor Service*", "*Malwarebytes*", "*McAfee Agent*", "*Microsoft Security Client*", "*Sophos Anti-Virus*", "*Sophos AutoUpdate*", "*Sophos Credential Store*", "*Sophos Management Console*", "*Sophos Management Database*", "*Sophos Management Server*", "*Sophos Remote Management System*", "*Sophos Update Manager*", "*Threat Protection*", "*VirusScan*", "*Webroot SecureAnywhere*", "*Windows Defender*"))
