any where (powershell.file.script_block_text like~ ("*Get-PasswordVaultCredentials*", "*Get-CredManCreds*")) or (powershell.file.script_block_text:"*New-Object*" and powershell.file.script_block_text:"*Windows.Security.Credentials.PasswordVault*") or (powershell.file.script_block_text:"*New-Object*" and powershell.file.script_block_text:"*Microsoft.CSharp.CSharpCodeProvider*" and powershell.file.script_block_text:"*[System.Runtime.InteropServices.RuntimeEnvironment]::GetRuntimeDirectory())*" and powershell.file.script_block_text:"*Collections.ArrayList*" and powershell.file.script_block_text:"*System.CodeDom.Compiler.CompilerParameters*")
