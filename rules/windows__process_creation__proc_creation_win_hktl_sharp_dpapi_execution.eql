any where (process.executable:"*\\SharpDPAPI.exe" or process.pe.original_file_name:"SharpDPAPI.exe") or ((process.command_line like~ ("* backupkey *", "* blob *", "* certificates *", "* credentials *", "* keepass *", "* masterkeys *", "* rdg *", "* vaults *")) and ((process.command_line:"* {*" and process.command_line:"*}:*") or (process.command_line like~ ("* /file:*", "* /machine*", "* /mkfile:*", "* /password:*", "* /pvk:*", "* /server:*", "* /target:*", "* /unprotect*"))))
