any where ((process.executable:"*\\reg.exe" or process.pe.original_file_name:"reg.exe") and (process.command_line:"*add*" and process.command_line:"*CurrentVersion\\Control Panel\\CPLs*")) or (process.command_line:"*.cpl" and (not ((process.command_line like~ ("*\\System32\*", "*%System%*", "*|C:\\Windows\\system32|*")) or (process.command_line:"*regsvr32 *" and process.command_line:"* /s *" and process.command_line:"*igfxCPL.cpl*"))))
