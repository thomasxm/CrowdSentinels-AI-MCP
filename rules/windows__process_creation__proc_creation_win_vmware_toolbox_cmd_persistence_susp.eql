any where (process.executable:"*\\VMwareToolBoxCmd.exe" or process.pe.original_file_name:"toolbox-cmd.exe") and (process.command_line:"* script *" and process.command_line:"* set *") and (process.command_line like~ ("*:\\PerfLogs\*", "*:\\Temp\*", "*:\\Windows\\System32\\Tasks\*", "*:\\Windows\\Tasks\*", "*:\\Windows\\Temp\*", "*\\AppData\\Local\\Temp*"))
