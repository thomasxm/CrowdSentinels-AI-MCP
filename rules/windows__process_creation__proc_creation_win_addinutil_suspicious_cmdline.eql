any where (process.executable:"*\\addinutil.exe" or process.pe.original_file_name:"AddInUtil.exe") and (((process.command_line like~ ("*-AddInRoot:*", "*-PipelineRoot:*")) and (process.command_line like~ ("*\\AppData\\Local\\Temp\*", "*\\Desktop\*", "*\\Downloads\*", "*\\Users\\Public\*", "*\\Windows\\Temp\*"))) or ((process.command_line like~ ("*-AddInRoot:.*", "*-AddInRoot:\".\"*", "*-PipelineRoot:.*", "*-PipelineRoot:\".\"*")) and (process.working_directory like~ ("*\\AppData\\Local\\Temp\*", "*\\Desktop\*", "*\\Downloads\*", "*\\Users\\Public\*", "*\\Windows\\Temp\*"))))
