any where winlog.channel:"Microsoft-Windows-Windows Firewall With Advanced Security/Firewall" and ((event.code like~ ("2006", "2052")) and (not ((winlog.event_data.ModifyingApplication like~ ("C:\\Program Files (x86)\*", "C:\\Program Files\*", "C:\\Windows\\WinSxS\*")) or winlog.event_data.ModifyingApplication:"C:\\Windows\\System32\\svchost.exe" or winlog.event_data.ModifyingApplication:"<sigma.types.SigmaNull object at 0x7f5393b20d70>" or winlog.event_data.ModifyingApplication=="")) and (not (winlog.event_data.ModifyingApplication:"C:\\ProgramData\\Microsoft\\Windows Defender\\Platform\*" and winlog.event_data.ModifyingApplication:"*\\MsMpEng.exe")))
