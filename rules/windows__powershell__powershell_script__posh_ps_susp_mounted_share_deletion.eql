any where (powershell.file.script_block_text like~ ("*Remove-SmbShare*", "*Remove-FileShare*")) and (not (powershell.file.script_block_text:"*FileShare.cdxml*" and powershell.file.script_block_text:"*Microsoft.PowerShell.Core\\Export-ModuleMember*" and powershell.file.script_block_text:"*ROOT/Microsoft/Windows/Storage/MSFT_FileShare*" and powershell.file.script_block_text:"*ObjectModelWrapper*" and powershell.file.script_block_text:"*Cmdletization.MethodParameter*"))
