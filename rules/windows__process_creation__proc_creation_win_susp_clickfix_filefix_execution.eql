any where (process.parent.executable:"*\\explorer.exe" and process.command_line:"*#*") and (process.command_line like~ ("*account*", "*anti-bot*", "*botcheck*", "*captcha*", "*challenge*", "*confirmation*", "*fraud*", "*human*", "*identification*", "*identificator*", "*identity*", "*robot*", "*validation*", "*verification*", "*verify*"))
