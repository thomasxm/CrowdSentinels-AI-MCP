any where ((process.executable:"*\\cmd.exe" and process.command_line:"*copy *") or ((process.executable like~ ("*\\powershell.exe", "*\\pwsh.exe")) and (process.command_line like~ ("*copy-item*", "* copy *", "*cpi *", "* cp *"))) or ((process.executable like~ ("*\\robocopy.exe", "*\\xcopy.exe")) or (process.pe.original_file_name like~ ("robocopy.exe", "XCOPY.EXE")))) and process.command_line:"SigmaRegularExpression(regexp=SigmaString(['\\s[\\'\"]', <SpecialChars.WILDCARD_SINGLE: 2>, 'C:\\\\Windows\\\\(System32|SysWOW64|WinSxS)']), flags={<SigmaRegularExpressionFlag.IGNORECASE: 1>})" and (not (process.executable:"*\\cmd.exe" and (process.command_line:"*/c copy*" and process.command_line:"*\\Temp\*" and process.command_line:"*\\avira_system_speedup.exe*") and (process.command_line like~ ("*C:\\Program Files\\Avira\*", "*C:\\Program Files (x86)\\Avira\*"))))
