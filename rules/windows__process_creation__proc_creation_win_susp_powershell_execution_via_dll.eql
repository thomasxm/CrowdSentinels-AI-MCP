any where ((process.executable like~ ("*\\InstallUtil.exe", "*\\RegAsm.exe", "*\\RegSvcs.exe", "*\\regsvr32.exe", "*\\rundll32.exe")) or (process.pe.original_file_name like~ ("InstallUtil.exe", "RegAsm.exe", "RegSvcs.exe", "REGSVR32.EXE", "RUNDLL32.EXE"))) and (process.command_line like~ ("*Default.GetString*", "*DownloadString*", "*FromBase64String*", "*ICM *", "*IEX *", "*Invoke-Command*", "*Invoke-Expression*"))
