any where ((process.executable:"*\\rar.exe" or process.pe.description:"Command line RAR") or (process.command_line like~ ("*.exe a *", "* a -m*"))) and ((process.command_line:"* -hp*" and process.command_line:"* -r *") and (process.command_line like~ ("* ?:\\*.*", "* ?:\\\*.*", "* ?:\\$Recycle.bin\*", "* ?:\\PerfLogs\*", "* ?:\\Temp*", "* ?:\\Users\\Public\*", "* ?:\\Windows\*", "* %public%*")))
