any where (registry.path:"*\\System\\CurrentControlSet\\Control\\WMI\\Autologger\*" and ((registry.path like~ ("*\\EventLog-*", "*\\Defender*")) and (registry.path like~ ("*\\Enable", "*\\Start")) and winlog.event_data.Details:"DWORD (0x00000000)")) and (not (process.executable:"C:\\Windows\\system32\\wevtutil.exe" or ((process.executable like~ ("C:\\ProgramData\\Microsoft\\Windows Defender\\Platform\*", "C:\\Program Files\\Windows Defender\*", "C:\\Program Files (x86)\\Windows Defender\*")) and process.executable:"*\\MsMpEng.exe" and (registry.path like~ ("*\\DefenderApiLogger\*", "*\\DefenderAuditLogger\*")))))
