any where ((process.executable:"*\\Werfault.exe" or process.pe.original_file_name:"WerFault.exe") and ((winlog.event_data.ParentUser like~ ("*AUTHORI*", "*AUTORI*")) and (user.name like~ ("*AUTHORI*", "*AUTORI*")) and (process.command_line:"* -u -p *" and process.command_line:"* -ip *" and process.command_line:"* -s *"))) and (not process.parent.executable:"C:\\Windows\\System32\\lsass.exe")
