(file.path:(*\\UsageLogs\\cmstp.exe.log OR *\\UsageLogs\\cscript.exe.log OR *\\UsageLogs\\mshta.exe.log OR *\\UsageLogs\\msxsl.exe.log OR *\\UsageLogs\\regsvr32.exe.log OR *\\UsageLogs\\rundll32.exe.log OR *\\UsageLogs\\svchost.exe.log OR *\\UsageLogs\\wscript.exe.log OR *\\UsageLogs\\wmic.exe.log)) AND (NOT (process.parent.executable:*\\MsiExec.exe AND process.parent.command_line:*\ \-Embedding* AND process.executable:*\\rundll32.exe AND (winlog.event_data.CommandLine:*Temp* AND winlog.event_data.CommandLine:*zzzzInvokeManagedCustomActionOutOfProc*)))
