any where (process.executable:"*\\schtasks.exe" and (process.command_line:"*/Create*" and process.command_line:"*/RU*" and process.command_line:"*/TR*" and process.command_line:"*C:\\Users\*" and process.command_line:"*\\AppData\\Local\*") and (process.command_line like~ ("*NT AUT*", "* SYSTEM *"))) and (not ((process.parent.executable:"*\\AppData\\Local\\Temp\*" and process.parent.executable:"*TeamViewer_.exe*") and process.executable:"*\\schtasks.exe" and process.command_line:"*/TN TVInstallRestore*"))
