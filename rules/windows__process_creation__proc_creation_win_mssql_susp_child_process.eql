any where (process.parent.executable:"*\\sqlservr.exe" and (process.executable like~ ("*\\bash.exe", "*\\bitsadmin.exe", "*\\cmd.exe", "*\\netstat.exe", "*\\nltest.exe", "*\\ping.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\regsvr32.exe", "*\\rundll32.exe", "*\\sh.exe", "*\\systeminfo.exe", "*\\tasklist.exe", "*\\wsl.exe"))) and (not (process.parent.executable:"C:\\Program Files\\Microsoft SQL Server\*" and process.parent.executable:"*DATEV_DBENGINE\\MSSQL\\Binn\\sqlservr.exe" and process.executable:"C:\\Windows\\System32\\cmd.exe" and process.command_line:"\"C:\\Windows\\system32\\cmd.exe\" *"))
