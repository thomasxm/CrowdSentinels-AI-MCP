any where winlog.channel:"Security" and (event.code:"4702" and (winlog.event_data.TaskContentNew like~ ("*\\AppData\\Local\\Temp\*", "*\\AppData\\Roaming\*", "*\\Users\\Public\*", "*\\WINDOWS\\Temp\*", "*C:\\Temp\*", "*\\Desktop\*", "*\\Downloads\*", "*\\Temporary Internet*", "*C:\\ProgramData\*", "*C:\\Perflogs\*")) and (winlog.event_data.TaskContentNew like~ ("*regsvr32*", "*rundll32*", "*cmd.exe</Command>*", "*cmd</Command>*", "*<Arguments>/c *", "*<Arguments>/k *", "*<Arguments>/r *", "*powershell*", "*pwsh*", "*mshta*", "*wscript*", "*cscript*", "*certutil*", "*bitsadmin*", "*bash.exe*", "*bash *", "*scrcons*", "*wmic *", "*wmic.exe*", "*forfiles*", "*scriptrunner*", "*hh.exe*")))
