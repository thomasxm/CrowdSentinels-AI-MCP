any where ((process.executable:"*\\wmic.exe" or process.pe.original_file_name:"wmic.exe" or process.parent.executable:"*\\wmiprvse.exe") and ((process.command_line:"*reg*" and process.command_line:"* add *") and (process.command_line like~ ("*\\Software\\Microsoft\\Windows\\CurrentVersion\\Run*", "*\\Software\\WOW6432Node\\Microsoft\\Windows\\CurrentVersion\\Run*", "*\\Software\\Microsoft\\Windows\\CurrentVersion\\Policies\\Explorer\\Run*")))) and ((process.command_line like~ ("*:\\Perflogs*", "*:\\ProgramData'*", "*:\\Windows\\Temp*", "*:\\Temp*", "*\\AppData\\Local\\Temp*", "*\\AppData\\Roaming*", "*:\\$Recycle.bin*", "*:\\Users\\Default*", "*:\\Users\\public*", "*%temp%*", "*%tmp%*", "*%Public%*", "*%AppData%*")) or (process.command_line:"*:\\Users\*" and (process.command_line like~ ("*\\Favorites*", "*\\Favourites*", "*\\Contacts*", "*\\Music*", "*\\Pictures*", "*\\Documents*", "*\\Photos*"))))
