any where ((process.parent.command_line like~ ("*.bat*", "*.chm*", "*.cmd*", "*.hta*", "*.htm*", "*.html*", "*.js*", "*.lnk*", "*.ps1*", "*.vbe*", "*.vbs*", "*.wsf*")) or (process.parent.command_line like~ ("*:\\Perflogs\*", "*:\\Temp\*", "*:\\Users\\Public\*", "*:\\Windows\\Temp\*", "*\\AppData\\Local\\Temp*", "*\\AppData\\Roaming\*", "*\\Temporary Internet*")) or ((process.parent.command_line:"*:\\Users\*" and process.parent.command_line:"*\\Favorites\*") or (process.parent.command_line:"*:\\Users\*" and process.parent.command_line:"*\\Favourites\*") or (process.parent.command_line:"*:\\Users\*" and process.parent.command_line:"*\\Contacts\*"))) and (process.parent.command_line like~ ("*.bat*", "*.chm*", "*.cmd*", "*.hta*", "*.htm*", "*.html*", "*.js*", "*.lnk*", "*.ps1*", "*.vbe*", "*.vbs*", "*.wsf*")) and (process.executable:"*\\PingCastle.exe" or process.pe.original_file_name:"PingCastle.exe" or process.pe.product:"Ping Castle" or (process.command_line like~ ("*--scanner aclcheck*", "*--scanner antivirus*", "*--scanner computerversion*", "*--scanner foreignusers*", "*--scanner laps_bitlocker*", "*--scanner localadmin*", "*--scanner nullsession*", "*--scanner nullsession-trust*", "*--scanner oxidbindings*", "*--scanner remote*", "*--scanner share*", "*--scanner smb*", "*--scanner smb3querynetwork*", "*--scanner spooler*", "*--scanner startup*", "*--scanner zerologon*")) or process.command_line:"*--no-enum-limit*" or (process.command_line:"*--healthcheck*" and process.command_line:"*--level Full*") or (process.command_line:"*--healthcheck*" and process.command_line:"*--server *"))
