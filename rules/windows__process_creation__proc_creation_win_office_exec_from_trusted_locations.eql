any where ((process.parent.executable like~ ("*\\explorer.exe", "*\\dopus.exe")) and ((process.executable like~ ("*\\EXCEL.EXE", "*\\POWERPNT.EXE", "*\\WINWORD.exe")) or (process.pe.original_file_name like~ ("Excel.exe", "POWERPNT.EXE", "WinWord.exe"))) and (process.command_line like~ ("*\\AppData\\Roaming\\Microsoft\\Templates*", "*\\AppData\\Roaming\\Microsoft\\Word\\Startup\*", "*\\Microsoft Office\\root\\Templates\*", "*\\Microsoft Office\\Templates\*"))) and (not (process.command_line like~ ("*.dotx", "*.xltx", "*.potx")))
