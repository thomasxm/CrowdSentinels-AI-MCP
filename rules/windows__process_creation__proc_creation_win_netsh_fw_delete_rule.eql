any where ((process.executable:"*\\netsh.exe" or process.pe.original_file_name:"netsh.exe") and (process.command_line:"*firewall*" and process.command_line:"*delete *")) and (not ((process.parent.executable:"*\\Dropbox.exe" and process.command_line:"*name=Dropbox*") or (process.parent.executable:"*\\instup.exe" and process.command_line:"*advfirewall firewall delete rule name=\"Avast Antivirus Admin Client\"*")))
