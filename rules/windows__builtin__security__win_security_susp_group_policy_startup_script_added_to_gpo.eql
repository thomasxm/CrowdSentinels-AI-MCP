any where winlog.channel:"Security" and ((event.code like~ ("5136", "5145")) and ((((winlog.event_data.AttributeLDAPDisplayName like~ ("gPCMachineExtensionNames", "gPCUserExtensionNames")) and winlog.event_data.AttributeValue:"*42B5FAAE-6536-11D2-AE5A-0000F87571E3*") and (winlog.event_data.AttributeValue like~ ("*40B6664F-4972-11D1-A7CA-0000F87571E3*", "*40B66650-4972-11D1-A7CA-0000F87571E3*"))) or (winlog.event_data.ShareName:"*\\SYSVOL" and (winlog.event_data.RelativeTargetName like~ ("*\\scripts.ini", "*\\psscripts.ini")) and winlog.event_data.AccessList:"*%%4417*")))
