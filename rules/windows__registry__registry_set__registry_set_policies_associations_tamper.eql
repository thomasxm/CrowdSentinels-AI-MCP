any where registry.path:"*\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Policies\\Associations\*" and ((registry.path:"*\\DefaultFileTypeRisk" and winlog.event_data.Details:"DWORD (0x00006152)") or (registry.path:"*\\LowRiskFileTypes" and (winlog.event_data.Details like~ ("*.zip;*", "*.rar;*", "*.exe;*", "*.bat;*", "*.com;*", "*.cmd;*", "*.reg;*", "*.msi;*", "*.htm;*", "*.html;*"))))
