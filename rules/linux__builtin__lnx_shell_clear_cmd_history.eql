any where "cat /dev/null >*sh_history" or "cat /dev/zero >*sh_history" or "chattr +i*sh_history" or "echo \"\" >*sh_history" or "empty_bash_history" or "export HISTFILESIZE=0" or "history -c" or "history -w" or "ln -sf /dev/null *sh_history" or "ln -sf /dev/zero *sh_history" or "rm *sh_history" or "shopt -ou history" or "shopt -uo history" or "shred *sh_history" or "truncate -s0 *sh_history"
