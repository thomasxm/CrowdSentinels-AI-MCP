any where winlog.event_data.Contents:"SigmaRegularExpression(regexp=SigmaString(['http[s]', <SpecialChars.WILDCARD_SINGLE: 2>, '://[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3}']), flags=set())" and (file.path like~ ("*.ps1:Zone*", "*.bat:Zone*", "*.exe:Zone*", "*.vbe:Zone*", "*.vbs:Zone*", "*.dll:Zone*", "*.one:Zone*", "*.cmd:Zone*", "*.hta:Zone*", "*.xll:Zone*", "*.lnk:Zone*"))
