any where ((process.executable:"*\\addinutil.exe" or process.pe.original_file_name:"AddInUtil.exe") and (process.command_line like~ ("*-AddInRoot:*", "*-PipelineRoot:*"))) and (not (process.command_line like~ ("*-AddInRoot:\"C:\\Program Files (x86)\\Common Files\\Microsoft Shared\\VSTA*", "*-AddInRoot:C:\\Program Files (x86)\\Common Files\\Microsoft Shared\\VSTA*", "*-PipelineRoot:\"C:\\Program Files (x86)\\Common Files\\Microsoft Shared\\VSTA*", "*-PipelineRoot:C:\\Program Files (x86)\\Common Files\\Microsoft Shared\\VSTA*")))
