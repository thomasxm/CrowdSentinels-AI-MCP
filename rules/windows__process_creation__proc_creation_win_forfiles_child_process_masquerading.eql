any where ((process.parent.command_line like~ ("*.exe", "*.exe\"")) and process.executable:"*\\cmd.exe" and process.command_line:"/c echo \"*") and (not ((process.parent.executable like~ ("*:\\Windows\\System32\*", "*:\\Windows\\SysWOW64\*")) and process.parent.executable:"*\\forfiles.exe" and (process.executable like~ ("*:\\Windows\\System32\*", "*:\\Windows\\SysWOW64\*")) and process.executable:"*\\cmd.exe"))
