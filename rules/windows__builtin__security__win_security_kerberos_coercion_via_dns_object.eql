any where winlog.channel:"Security" and (((event.code like~ ("5136", "5137")) and winlog.event_data.ObjectClass:"dnsNode" and (winlog.event_data.ObjectDN:"*UWhRCA*" and winlog.event_data.ObjectDN:"*BAAAA*" and winlog.event_data.ObjectDN:"*CN=MicrosoftDNS*")) or (event.code:"4662" and (winlog.event_data.AdditionalInfo:"*UWhRCA*" and winlog.event_data.AdditionalInfo:"*BAAAA*" and winlog.event_data.AdditionalInfo:"*CN=MicrosoftDNS*")))
