any where (powershell.file.script_block_text:"*Set-ExecutionPolicy*" and (powershell.file.script_block_text like~ ("*Unrestricted*", "*bypass*"))) and (not (powershell.file.script_block_text like~ ("*(New-Object System.Net.WebClient).DownloadString('https://community.chocolatey.org/install.ps1')*", "*(New-Object System.Net.WebClient).DownloadString('https://chocolatey.org/install.ps1')*")))
