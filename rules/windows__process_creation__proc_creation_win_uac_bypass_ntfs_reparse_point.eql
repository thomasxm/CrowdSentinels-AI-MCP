any where (process.command_line:"\"C:\\Windows\\system32\\wusa.exe\"  /quiet C:\\Users\*" and process.command_line:"*\\AppData\\Local\\Temp\\update.msu" and (winlog.event_data.IntegrityLevel like~ ("High", "System", "S-1-16-16384", "S-1-16-12288"))) or (process.parent.command_line:"\"C:\\Windows\\system32\\dism.exe\" /online /quiet /norestart /add-package /packagepath:\"C:\\Windows\\system32\\pe386\" /ignorecheck" and (winlog.event_data.IntegrityLevel like~ ("High", "System")) and (process.command_line:"*C:\\Users\*" and process.command_line:"*\\AppData\\Local\\Temp\*" and process.command_line:"*\\dismhost.exe {*") and process.executable:"*\\DismHost.exe")
