any where (registry.path:"*\\SYSTEM\\CurrentControlSet\\Control*" and (registry.path like~ ("*\\Terminal Server\\WinStations\\RDP-Tcp\\InitialProgram*", "*\\Terminal Server\\Wds\\rdpwd\\StartupPrograms*", "*\\SecurityProviders\\SecurityProviders*", "*\\SafeBoot\\AlternateShell*", "*\\Print\\Providers*", "*\\Print\\Monitors*", "*\\NetworkProvider\\Order*", "*\\Lsa\\Notification Packages*", "*\\Lsa\\Authentication Packages*", "*\\BootVerificationProgram\\ImagePath*"))) and (not (winlog.event_data.Details:"(Empty)" or (process.executable:"C:\\Windows\\System32\\spoolsv.exe" and registry.path:"*\\Print\\Monitors\\CutePDF Writer Monitor*" and (winlog.event_data.Details like~ ("cpwmon64_v40.dll", "CutePDF Writer"))) or (process.executable:"C:\\Windows\\System32\\spoolsv.exe" and registry.path:"*Print\\Monitors\\Appmon\\Ports\\Microsoft.Office.OneNote_*" and (user.name like~ ("*AUTHORI*", "*AUTORI*"))) or (process.executable:"C:\\Windows\\System32\\poqexec.exe" and registry.path:"*\\NetworkProvider\\Order\\ProviderOrder") or (process.executable:"C:\\Windows\\System32\\spoolsv.exe" and registry.path:"*\\Print\\Monitors\\MONVNC\\Driver" and winlog.event_data.Details:"VNCpm.dll")))
