any where winlog.channel:"Security" and ((event.code:"4697" and winlog.event_data.ServiceFileName:"SigmaRegularExpression(regexp=SigmaString(['^%systemroot%\\\\[a-zA-Z]{8}\\.exe$']), flags=set())" and service.name:"SigmaRegularExpression(regexp=SigmaString(['(^[a-zA-Z]{4}$)|(^[a-zA-Z]{8}$)|(^[a-zA-Z]{16}$)']), flags=set())" and winlog.event_data.ServiceStartType:"3" and winlog.event_data.ServiceType:"0x10") and (not service.name:"PSEXESVC"))
