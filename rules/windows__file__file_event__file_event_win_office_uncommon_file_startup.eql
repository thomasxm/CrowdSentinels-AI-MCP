any where (((file.path:"*\\Microsoft\\Word\\STARTUP*" or (file.path:"*\\Office*" and file.path:"*\\Program Files*" and file.path:"*\\STARTUP*")) and (not (file.path like~ ("*.docb", "*.docm", "*.docx", "*.dotm", "*.mdb", "*.mdw", "*.pdf", "*.wll", "*.wwl")))) or ((file.path:"*\\Microsoft\\Excel\\XLSTART*" or (file.path:"*\\Office*" and file.path:"*\\Program Files*" and file.path:"*\\XLSTART*")) and (not (file.path like~ ("*.xll", "*.xls", "*.xlsm", "*.xlsx", "*.xlt", "*.xltm", "*.xlw"))))) and (not ((process.executable:"*:\\Program Files\\Common Files\\Microsoft Shared\\ClickToRun\*" and process.executable:"*\\OfficeClickToRun.exe") or ((process.executable like~ ("*:\\Program Files\\Microsoft Office\*", "*:\\Program Files (x86)\\Microsoft Office\*")) and (process.executable like~ ("*\\winword.exe", "*\\excel.exe")))))
