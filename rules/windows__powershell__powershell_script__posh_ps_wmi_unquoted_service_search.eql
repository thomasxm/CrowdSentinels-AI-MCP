any where (powershell.file.script_block_text like~ ("*Get-WmiObject *", "*gwmi *")) and (powershell.file.script_block_text:"* Win32_Service *" and powershell.file.script_block_text:"*Name*" and powershell.file.script_block_text:"*DisplayName*" and powershell.file.script_block_text:"*PathName*" and powershell.file.script_block_text:"*StartMode*")
