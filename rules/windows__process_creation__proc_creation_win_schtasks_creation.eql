any where (process.executable:"*\\schtasks.exe" and process.command_line:"* /create *") and (not (user.name like~ ("*AUTHORI*", "*AUTORI*"))) and (not ((process.parent.executable like~ ("C:\\Program Files\\Microsoft Office\\root\\integration\\integrator.exe", "C:\\Program Files (x86)\\Microsoft Office\\root\\integration\\integrator.exe")) and (process.executable like~ ("C:\\Windows\\System32\\schtasks.exe", "C:\\Windows\\SysWOW64\\schtasks.exe")) and process.command_line:"*Microsoft\\Office\\Office Performance Monitor*"))
