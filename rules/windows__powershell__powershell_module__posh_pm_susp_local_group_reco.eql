any where ((powershell.file.script_block_text like~ ("*get-localgroup *", "*get-localgroupmember *")) or (winlog.event_data.ContextInfo like~ ("*get-localgroup *", "*get-localgroupmember *"))) or (((powershell.file.script_block_text like~ ("*get-wmiobject *", "*gwmi *", "*get-ciminstance *", "*gcim *")) or (winlog.event_data.ContextInfo:"*get-wmiobject *" and winlog.event_data.ContextInfo:"*gwmi *" and winlog.event_data.ContextInfo:"*get-ciminstance *" and winlog.event_data.ContextInfo:"*gcim *")) and (powershell.file.script_block_text:"*win32_group*" or winlog.event_data.ContextInfo:"*win32_group*"))
