any where winlog.channel:"Security" and ((event.code:"4648" and (process.executable like~ ("*\\cmd.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\winrs.exe", "*\\wmic.exe", "*\\net.exe", "*\\net1.exe", "*\\reg.exe"))) and (not (winlog.event_data.TargetServerName:"localhost" or (user.name:"*$" and winlog.event_data.TargetUserName:"*$"))))
