any where ((process.executable:"*\\RpcPing.exe" or process.pe.original_file_name:"\\RpcPing.exe") and process.command_line like~ ("*-s*", "*/s*", "*–s*", "*—s*", "*―s*")) and ((process.command_line like~ ("*-u*", "*/u*", "*–u*", "*—u*", "*―u*") and process.command_line:"*NTLM*") or (process.command_line like~ ("*-t*", "*/t*", "*–t*", "*—t*", "*―t*") and process.command_line:"*ncacn_np*"))
