any where ((process.executable:"*\\cmd.exe" and (process.command_line:"* /c*" and process.command_line:"*dir *" and process.command_line:"*\\Users\*")) and (not process.command_line:"* rmdir *")) or (((process.executable like~ ("*\\net.exe", "*\\net1.exe")) and process.command_line:"*user*") and (not (process.command_line like~ ("*/domain*", "*/add*", "*/delete*", "*/active*", "*/expires*", "*/passwordreq*", "*/scriptpath*", "*/times*", "*/workstations*")))) or (((process.executable like~ ("*\\whoami.exe", "*\\quser.exe", "*\\qwinsta.exe")) or (process.pe.original_file_name like~ ("whoami.exe", "quser.exe", "qwinsta.exe"))) or (process.executable:"*\\wmic.exe" and (process.command_line:"*useraccount*" and process.command_line:"*get*")) or (process.executable:"*\\cmdkey.exe" and process.command_line:"* /l*"))
