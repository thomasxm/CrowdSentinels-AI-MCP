any where (process.executable:"*\\curl.exe" or process.pe.original_file_name:"curl.exe") and process.command_line:"SigmaRegularExpression(regexp=SigmaString(['://[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3}']), flags=set())" and process.command_line:"*http*" and (process.command_line like~ ("* -O*", "*--remote-name*", "*--output*")) and (process.command_line like~ ("*.bat", "*.bat\"", "*.dat", "*.dat\"", "*.dll", "*.dll\"", "*.exe", "*.exe\"", "*.gif", "*.gif\"", "*.hta", "*.hta\"", "*.jpeg", "*.jpeg\"", "*.log", "*.log\"", "*.msi", "*.msi\"", "*.png", "*.png\"", "*.ps1", "*.ps1\"", "*.psm1", "*.psm1\"", "*.vbe", "*.vbe\"", "*.vbs", "*.vbs\"", "*.bat'", "*.dat'", "*.dll'", "*.exe'", "*.gif'", "*.hta'", "*.jpeg'", "*.log'", "*.msi'", "*.png'", "*.ps1'", "*.psm1'", "*.vbe'", "*.vbs'"))
