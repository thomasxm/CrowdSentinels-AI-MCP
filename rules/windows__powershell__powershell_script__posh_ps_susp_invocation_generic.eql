any where (powershell.file.script_block_text like~ ("* -enc *", "* -EncodedCommand *", "* -ec *")) and (powershell.file.script_block_text like~ ("* -w hidden *", "* -window hidden *", "* -windowstyle hidden *", "* -w 1 *")) and (powershell.file.script_block_text like~ ("* -noni *", "* -noninteractive *"))
