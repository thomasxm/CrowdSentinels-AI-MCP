any where (process.executable:"*\\reg.exe" or process.pe.original_file_name:"reg.exe") and process.command_line:"*\\SOFTWARE\\Policies\\Microsoft\\Windows\\System*" and (process.command_line like~ ("*GroupPolicyRefreshTimeDC*", "*GroupPolicyRefreshTimeOffsetDC*", "*GroupPolicyRefreshTime*", "*GroupPolicyRefreshTimeOffset*", "*EnableSmartScreen*", "*ShellSmartScreenLevel*"))
