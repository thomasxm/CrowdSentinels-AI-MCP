any where winlog.channel:"Microsoft-Windows-WMI-Activity/Operational" and (((event.code:"5861" and ("ActiveScriptEventConsumer" or "CommandLineEventConsumer" or "CommandLineTemplate")) or event.code:"5859") and (not (winlog.event_data.Provider:"SCM Event Provider" and winlog.event_data.Query:"select * from MSFT_SCMEventLogEvent" and user.name:"S-1-5-32-544" and winlog.event_data.PossibleCause:"Permanent")))
