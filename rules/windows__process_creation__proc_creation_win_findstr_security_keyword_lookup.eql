any where ((process.executable like~ ("*\\find.exe", "*\\findstr.exe")) or (process.pe.original_file_name like~ ("FIND.EXE", "FINDSTR.EXE"))) and (process.command_line like~ ("* avira", "* avira\"", "* cb", "* cb\"", "* cylance", "* cylance\"", "* defender", "* defender\"", "* kaspersky", "* kaspersky\"", "* kes", "* kes\"", "* mc", "* mc\"", "* sec", "* sec\"", "* sentinel", "* sentinel\"", "* symantec", "* symantec\"", "* virus", "* virus\""))
