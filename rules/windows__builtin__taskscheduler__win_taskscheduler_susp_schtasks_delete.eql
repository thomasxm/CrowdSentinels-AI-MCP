any where winlog.channel:"Microsoft-Windows-TaskScheduler/Operational" and ((event.code:"141" and (winlog.event_data.TaskName like~ ("*\\Windows\\SystemRestore\\SR*", "*\\Windows\\Windows Defender\*", "*\\Windows\\BitLocker*", "*\\Windows\\WindowsBackup\*", "*\\Windows\\WindowsUpdate\*", "*\\Windows\\UpdateOrchestrator\*", "*\\Windows\\ExploitGuard*"))) and (not (winlog.event_data.UserName like~ ("*AUTHORI*", "*AUTORI*"))))
