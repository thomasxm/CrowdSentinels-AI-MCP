any where (process.command_line like~ ("*\\*\*$*", "*\\Sysvol\*")) and (((process.executable like~ ("*\\robocopy.exe", "*\\xcopy.exe")) or (process.pe.original_file_name like~ ("robocopy.exe", "XCOPY.EXE"))) or ((process.executable:"*\\cmd.exe" or process.pe.original_file_name:"Cmd.Exe") and process.command_line:"*copy*") or (((process.executable like~ ("*\\powershell_ise.exe*", "*\\powershell.exe*", "*\\pwsh.exe*")) or (process.pe.original_file_name like~ ("powershell_ise.exe", "PowerShell.EXE", "pwsh.dll"))) and (process.command_line like~ ("*copy-item*", "*copy *", "*cpi *", "* cp *", "*move *", "* move-item*", "* mi *", "* mv *"))))
