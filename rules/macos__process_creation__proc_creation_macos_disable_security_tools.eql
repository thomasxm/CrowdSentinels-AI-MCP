any where ((Image:"/bin/launchctl" and CommandLine:"*unload*") and (CommandLine like~ ("*com.objective-see.lulu.plist*", "*com.objective-see.blockblock.plist*", "*com.google.santad.plist*", "*com.carbonblack.defense.daemon.plist*", "*com.carbonblack.daemon.plist*", "*at.obdev.littlesnitchd.plist*", "*com.tenablesecurity.nessusagent.plist*", "*com.opendns.osx.RoamingClientConfigUpdater.plist*", "*com.crowdstrike.falcond.plist*", "*com.crowdstrike.userdaemon.plist*", "*osquery*", "*filebeat*", "*auditbeat*", "*packetbeat*", "*td-agent*"))) or (Image:"/usr/sbin/spctl" and CommandLine:"*disable*")
