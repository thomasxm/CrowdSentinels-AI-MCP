any where ((process.parent.executable like~ ("*Acrobat Reader*", "*Microsoft Office*", "*PDF Reader*")) and (process.executable like~ ("*\\brave.exe", "*\\chrome.exe", "*\\firefox.exe", "*\\msedge.exe", "*\\opera.exe", "*\\maxthon.exe", "*\\seamonkey.exe", "*\\vivaldi.exe")) and process.command_line:"*http*") and (not process.command_line:"*https://go.microsoft.com/fwlink/*") and (not (process.command_line like~ ("*http://ad.foxitsoftware.com/adlog.php?*", "*https://globe-map.foxitservice.com/go.php?do=redirect*")))
