any where winlog.channel:"Microsoft-Windows-AppXDeploymentServer/Operational" and (event.code:"854" and (not ((winlog.event_data.Path like~ ("*C:\\Program Files (x86)\*", "*C:\\Program Files\*", "*C:\\Program Files\\WindowsApps\*", "*C:\\Windows\\ImmersiveControlPanel\*", "*C:\\Windows\\PrintDialog\*", "*C:\\Windows\\SystemApps\*", "*file:///C:/Program%20Files/*", "*file:///C:/Program%20Files%20(x86)/*", "*file:///C:/Windows/System32/*")) or (winlog.event_data.Path like~ ("*https://statics.teams.cdn.live.net/*", "*https://statics.teams.cdn.office.net/*", "*microsoft.com*", "*https://installer.teams.static.microsoft/*", "*https://res.cdn.office.net*")))) and (not (winlog.event_data.Path:"*AppData\\Local\\Microsoft\\OneDrive\*" or (winlog.event_data.Path like~ ("*AppData/Local/Temp/WinGet/Microsoft.Winget.Source*", "*AppData\\Local\\Temp\\WinGet\\Microsoft.Winget.Source*")) or winlog.event_data.Path:"*x-windowsupdate://*")))
