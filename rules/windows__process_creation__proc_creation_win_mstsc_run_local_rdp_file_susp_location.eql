any where (process.executable:"*\\mstsc.exe" or process.pe.original_file_name:"mstsc.exe") and (process.command_line like~ ("*.rdp", "*.rdp\"")) and (process.command_line like~ ("*:\\Users\\Public\*", "*:\\Windows\\System32\\spool\\drivers\\color*", "*:\\Windows\\System32\\Tasks_Migrated *", "*:\\Windows\\Tasks\*", "*:\\Windows\\Temp\*", "*:\\Windows\\Tracing\*", "*\\AppData\\Local\\Temp\*", "*\\Downloads\*"))
