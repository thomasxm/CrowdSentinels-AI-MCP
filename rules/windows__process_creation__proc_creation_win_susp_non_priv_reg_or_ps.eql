any where ((process.command_line:"*reg *" and process.command_line:"*add*") or (process.command_line like~ ("*powershell*", "*set-itemproperty*", "* sp *", "*new-itemproperty*"))) and ((winlog.event_data.IntegrityLevel like~ ("Medium", "S-1-16-8192")) and (process.command_line:"*ControlSet*" and process.command_line:"*Services*") and (process.command_line like~ ("*ImagePath*", "*FailureCommand*", "*ServiceDLL*")))
