any where (process.executable:"*\\Certipy.exe" or process.pe.original_file_name:"Certipy.exe" or process.pe.description:"*Certipy*") or ((process.command_line like~ ("* account *", "* auth *", "* cert *", "* find *", "* forge *", "* ptt *", "* relay *", "* req *", "* shadow *", "* template *")) and (process.command_line like~ ("* -bloodhound*", "* -ca-pfx *", "* -dc-ip *", "* -kirbi*", "* -old-bloodhound*", "* -pfx *", "* -target*", "* -template*", "* -username *", "* -vulnerable*", "*auth -pfx*", "*shadow auto*", "*shadow list*")))
