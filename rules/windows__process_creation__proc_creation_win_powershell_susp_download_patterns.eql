any where process.command_line like~ ("*IEX ((New-Object Net.WebClient).DownloadString*", "*IEX (New-Object Net.WebClient).DownloadString*", "*IEX((New-Object Net.WebClient).DownloadString*", "*IEX(New-Object Net.WebClient).DownloadString*", "* -command (New-Object System.Net.WebClient).DownloadFile(*", "* -c (New-Object System.Net.WebClient).DownloadFile(*")
