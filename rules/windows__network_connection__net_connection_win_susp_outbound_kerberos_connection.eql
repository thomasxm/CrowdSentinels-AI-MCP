any where (destination.port:88 and network.direction:"true") and (not process.executable:"C:\\Windows\\System32\\lsass.exe") and (not ((process.executable like~ ("C:\\Program Files (x86)\\Google\\Chrome\\Application\\chrome.exe", "C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe")) or (process.executable like~ ("C:\\Program Files (x86)\\Mozilla Firefox\\firefox.exe", "C:\\Program Files\\Mozilla Firefox\\firefox.exe")) or process.executable:"*\\tomcat\\bin\\tomcat8.exe"))
