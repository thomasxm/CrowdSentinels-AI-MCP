any where (host like~ ("*.bid", "*.by", "*.cf", "*.click", "*.cm", "*.ga", "*.gq", "*.ir", "*.kp", "*.loan", "*.ml", "*.mm", "*.party", "*.pw", "*.ru", "*.su", "*.sy", "*.tk", "*.top", "*.tv", "*.ve", "*.work", "*.xyz")) and ((uri like~ ("*.bat", "*.bin", "*.cmd", "*.cpl", "*.dll", "*.dylib", "*.elf", "*.exe", "*.hta", "*.iso", "*.jar", "*.js", "*.lnk", "*.msi", "*.pif", "*.ps1", "*.py", "*.reg", "*.scr", "*.sh", "*.so", "*.vbs", "*.wsf")) or (resp_mime_types like~ ("application/vnd.microsoft.portable-executable", "application/x-bat", "application/x-dosexec", "application/x-elf", "application/x-iso9660-image", "application/x-java-archive", "application/x-ms-shortcut", "application/x-msdos-program", "application/x-msdownload", "application/x-python-code", "application/x-sh")))
