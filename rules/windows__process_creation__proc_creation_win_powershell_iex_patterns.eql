any where (((process.executable like~ ("*\\powershell.exe", "*\\pwsh.exe")) and (process.command_line like~ ("* | iex;*", "* | iex *", "* | iex}*", "* | IEX ;*", "* | IEX -Error*", "* | IEX (new*", "*);IEX *"))) and (process.command_line like~ ("*::FromBase64String*", "*.GetString([System.Convert]::*"))) or (process.command_line like~ ("*)|iex;$*", "*);iex($*", "*);iex $*", "* | IEX | *", "* | iex\\\"*"))
