any where ((process.executable:"*\\mofcomp.exe" or process.pe.original_file_name:"mofcomp.exe") and ((process.parent.executable like~ ("*\\cmd.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\wsl.exe", "*\\wscript.exe", "*\\cscript.exe")) or (process.command_line like~ ("*\\AppData\\Local\\Temp*", "*\\Users\\Public\*", "*\\WINDOWS\\Temp\*", "*%temp%*", "*%tmp%*", "*%appdata%*")))) and (not (process.parent.executable:"C:\\Windows\\System32\\wbem\\WmiPrvSE.exe" and process.command_line:"*C:\\Windows\\TEMP\*" and process.command_line:"*.mof")) and (not (process.command_line:"*C:\\Windows\\TEMP\*" and process.command_line:"*.mof"))
