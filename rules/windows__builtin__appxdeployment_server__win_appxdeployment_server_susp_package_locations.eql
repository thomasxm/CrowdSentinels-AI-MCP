any where winlog.channel:"Microsoft-Windows-AppXDeploymentServer/Operational" and (event.code:"854" and (winlog.event_data.Path like~ ("*C:\\Users\\Public\*", "*/users/public/*", "*C:\\PerfLogs\*", "*C:/perflogs/*", "*\\Desktop\*", "*/desktop/*", "*\\Downloads\*", "*/Downloads/*", "*C:\\Windows\\Temp\*", "*C:/Windows/Temp/*", "*\\AppdData\\Local\\Temp\*", "*/AppdData/Local/Temp/*")))
