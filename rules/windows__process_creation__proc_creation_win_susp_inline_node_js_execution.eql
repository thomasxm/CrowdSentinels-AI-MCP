any where (process.executable:"*\\node.exe" or process.pe.original_file_name:"node.exe" or process.pe.product:"Node.js") and (process.command_line:"*http*" and process.command_line:"*execSync*" and process.command_line:"*spawn*" and process.command_line:"*fs*" and process.command_line:"*path*" and process.command_line:"*zlib*")
