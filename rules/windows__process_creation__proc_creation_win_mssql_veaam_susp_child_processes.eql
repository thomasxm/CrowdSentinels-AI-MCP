any where (process.parent.executable:"*\\sqlservr.exe" and process.parent.command_line:"*VEEAMSQL*") and (((process.executable like~ ("*\\cmd.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\wsl.exe", "*\\wt.exe")) and (process.command_line like~ ("*-ex *", "*bypass*", "*cscript*", "*DownloadString*", "*http://*", "*https://*", "*mshta*", "*regsvr32*", "*rundll32*", "*wscript*", "*copy *"))) or (process.executable like~ ("*\\net.exe", "*\\net1.exe", "*\\netstat.exe", "*\\nltest.exe", "*\\ping.exe", "*\\tasklist.exe", "*\\whoami.exe")))
