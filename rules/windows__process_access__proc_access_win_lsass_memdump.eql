any where (winlog.event_data.TargetImage:"*\\lsass.exe" and (winlog.event_data.GrantedAccess like~ ("*0x1038*", "*0x1438*", "*0x143a*", "*0x1fffff*")) and (winlog.event_data.CallTrace like~ ("*dbgcore.dll*", "*dbghelp.dll*", "*kernel32.dll*", "*kernelbase.dll*", "*ntdll.dll*"))) and (not (winlog.event_data.SourceUser like~ ("*AUTHORI*", "*AUTORI*"))) and (not (((winlog.event_data.CallTrace:"*:\\Windows\\Temp\\asgard2-agent\*" and winlog.event_data.CallTrace:"*\\thor\\thor64.exe+*" and winlog.event_data.CallTrace:"*|UNKNOWN(*") and winlog.event_data.GrantedAccess:"0x103800") or process.executable:"*:\\Windows\\Sysmon64.exe"))
