any where winlog.channel:"System" and ((winlog.provider_name:"Service Control Manager" and event.code:"7045") and ((winlog.event_data.ImagePath like~ ("*\\.\\pipe*", "*\\Users\\Public\*", "*\\Windows\\Temp\*")) or (winlog.event_data.ImagePath:"* -e*" and (winlog.event_data.ImagePath like~ ("* aQBlAHgA*", "* aWV4I*", "* IAB*", "* JAB*", "* PAA*", "* SQBFAFgA*", "* SUVYI*")))) and (not winlog.event_data.ImagePath:"C:\\ProgramData\\Microsoft\\Windows Defender\\Definition Updates\*") and (not winlog.event_data.ImagePath:"C:\\WINDOWS\\TEMP\\thor10-remote\\thor64.exe*"))
