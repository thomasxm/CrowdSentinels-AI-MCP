any where (((process.executable like~ ("*\\net.exe", "*\\net1.exe")) or (process.pe.original_file_name like~ ("net.exe", "net1.exe"))) and process.command_line:"* user *" and (process.command_line like~ ("* Järjestelmänvalvoja *", "* Rendszergazda *", "* Администратор *", "* Administrateur *", "* Administrador *", "* Administratör *", "* Administrator *", "* guest *", "* DefaultAccount *", "* \"Järjestelmänvalvoja\" *", "* \"Rendszergazda\" *", "* \"Администратор\" *", "* \"Administrateur\" *", "* \"Administrador\" *", "* \"Administratör\" *", "* \"Administrator\" *", "* \"guest\" *", "* \"DefaultAccount\" *", "* 'Järjestelmänvalvoja' *", "* 'Rendszergazda' *", "* 'Администратор' *", "* 'Administrateur' *", "* 'Administrador' *", "* 'Administratör' *", "* 'Administrator' *", "* 'guest' *", "* 'DefaultAccount' *"))) and (not (process.command_line:"*guest*" and process.command_line:"*/active no*"))
