any where (process.parent.executable like~ ("*\\bginfo.exe", "*\\bginfo64.exe")) and ((process.executable like~ ("*\\calc.exe", "*\\cmd.exe", "*\\cscript.exe", "*\\mshta.exe", "*\\notepad.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\wscript.exe")) or (process.executable like~ ("*\\AppData\\Local\*", "*\\AppData\\Roaming\*", "*:\\Users\\Public\*", "*:\\Temp\*", "*:\\Windows\\Temp\*", "*:\\PerfLogs\*")))
