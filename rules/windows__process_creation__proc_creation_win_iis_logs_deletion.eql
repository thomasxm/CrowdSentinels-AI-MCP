any where ((process.executable like~ ("*\\cmd.exe", "*\\powershell_ise.exe", "*\\powershell.exe", "*\\pwsh.exe")) or (process.pe.original_file_name like~ ("cmd.exe", "powershell.exe", "powershell_ise.exe", "pwsh.dll"))) and (process.command_line like~ ("*del *", "*erase *", "*rm *", "*remove-item *", "*rmdir *")) and process.command_line:"*\\inetpub\\logs\*"
