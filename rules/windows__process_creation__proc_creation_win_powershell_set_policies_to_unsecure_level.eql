any where (((process.pe.original_file_name like~ ("powershell_ise.exe", "PowerShell.EXE", "pwsh.dll")) or (process.executable like~ ("*\\powershell_ise.exe", "*\\powershell.exe", "*\\pwsh.exe"))) and (process.command_line like~ ("*-executionpolicy *", "* -ep *", "* -exec *")) and (process.command_line like~ ("*Bypass*", "*Unrestricted*"))) and (not ((process.parent.executable like~ ("C:\\Windows\\SysWOW64\\msiexec.exe", "C:\\Windows\\System32\\msiexec.exe")) and (process.command_line like~ ("*-NoProfile -ExecutionPolicy Bypass -File \"C:\\Program Files\\PowerShell\\7\*", "*-NoProfile -ExecutionPolicy Bypass -File \"C:\\Program Files (x86)\\PowerShell\\7\*")))) and (not ((process.parent.executable like~ ("*C:\\Program Files\\Avast Software\\Avast\*", "*C:\\Program Files (x86)\\Avast Software\\Avast\*", "*\\instup.exe*")) and (process.command_line like~ ("*-ExecutionPolicy ByPass -File \"C:\\Program Files\\Avast Software\\Avast*", "*-ExecutionPolicy ByPass -File \"C:\\Program Files (x86)\\Avast Software\\Avast\*"))))
