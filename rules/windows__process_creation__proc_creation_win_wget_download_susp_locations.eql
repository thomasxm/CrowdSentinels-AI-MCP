any where (process.executable:"*\\wget.exe" or process.pe.original_file_name:"wget.exe") and process.command_line:"SigmaRegularExpression(regexp=SigmaString(['://[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3}']), flags=set())" and process.command_line:"*http*" and (process.command_line like~ ("SigmaRegularExpression(regexp=SigmaString(['\\s-O\\s']), flags=set())", "*--output-document*")) and ((process.command_line like~ ("*:\\PerfLogs\*", "*:\\Temp\*", "*:\\Users\\Public\*", "*:\\Windows\\Help\*", "*:\\Windows\\Temp\*", "*\\Temporary Internet*")) or (process.command_line:"*:\\Users\*" and process.command_line:"*\\Favorites\*") or (process.command_line:"*:\\Users\*" and process.command_line:"*\\Favourites\*") or (process.command_line:"*:\\Users\*" and process.command_line:"*\\Contacts\*") or (process.command_line:"*:\\Users\*" and process.command_line:"*\\Pictures\*"))
