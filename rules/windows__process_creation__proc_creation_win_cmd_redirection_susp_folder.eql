any where (process.executable:"*\\cmd.exe" or process.pe.original_file_name:"Cmd.Exe") and ((process.command_line like~ ("*>?%APPDATA%\*", "*>?%TEMP%\*", "*>?%TMP%\*", "*>?%USERPROFILE%\*", "*>?C:\\ProgramData\*", "*>?C:\\Temp\*", "*>?C:\\Users\\Public\*", "*>?C:\\Windows\\Temp\*")) or ((process.command_line like~ ("* >*", "*\">*", "*'>*")) and (process.command_line:"*C:\\Users\*" and process.command_line:"*\\AppData\\Local\*")))
