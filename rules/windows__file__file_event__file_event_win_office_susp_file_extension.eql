any where ((process.executable like~ ("*\\excel.exe", "*\\msaccess.exe", "*\\mspub.exe", "*\\powerpnt.exe", "*\\visio.exe", "*\\winword.exe")) and (file.path like~ ("*.bat", "*.cmd", "*.com", "*.dll", "*.exe", "*.hta", "*.ocx", "*.proj", "*.ps1", "*.scf", "*.scr", "*.sys", "*.vbe", "*.vbs", "*.wsf", "*.wsh"))) and (not (file.path:"*\\AppData\\Local\\assembly\\tmp\*" and file.path:"*.dll")) and (not (((file.path:"*C:\\Users\*" and file.path:"*\\AppData\\Local\\Microsoft\\Office\*" and file.path:"*\\WebServiceCache\\AllUsers*") and file.path:"*.com") or (process.executable:"*\\winword.exe" and file.path:"*\\AppData\\Local\\Temp\\webexdelta\*" and (file.path like~ ("*.dll", "*.exe"))) or ((file.path:"*C:\\Users\*" and file.path:"*\\AppData\\Local\\Microsoft\\Office\*" and file.path:"*\\BackstageInAppNavCache\*") and file.path:"*.com")))
