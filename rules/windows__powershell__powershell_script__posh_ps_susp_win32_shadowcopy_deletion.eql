any where (powershell.file.script_block_text like~ ("*Get-WmiObject*", "*gwmi*", "*Get-CimInstance*", "*gcim*")) and powershell.file.script_block_text:"*Win32_ShadowCopy*" and (powershell.file.script_block_text like~ ("*.Delete()*", "*Remove-WmiObject*", "*rwmi*", "*Remove-CimInstance*", "*rcim*"))
