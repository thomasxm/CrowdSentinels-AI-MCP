any where (process.executable like~ ("*\\brave.exe", "*\\chrome.exe", "*\\msedge.exe", "*\\opera.exe", "*\\vivaldi.exe")) and process.command_line:"*http*" and ((process.command_line like~ ("*.7z", "*.dat", "*.dll", "*.exe", "*.hta", "*.ps1", "*.psm1", "*.txt", "*.vbe", "*.vbs", "*.zip")) or (process.command_line like~ ("*.7z\"*", "*.dat\"*", "*.dll\"*", "*.hta\"*", "*.ps1\"*", "*.psm1\"*", "*.txt\"*", "*.vbe\"*", "*.vbs\"*", "*.zip\"*")))
