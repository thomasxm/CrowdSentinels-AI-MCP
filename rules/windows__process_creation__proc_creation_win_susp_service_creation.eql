any where ((process.executable:"*\\sc.exe" and (process.command_line:"*create*" and process.command_line:"*binPath=*")) or (process.command_line:"*New-Service*" and process.command_line:"*-BinaryPathName*")) and (process.command_line like~ ("*powershell*", "*mshta*", "*wscript*", "*cscript*", "*svchost*", "*dllhost*", "*cmd *", "*cmd.exe /c*", "*cmd.exe /k*", "*cmd.exe /r*", "*rundll32*", "*C:\\Users\\Public*", "*\\Downloads\*", "*\\Desktop\*", "*\\Microsoft\\Windows\\Start Menu\\Programs\\Startup\*", "*C:\\Windows\\TEMP\*", "*\\AppData\\Local\\Temp*"))
