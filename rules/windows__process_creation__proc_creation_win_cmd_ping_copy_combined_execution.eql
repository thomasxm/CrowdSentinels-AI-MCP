any where (process.executable:"*\\cmd.exe" or process.pe.original_file_name:"Cmd.Exe") and (process.command_line:"*ping*" and process.command_line:"*copy *") and process.command_line like~ ("* -n *", "* /n *", "* –n *", "* —n *", "* ―n *") and process.command_line like~ ("* -y *", "* /y *", "* –y *", "* —y *", "* ―y *")
