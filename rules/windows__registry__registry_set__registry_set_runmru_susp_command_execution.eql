any where registry.path:"*\\Microsoft\\Windows\\CurrentVersion\\Explorer\\RunMRU*" and (((winlog.event_data.Details like~ ("*powershell*", "*pwsh*")) and (winlog.event_data.Details like~ ("* -e *", "* -ec *", "* -en *", "* -enc *", "* -enco*", "*ftp*", "*Hidden*", "*http*", "*iex*", "*Invoke-*"))) or (winlog.event_data.Details:"*wmic*" and (winlog.event_data.Details like~ ("*shadowcopy*", "*process call create*"))))
