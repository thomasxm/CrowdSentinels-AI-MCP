any where ((process.executable:"*\\msiexec.exe" or process.pe.original_file_name:"msiexec.exe") and (process.command_line like~ ("*-i*", "*/i*", "*–i*", "*—i*", "*―i*") or process.command_line like~ ("*-package*", "*/package*", "*–package*", "*—package*", "*―package*") or process.command_line like~ ("*-a*", "*/a*", "*–a*", "*—a*", "*―a*") or process.command_line like~ ("*-j*", "*/j*", "*–j*", "*—j*", "*―j*")) and process.command_line like~ ("*-q*", "*/q*", "*–q*", "*—q*", "*―q*") and (process.command_line like~ ("*http*", "*\\*"))) and (not (process.command_line:"*\\AppData\\Local\\Temp\\OpenOffice*" and process.command_line:"*Installation Files\\openoffice*"))
