any where (registry.path:"*Software\\Microsoft\\Windows\\CurrentVersion*" and (winlog.event_data.Details like~ ("*vbscript:*", "*jscript:*", "*mshtml,*", "*RunHTMLApplication*", "*Execute(*", "*CreateObject*", "*window.close*"))) and (not (registry.path:"*Software\\Microsoft\\Windows\\CurrentVersion\\Run*" or (process.executable:"*\\msiexec.exe" and registry.path:"*\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Installer\\UserData\*" and (winlog.event_data.Details like~ ("*\\Microsoft.NET\\Primary Interop Assemblies\\Microsoft.mshtml.dll*", "*<\\Microsoft.mshtml,fileVersion=*", "*_mshtml_dll_*", "*<\\Microsoft.mshtml,culture=*")))))
