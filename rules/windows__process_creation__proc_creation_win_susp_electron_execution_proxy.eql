any where ((process.executable like~ ("*\\chrome.exe", "*\\code.exe", "*\\discord.exe", "*\\GitHubDesktop.exe", "*\\keybase.exe", "*\\msedge_proxy.exe", "*\\msedge.exe", "*\\msedgewebview2.exe", "*\\msteams.exe", "*\\slack.exe", "*\\Teams.exe")) or (process.pe.original_file_name like~ ("chrome.exe", "code.exe", "discord.exe", "GitHubDesktop.exe", "keybase.exe", "msedge_proxy.exe", "msedge.exe", "msedgewebview2.exe", "msteams.exe", "slack.exe", "Teams.exe"))) and (process.command_line like~ ("*--browser-subprocess-path*", "*--gpu-launcher*", "*--renderer-cmd-prefix*", "*--utility-cmd-prefix*"))
