any where (winlog.event_data.Contents:"[ZoneTransfer]  ZoneId=3*" and file.path:"*:Zone.Identifier" and (file.path like~ ("*.exe*", "*.scr*", "*.bat*", "*.cmd*", "*.docx*", "*.hta*", "*.jse*", "*.lnk*", "*.pptx*", "*.ps*", "*.reg*", "*.sct*", "*.vb*", "*.wsc*", "*.wsf*", "*.xlsx*"))) and (not (process.executable:"*\\brave.exe" or (process.executable like~ ("C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe", "C:\\Program Files (x86)\\Google\\Chrome\\Application\\chrome.exe")) or (process.executable like~ ("C:\\Program Files\\Mozilla Firefox\\firefox.exe", "C:\\Program Files (x86)\\Mozilla Firefox\\firefox.exe")) or (process.executable like~ ("C:\\Program Files (x86)\\Internet Explorer\\iexplore.exe", "C:\\Program Files\\Internet Explorer\\iexplore.exe")) or process.executable:"*\\maxthon.exe" or (process.executable:"C:\\Program Files (x86)\\Microsoft\\EdgeWebView\\Application\*" or process.executable:"*\\WindowsApps\\MicrosoftEdge.exe" or (process.executable like~ ("C:\\Program Files (x86)\\Microsoft\\Edge\\Application\\msedge.exe", "C:\\Program Files\\Microsoft\\Edge\\Application\\msedge.exe"))) or ((process.executable like~ ("C:\\Program Files (x86)\\Microsoft\\EdgeCore\*", "C:\\Program Files\\Microsoft\\EdgeCore\*")) and (process.executable like~ ("*\\msedge.exe", "*\\msedgewebview2.exe"))) or process.executable:"*\\opera.exe" or process.executable:"*\\safari.exe" or process.executable:"*\\seamonkey.exe" or process.executable:"*\\vivaldi.exe" or process.executable:"*\\whale.exe" or (process.executable:"C:\\Program Files\\WindowsApps\\Microsoft.ScreenSketch_*" and process.executable:"*\\SnippingTool\\SnippingTool.exe" and file.path:"C:\\Users\*" and (file.path:"*\\AppData\\Local\\Packages\\Microsoft.ScreenSketch_*" and file.path:"*\\TempState\\Screenshot *") and file.path:"*.png:Zone.Identifier")))
