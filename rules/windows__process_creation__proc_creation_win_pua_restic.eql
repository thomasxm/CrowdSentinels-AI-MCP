any where ((process.command_line:"*--password-file*" and process.command_line:"*init*" and process.command_line:"* -r *") or (process.command_line:"*--use-fs-snapshot*" and process.command_line:"*backup*" and process.command_line:"* -r *")) or ((process.command_line like~ ("*sftp:*", "*rest:http*", "*s3:s3.*", "*s3.http*", "*azure:*", "* gs:*", "*rclone:*", "*swift:*", "* b2:*")) and (process.command_line:"* init *" and process.command_line:"* -r *"))
