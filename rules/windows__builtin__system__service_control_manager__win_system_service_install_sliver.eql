any where winlog.channel:"System" and ((winlog.provider_name:"Service Control Manager" and event.code:"7045") and (winlog.event_data.ImagePath:"SigmaRegularExpression(regexp=SigmaString(['^[a-zA-Z]:\\\\windows\\\\temp\\\\[a-zA-Z0-9]{10}\\.exe']), flags=set())" or (winlog.event_data.ServiceName like~ ("Sliver", "Sliver implant"))))
