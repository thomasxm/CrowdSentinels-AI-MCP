any where (((process.executable:"*:\\Users\*" and process.executable:"*\\AppData\\Local\\packages\\KaliLinux*") or (process.executable:"*:\\Users\*" and process.executable:"*\\AppData\\Local\\Microsoft\\WindowsApps\\kali.exe*")) or (process.executable:"*:\\Program Files\\WindowsApps\\KaliLinux.*" and process.executable:"*\\kali.exe")) or (((process.parent.executable like~ ("*\\wsl.exe", "*\\wslhost.exe")) and ((process.executable like~ ("*\\kali.exe*", "*\\KaliLinux*")) or (process.command_line like~ ("*Kali.exe*", "*Kali-linux*", "*kalilinux*")))) and (not (process.command_line like~ ("* -i *", "* --install *", "* --unregister *"))))
