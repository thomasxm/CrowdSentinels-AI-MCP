any where winlog.channel:"System" and ((winlog.provider_name:"Service Control Manager" and event.code:"7045") and (((winlog.event_data.ImagePath:"*/c*" and winlog.event_data.ImagePath:"*echo*" and winlog.event_data.ImagePath:"*\\pipe\*") and (winlog.event_data.ImagePath like~ ("*cmd*", "*%COMSPEC%*"))) or (winlog.event_data.ImagePath:"*rundll32*" and winlog.event_data.ImagePath:"*.dll,a*" and winlog.event_data.ImagePath:"*/p:*") or winlog.event_data.ImagePath:"\\127.0.0.1\\ADMIN$\*"))
