any where (process.parent.executable like~ ("*\\WINWORD.EXE", "*\\EXCEL.EXE", "*\\POWERPNT.exe", "*\\MSPUB.exe", "*\\VISIO.exe", "*\\MSACCESS.EXE", "*\\EQNEDT32.EXE", "*\\ONENOTE.EXE", "*\\wordpad.exe", "*\\wordview.exe")) and (process.executable:"*\\wbem\\WMIC.exe" or process.pe.original_file_name:"wmic.exe") and ((process.command_line:"*process*" and process.command_line:"*create*" and process.command_line:"*call*") and (process.command_line like~ ("*regsvr32*", "*rundll32*", "*msiexec*", "*mshta*", "*verclsid*", "*wscript*", "*cscript*")))
