any where ((process.executable like~ ("*\\powershell.exe", "*\\pwsh.exe")) or (process.pe.original_file_name like~ ("PowerShell.EXE", "pwsh.dll"))) and (not ((process.parent.executable like~ ("*:\\Windows\\explorer.exe", "*:\\Windows\\System32\\CompatTelRunner.exe", "*:\\Windows\\SysWOW64\\explorer.exe")) or process.parent.executable:":\\$WINDOWS.~BT\\Sources\\SetupHost.exe")) and (not ((process.parent.executable:"*\\AppData\\Local\\Programs\\Microsoft VS Code\\Code.exe" and process.parent.command_line:"* --ms-enable-electron-run-as-node *") or (process.parent.executable:"*:\\Program Files\\WindowsApps\\Microsoft.WindowsTerminal_*" and process.parent.executable:"*\\WindowsTerminal.exe")))
