(((process.command_line:(*\ \-create\ * OR *\ \/create\ * OR *\ –create\ * OR *\ —create\ * OR *\ ―create\ *) OR process.command_line:(*\ \-delete\ * OR *\ \/delete\ * OR *\ –delete\ * OR *\ —delete\ * OR *\ ―delete\ *) OR process.command_line:(*\ \-query\ * OR *\ \/query\ * OR *\ –query\ * OR *\ —query\ * OR *\ ―query\ *) OR process.command_line:(*\ \-change\ * OR *\ \/change\ * OR *\ –change\ * OR *\ —change\ * OR *\ ―change\ *) OR process.command_line:(*\ \-run\ * OR *\ \/run\ * OR *\ –run\ * OR *\ —run\ * OR *\ ―run\ *) OR process.command_line:(*\ \-end\ * OR *\ \/end\ * OR *\ –end\ * OR *\ —end\ * OR *\ ―end\ *)) AND (process.command_line:(*\ \-tn\ * OR *\ \/tn\ * OR *\ –tn\ * OR *\ —tn\ * OR *\ ―tn\ *) OR process.command_line:(*\ \-tr\ * OR *\ \/tr\ * OR *\ –tr\ * OR *\ —tr\ * OR *\ ―tr\ *) OR process.command_line:(*\ \-sc\ * OR *\ \/sc\ * OR *\ –sc\ * OR *\ —sc\ * OR *\ ―sc\ *) OR process.command_line:(*\ \-st\ * OR *\ \/st\ * OR *\ –st\ * OR *\ —st\ * OR *\ ―st\ *) OR process.command_line:(*\ \-ru\ * OR *\ \/ru\ * OR *\ –ru\ * OR *\ —ru\ * OR *\ ―ru\ *) OR process.command_line:(*\ \-fo\ * OR *\ \/fo\ * OR *\ –fo\ * OR *\ —fo\ * OR *\ ―fo\ *))) AND (NOT process.command_line:*schtasks*)) OR (process.pe.original_file_name:schtasks.exe AND (NOT process.executable:*\\schtasks.exe))
