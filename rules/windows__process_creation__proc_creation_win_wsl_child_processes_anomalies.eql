any where (process.parent.executable like~ ("*\\wsl.exe", "*\\wslhost.exe")) and ((process.executable like~ ("*\\calc.exe", "*\\cmd.exe", "*\\cscript.exe", "*\\mshta.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\regsvr32.exe", "*\\rundll32.exe", "*\\wscript.exe")) or (process.executable like~ ("*\\AppData\\Local\\Temp\*", "*C:\\Users\\Public\*", "*C:\\Windows\\Temp\*", "*C:\\Temp\*", "*\\Downloads\*", "*\\Desktop\*")))
