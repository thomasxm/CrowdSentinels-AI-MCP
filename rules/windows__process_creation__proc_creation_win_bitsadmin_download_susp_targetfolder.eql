any where (process.executable:"*\\bitsadmin.exe" or process.pe.original_file_name:"bitsadmin.exe") and (process.command_line like~ ("* /transfer *", "* /create *", "* /addfile *")) and (process.command_line like~ ("*:\\Perflogs*", "*:\\ProgramData\*", "*:\\Temp\*", "*:\\Users\\Public\*", "*:\\Windows\*", "*\\AppData\\Local\\Temp\*", "*\\AppData\\Roaming\*", "*\\Desktop\*", "*%ProgramData%*", "*%public%*"))
