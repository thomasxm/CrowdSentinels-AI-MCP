any where ((process.executable like~ ("*\\powershell.exe", "*\\pwsh.exe", "*\\mshta.exe", "*\\wscript.exe", "*\\cscript.exe")) and (process.command_line like~ ("*\\Windows\\Temp*", "*\\Temporary Internet*", "*\\AppData\\Local\\Temp*", "*\\AppData\\Roaming\\Temp*", "*%TEMP%*", "*%TMP%*", "*%LocalAppData%\\Temp*"))) and (not (process.command_line like~ ("* >*", "*Out-File*", "*ConvertTo-Json*", "*-WindowStyle hidden -Verb runAs*", "*\\Windows\\system32\\config\\systemprofile\\AppData\\Local\\Temp\\Amazon\\EC2-Windows\*")))
