((process.executable:(*\\powershell.exe OR *\\powershell_ise.exe OR *\\pwsh.exe)) AND (file.path:(*.bat OR *.chm OR *.cmd OR *.com OR *.dll OR *.exe OR *.hta OR *.jar OR *.js OR *.ocx OR *.scr OR *.sys OR *.vbe OR *.vbs OR *.wsf))) AND (NOT ((file.path:C\:\\Users\* AND file.path:*\\AppData\\Local\\Temp\* AND (file.path:(*.dll OR *.exe))) OR ((file.path:(C\:\\Windows\\Temp\* OR C\:\\Windows\\SystemTemp\*)) AND (file.path:(*.dll OR *.exe))) OR (file.path:C\:\\Users\* AND file.path:*\\WindowsPowerShell\\Modules\* AND file.path:*.dll) OR (file.path:C\:\\Program\ Files\\PackageManagement\\ProviderAssemblies\\nuget\* AND file.path:*\\Microsoft.PackageManagement.NuGetProvider.dll)))
