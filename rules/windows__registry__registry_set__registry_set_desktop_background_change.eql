any where (registry.path like~ ("*Control Panel\\Desktop*", "*CurrentVersion\\Policies\\ActiveDesktop*", "*CurrentVersion\\Policies\\System*")) and ((registry.path:"*NoChangingWallpaper" and winlog.event_data.Details:"DWORD (0x00000001)") or registry.path:"*\\Wallpaper" or (registry.path:"*\\WallpaperStyle" and winlog.event_data.Details:"2")) and (not (process.executable:"*\\svchost.exe" or (registry.path:"*\\Control Panel\\Desktop\\Wallpaper" and winlog.event_data.Details:"(Empty)") or process.executable:"*C:\\Windows\\Explorer.EXE")) and (not ((process.executable like~ ("C:\\Program Files\\Amazon\\EC2Launch\\EC2Launch.exe", "C:\\Program Files (x86)\\Amazon\\EC2Launch\\EC2Launch.exe")) and registry.path:"*\\Control Panel\\Desktop\\Wallpaper"))
