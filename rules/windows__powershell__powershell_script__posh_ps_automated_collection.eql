any where (powershell.file.script_block_text like~ ("*.doc*", "*.docx*", "*.xls*", "*.xlsx*", "*.ppt*", "*.pptx*", "*.rtf*", "*.pdf*", "*.txt*")) and (powershell.file.script_block_text:"*Get-ChildItem*" and powershell.file.script_block_text:"* -Recurse *" and powershell.file.script_block_text:"* -Include *")
