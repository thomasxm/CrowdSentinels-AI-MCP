any where ((process.pe.original_file_name like~ ("PingCastleReporting.exe", "PingCastleCloud.exe", "PingCastle.exe")) or (process.command_line like~ ("*--scanner aclcheck*", "*--scanner antivirus*", "*--scanner computerversion*", "*--scanner foreignusers*", "*--scanner laps_bitlocker*", "*--scanner localadmin*", "*--scanner nullsession*", "*--scanner nullsession-trust*", "*--scanner oxidbindings*", "*--scanner remote*", "*--scanner share*", "*--scanner smb*", "*--scanner smb3querynetwork*", "*--scanner spooler*", "*--scanner startup*", "*--scanner zerologon*")) or process.command_line:"*--no-enum-limit*" or (process.command_line:"*--healthcheck*" and process.command_line:"*--level Full*") or (process.command_line:"*--healthcheck*" and process.command_line:"*--server *")) and (not (process.executable like~ ("*\\PingCastleReporting.exe", "*\\PingCastleCloud.exe", "*\\PingCastle.exe")))
