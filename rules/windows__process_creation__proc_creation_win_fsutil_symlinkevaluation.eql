any where ((process.executable like~ ("*\\cmd.exe", "*\\powershell.exe", "*\\pwsh.exe")) or (process.pe.original_file_name like~ ("Cmd.Exe", "PowerShell.EXE", "pwsh.dll"))) and (process.command_line:"*fsutil*" and process.command_line:"*behavior*" and process.command_line:"*set*" and process.command_line:"*SymlinkEvaluation*") and (process.command_line like~ ("*R2L:1*", "*R2R:1*", "*L2L:1*"))
