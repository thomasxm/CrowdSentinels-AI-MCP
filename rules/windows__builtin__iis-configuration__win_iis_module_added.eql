any where (event.code:"29" and winlog.event_data.Configuration:"*/system.webServer/modules/add*") and (not ((winlog.event_data.NewValue like~ ("AnonymousAuthenticationModule", "CustomErrorModule", "DefaultDocumentModule", "DirectoryListingModule", "FileCacheModule", "HttpCacheModule", "HttpLoggingModule", "ProtocolSupportModule", "RequestFilteringModule", "StaticCompressionModule", "StaticFileModule", "TokenCacheModule", "UriCacheModule")) or winlog.event_data.NewValue==""))
