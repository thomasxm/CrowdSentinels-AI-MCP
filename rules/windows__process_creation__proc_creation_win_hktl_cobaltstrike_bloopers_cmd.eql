any where (process.pe.original_file_name:"Cmd.Exe" or process.executable:"*\\cmd.exe") and ((process.command_line like~ ("cmd *", "cmd.exe*", "c:\\windows\\system32\\cmd.exe*")) and (process.command_line like~ ("*psinject*", "*spawnas*", "*make_token*", "*remote-exec*", "*rev2self*", "*dcsync*", "*logonpasswords*", "*execute-assembly*", "*getsystem*")))
