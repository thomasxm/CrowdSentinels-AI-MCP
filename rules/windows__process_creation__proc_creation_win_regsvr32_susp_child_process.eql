any where (process.parent.executable:"*\\regsvr32.exe" and (process.executable like~ ("*\\calc.exe", "*\\cscript.exe", "*\\explorer.exe", "*\\mshta.exe", "*\\net.exe", "*\\net1.exe", "*\\nltest.exe", "*\\notepad.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\reg.exe", "*\\schtasks.exe", "*\\werfault.exe", "*\\wscript.exe"))) and (not (process.executable:"*\\werfault.exe" and process.command_line:"* -u -p *"))
