any where (((process.executable like~ ("*\\powershell_ise.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\cmd.exe")) and (process.command_line like~ ("*curl *", "*Invoke-RestMethod*", "*Invoke-WebRequest*", "*irm *", "*iwr *", "*wget *")) and (process.command_line:"* -ur*" and process.command_line:"* -me*" and process.command_line:"* -b*" and process.command_line:"* POST *")) or ((process.executable:"*\\curl.exe" and process.command_line:"*--ur*") and (process.command_line like~ ("* -d *", "* --data *"))) or (process.executable:"*\\wget.exe" and (process.command_line like~ ("*--post-data*", "*--post-file*")))) and ((process.command_line like~ ("SigmaRegularExpression(regexp=SigmaString(['net\\s+view']), flags=set())", "SigmaRegularExpression(regexp=SigmaString(['sc\\s+query']), flags=set())")) or (process.command_line like~ ("*Get-Content*", "*GetBytes*", "*hostname*", "*ifconfig*", "*ipconfig*", "*netstat*", "*nltest*", "*qprocess*", "*systeminfo*", "*tasklist*", "*ToBase64String*", "*whoami*")) or (process.command_line:"*type *" and process.command_line:"* > *" and process.command_line:"* C:\*"))
