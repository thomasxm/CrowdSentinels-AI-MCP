any where (process.executable:"*\\reg.exe" or process.pe.original_file_name:"reg.exe") and process.command_line:"*query*" and (process.command_line like~ ("*currentVersion\\windows*", "*winlogon\*", "*currentVersion\\shellServiceObjectDelayLoad*", "*currentVersion\\run*", "*currentVersion\\policies\\explorer\\run*", "*currentcontrolset\\services*"))
