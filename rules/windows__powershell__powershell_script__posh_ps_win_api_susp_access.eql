any where (powershell.file.script_block_text:"*VirtualAlloc*" and powershell.file.script_block_text:"*OpenProcess*" and powershell.file.script_block_text:"*WriteProcessMemory*" and powershell.file.script_block_text:"*CreateRemoteThread*") or (powershell.file.script_block_text:"*OpenProcessToken*" and powershell.file.script_block_text:"*LookupPrivilegeValue*" and powershell.file.script_block_text:"*AdjustTokenPrivileges*") or (powershell.file.script_block_text:"*OpenProcessToken*" and powershell.file.script_block_text:"*DuplicateTokenEx*" and powershell.file.script_block_text:"*CloseHandle*") or (powershell.file.script_block_text:"*WriteProcessMemory*" and powershell.file.script_block_text:"*VirtualAlloc*" and powershell.file.script_block_text:"*ReadProcessMemory*" and powershell.file.script_block_text:"*VirtualFree*")
