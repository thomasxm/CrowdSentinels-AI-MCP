any where winlog.channel:"Security" and (((event.code like~ ("4699", "4701")) and (winlog.event_data.TaskName like~ ("*\\Windows\\SystemRestore\\SR*", "*\\Windows\\Windows Defender\*", "*\\Windows\\BitLocker*", "*\\Windows\\WindowsBackup\*", "*\\Windows\\WindowsUpdate\*", "*\\Windows\\UpdateOrchestrator\\Schedule*", "*\\Windows\\ExploitGuard*"))) and (not (event.code:"4699" and user.name:"*$" and winlog.event_data.TaskName:"*\\Windows\\Windows Defender\*")))
