any where ((process.executable like~ ("*\\Regsvcs.exe", "*\\Regasm.exe")) or (process.pe.original_file_name like~ ("RegSvcs.exe", "RegAsm.exe"))) and (process.command_line like~ ("*\\AppData\\Local\\Temp\*", "*\\Microsoft\\Windows\\Start Menu\\Programs\\Startup\*", "*\\PerfLogs\*", "*\\Users\\Public\*", "*\\Windows\\Temp\*"))
