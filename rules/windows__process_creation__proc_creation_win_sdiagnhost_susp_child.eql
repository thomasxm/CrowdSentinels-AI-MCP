any where (process.parent.executable:"*\\sdiagnhost.exe" and (process.executable like~ ("*\\powershell.exe", "*\\pwsh.exe", "*\\cmd.exe", "*\\mshta.exe", "*\\cscript.exe", "*\\wscript.exe", "*\\taskkill.exe", "*\\regsvr32.exe", "*\\rundll32.exe", "*\\calc.exe"))) and (not ((process.executable:"*\\cmd.exe" and process.command_line:"*bits*") or (process.executable:"*\\powershell.exe" and (process.command_line like~ ("*-noprofile -", "*-noprofile")))))
