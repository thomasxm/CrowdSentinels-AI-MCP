any where (type:"PATH" and (name like~ ("/etc/login.defs", "/etc/pam.d/auth", "/etc/pam.d/common-account", "/etc/pam.d/common-auth", "/etc/pam.d/common-password", "/etc/pam.d/system-auth", "/etc/security/pwquality.conf"))) or (type:"EXECVE" and a0:"chage" and (a1 like~ ("--list", "-l"))) or (type:"EXECVE" and a0:"passwd" and (a1 like~ ("-S", "--status")))
