any where (process.executable like~ ("*\\svchost.exe", "*\\taskhost.exe", "*\\lsm.exe", "*\\lsass.exe", "*\\services.exe", "*\\lsaiso.exe", "*\\csrss.exe", "*\\wininit.exe", "*\\winlogon.exe")) and (not (((process.parent.executable like~ ("*\\SavService.exe", "*\\ngen.exe")) or (process.parent.executable like~ ("*\\System32\*", "*\\SysWOW64\*"))) or ((process.parent.executable like~ ("*\\Windows Defender\*", "*\\Microsoft Security Client\*")) and process.parent.executable:"*\\MsMpEng.exe") or (process.parent.executable:"<sigma.types.SigmaNull object at 0x7fa1e35e1160>" or (process.parent.executable like~ ("", "-")))))
