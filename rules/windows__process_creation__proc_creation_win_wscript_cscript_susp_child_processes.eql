any where (process.parent.executable like~ ("*\\wscript.exe", "*\\cscript.exe")) and (process.executable:"*\\rundll32.exe" or ((process.executable like~ ("*\\cmd.exe", "*\\powershell.exe", "*\\pwsh.exe")) and ((process.command_line:"*mshta*" and process.command_line:"*http*") or (process.command_line like~ ("*rundll32*", "*regsvr32*", "*msiexec*"))))) and (not (process.executable:"*\\rundll32.exe" and (process.command_line like~ ("*UpdatePerUserSystemParameters*", "*PrintUIEntry*", "*ClearMyTracksByProcess*"))))
