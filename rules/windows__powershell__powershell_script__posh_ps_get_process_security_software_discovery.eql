any where (powershell.file.script_block_text like~ ("*get-process | \?*", "*get-process | where*", "*gps | \?*", "*gps | where*")) and (powershell.file.script_block_text like~ ("*Company -like*", "*Description -like*", "*Name -like*", "*Path -like*", "*Product -like*")) and (powershell.file.script_block_text like~ ("*\*avira\**", "*\*carbonblack\**", "*\*cylance\**", "*\*defender\**", "*\*kaspersky\**", "*\*malware\**", "*\*sentinel\**", "*\*symantec\**", "*\*virus\**"))
