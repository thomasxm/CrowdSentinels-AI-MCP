any where (((Image like~ ("*/cat", "*/echo", "*/grep", "*/head", "*/more", "*/tail")) and CommandLine:"*>*") or (Image like~ ("*/emacs", "*/nano", "*/sed", "*/vi", "*/vim"))) and (CommandLine like~ ("*/bin/login*", "*/bin/passwd*", "*/boot/*", "*/etc/*.conf*", "*/etc/cron.*", "*/etc/crontab*", "*/etc/hosts*", "*/etc/init.d*", "*/etc/sudoers*", "*/opt/bin/*", "*/sbin*", "*/usr/bin/*", "*/usr/local/bin/*"))
