any where (registry.path:"*\\Control\\Keyboard Layouts\*" and registry.path:"*Ime File*") and ((winlog.event_data.Details like~ ("*:\\Perflogs\*", "*:\\Users\\Public\*", "*:\\Windows\\Temp\*", "*\\AppData\\Local\\Temp\*", "*\\AppData\\Roaming\*", "*\\Temporary Internet*")) or ((winlog.event_data.Details:"*:\\Users\*" and winlog.event_data.Details:"*\\Favorites\*") or (winlog.event_data.Details:"*:\\Users\*" and winlog.event_data.Details:"*\\Favourites\*") or (winlog.event_data.Details:"*:\\Users\*" and winlog.event_data.Details:"*\\Contacts\*")))
