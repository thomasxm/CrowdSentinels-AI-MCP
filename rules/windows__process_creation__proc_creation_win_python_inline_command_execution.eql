any where ((process.pe.original_file_name:"python.exe" or (process.executable like~ ("*python.exe", "*python3.exe", "*python2.exe"))) and process.command_line:"* -c*") and (not (((process.parent.executable like~ ("C:\\Program Files\\Python*", "C:\\Program Files (x86)\\Python*")) and process.parent.executable:"*\\python.exe" and process.parent.command_line:"*-E -s -m ensurepip -U --default-pip*") or ((process.parent.executable like~ ("C:\\Program Files\\Python*", "C:\\Program Files (x86)\\Python*")) and (process.command_line:"*-W ignore::DeprecationWarning*" and process.command_line:"*['install', '--no-cache-dir', '--no-index', '--find-links',*" and process.command_line:"*'--upgrade', 'pip'*")))) and (not ((process.parent.executable:"*\\AppData\\Local\\Programs\\Microsoft VS Code\\Code.exe" or (process.parent.executable like~ ("C:\\Program Files\\Microsoft VS Code\\Code.exe", "C:\\Program Files (x86)\\Microsoft VS Code\\Code.exe"))) or (process.command_line:"*<pip-setuptools-caller>*" and process.command_line:"*exec(compile(*")))
