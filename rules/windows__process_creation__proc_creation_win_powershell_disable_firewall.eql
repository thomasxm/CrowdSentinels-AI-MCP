any where ((process.executable like~ ("*\\powershell.exe", "*\\pwsh.exe", "*\\powershell_ise.exe")) or (process.pe.original_file_name like~ ("PowerShell.EXE", "pwsh.dll"))) and (process.command_line:"*Set-NetFirewallProfile *" and process.command_line:"* -Enabled *" and process.command_line:"* False*") and (process.command_line like~ ("* -All *", "*Public*", "*Domain*", "*Private*"))
