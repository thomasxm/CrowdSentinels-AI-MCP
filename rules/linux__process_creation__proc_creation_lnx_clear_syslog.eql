any where (CommandLine:"*/var/log/syslog*" and ((Image:"*/rm" and (CommandLine like~ ("* -r *", "* -f *", "* -rf *", "*/var/log/syslog*"))) or Image:"*/unlink" or Image:"*/mv" or (Image:"*/truncate" and (CommandLine:"*0 *" and CommandLine:"*/var/log/syslog*") and (CommandLine like~ ("*-s *", "*-c *", "*--size*"))) or (Image:"*/ln" and (CommandLine:"*/dev/null *" and CommandLine:"*/var/log/syslog*") and (CommandLine like~ ("*-sf *", "*-sfn *", "*-sfT *"))) or (Image:"*/cp" and CommandLine:"*/dev/null*") or (Image:"*/shred" and CommandLine:"*-u *"))) or ((CommandLine like~ ("* > /var/log/syslog*", "* >/var/log/syslog*", "* >| /var/log/syslog*", "*: > /var/log/syslog*", "*:> /var/log/syslog*", "*:>/var/log/syslog*", "*>|/var/log/syslog*")) or (CommandLine like~ ("*journalctl --vacuum*", "*journalctl --rotate*")))
