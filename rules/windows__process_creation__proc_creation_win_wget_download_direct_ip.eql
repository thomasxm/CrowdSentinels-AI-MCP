any where (process.executable:"*\\wget.exe" or process.pe.original_file_name:"wget.exe") and process.command_line:"SigmaRegularExpression(regexp=SigmaString(['://[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3}']), flags=set())" and process.command_line:"*http*" and (process.command_line like~ ("SigmaRegularExpression(regexp=SigmaString(['\\s-O\\s']), flags=set())", "*--output-document*")) and (process.command_line like~ ("*.ps1", "*.ps1'", "*.ps1\"", "*.dat", "*.dat'", "*.dat\"", "*.msi", "*.msi'", "*.msi\"", "*.bat", "*.bat'", "*.bat\"", "*.exe", "*.exe'", "*.exe\"", "*.vbs", "*.vbs'", "*.vbs\"", "*.vbe", "*.vbe'", "*.vbe\"", "*.hta", "*.hta'", "*.hta\"", "*.dll", "*.dll'", "*.dll\"", "*.psm1", "*.psm1'", "*.psm1\""))
