any where ((process.executable:"*\\rundll32.exe" or process.pe.original_file_name:"RUNDLL32.EXE" or process.command_line:"*rundll32*") and ((process.command_line:"*comsvcs*" and process.command_line:"*full*") and (process.command_line like~ ("*#-*", "*#+*", "*#24*", "*24 *", "*MiniDump*", "*#65560*")))) or ((process.command_line:"*24*" and process.command_line:"*comsvcs*" and process.command_line:"*full*") and (process.command_line like~ ("* #*", "*,#*", "*, #*", "*\"#*")))
