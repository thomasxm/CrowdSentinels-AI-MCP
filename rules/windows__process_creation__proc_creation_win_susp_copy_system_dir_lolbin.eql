any where ((process.executable:"*\\cmd.exe" and process.command_line:"*copy *") or ((process.executable like~ ("*\\powershell.exe", "*\\pwsh.exe")) and (process.command_line like~ ("*copy-item*", "* copy *", "*cpi *", "* cp *"))) or ((process.executable like~ ("*\\robocopy.exe", "*\\xcopy.exe")) or (process.pe.original_file_name like~ ("robocopy.exe", "XCOPY.EXE")))) and ((process.command_line like~ ("*\\System32*", "*\\SysWOW64*", "*\\WinSxS*")) and (process.command_line like~ ("*\\bitsadmin.exe*", "*\\calc.exe*", "*\\certutil.exe*", "*\\cmdl32.exe*", "*\\cscript.exe*", "*\\mshta.exe*", "*\\rundll32.exe*", "*\\wscript.exe*", "*\\ie4uinit.exe*")))
