any where winlog.channel:"Security" and (((event.code like~ ("4663", "4656")) and (winlog.event_data.AccessMask like~ ("0x100000", "0x1010", "0x1400", "0x1410", "0x1418", "0x1438", "0x143a", "0x1f0fff", "0x1f1fff", "0x1f2fff", "0x1f3fff", "0x40", "143a", "1f0fff", "1f1fff", "1f2fff", "1f3fff")) and winlog.event_data.ObjectType:"Process" and winlog.event_data.ObjectName:"*\\lsass.exe") and (not (user.name:"*$" or (process.executable like~ ("*:\\Program Files\*", "*:\\Program Files (x86)\*")) or (process.executable:"C:\\Windows\\System32\\wbem\\WmiPrvSE.exe" and winlog.event_data.AccessMask:"0x1410"))) and (not process.executable:"*\\SteamLibrary\\steamapps\*"))
