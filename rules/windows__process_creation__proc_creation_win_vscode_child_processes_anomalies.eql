any where process.parent.executable:"*\\code.exe" and ((process.executable like~ ("*\\calc.exe", "*\\regsvr32.exe", "*\\rundll32.exe", "*\\cscript.exe", "*\\wscript.exe")) or ((process.executable like~ ("*\\powershell.exe", "*\\pwsh.exe", "*\\cmd.exe")) and (process.command_line like~ ("*Invoke-Expressions*", "*IEX*", "*Invoke-Command*", "*ICM*", "*DownloadString*", "*rundll32*", "*regsvr32*", "*wscript*", "*cscript*"))) or (process.executable like~ ("*:\\Users\\Public\*", "*:\\Windows\\Temp\*", "*:\\Temp\*")))
