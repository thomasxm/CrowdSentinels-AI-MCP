any where (file.path like~ ("*\\UsageLogs\\cmstp.exe.log", "*\\UsageLogs\\cscript.exe.log", "*\\UsageLogs\\mshta.exe.log", "*\\UsageLogs\\msxsl.exe.log", "*\\UsageLogs\\regsvr32.exe.log", "*\\UsageLogs\\rundll32.exe.log", "*\\UsageLogs\\svchost.exe.log", "*\\UsageLogs\\wscript.exe.log", "*\\UsageLogs\\wmic.exe.log")) and (not (process.parent.executable:"*\\MsiExec.exe" and process.parent.command_line:"* -Embedding*" and process.executable:"*\\rundll32.exe" and (winlog.event_data.CommandLine:"*Temp*" and winlog.event_data.CommandLine:"*zzzzInvokeManagedCustomActionOutOfProc*")))
