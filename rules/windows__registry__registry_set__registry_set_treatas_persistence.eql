any where registry.path:"*TreatAs\\(Default)" and (not ((process.executable:"C:\\Program Files\\Common Files\\Microsoft Shared\\ClickToRun\*" and process.executable:"*\\OfficeClickToRun.exe") or (process.executable like~ ("C:\\Program Files\\Microsoft Office\\root\\integration\\integrator.exe", "C:\\Program Files (x86)\\Microsoft Office\\root\\integration\\integrator.exe")) or process.executable:"C:\\Windows\\system32\\svchost.exe" or (process.executable like~ ("C:\\Windows\\system32\\msiexec.exe", "C:\\Windows\\SysWOW64\\msiexec.exe"))))
