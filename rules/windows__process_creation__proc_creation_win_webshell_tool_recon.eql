any where ((process.parent.executable like~ ("*\\caddy.exe", "*\\httpd.exe", "*\\nginx.exe", "*\\php-cgi.exe", "*\\w3wp.exe", "*\\ws_tomcatservice.exe")) or ((process.parent.executable like~ ("*\\java.exe", "*\\javaw.exe")) and (process.parent.executable like~ ("*-tomcat-*", "*\\tomcat*"))) or ((process.parent.executable like~ ("*\\java.exe", "*\\javaw.exe")) and (process.command_line like~ ("*CATALINA_HOME*", "*catalina.jar*")))) and (process.command_line like~ ("*perl --help*", "*perl -h*", "*python --help*", "*python -h*", "*python3 --help*", "*python3 -h*", "*wget --help*"))
