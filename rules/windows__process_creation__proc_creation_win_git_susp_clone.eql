any where ((process.executable like~ ("*\\git.exe", "*\\git-remote-https.exe")) or process.pe.original_file_name:"git.exe") and (process.command_line like~ ("* clone *", "*git-remote-https *")) and (process.command_line like~ ("*exploit*", "*Vulns*", "*vulnerability*", "*RemoteCodeExecution*", "*Invoke-*", "*CVE-*", "*poc-*", "*ProofOfConcept*", "*proxyshell*", "*log4shell*", "*eternalblue*", "*eternal-blue*", "*MS17-*"))
