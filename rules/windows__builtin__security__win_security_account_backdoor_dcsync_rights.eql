any where winlog.channel:"Security" and ((event.code:"5136" and winlog.event_data.AttributeLDAPDisplayName:"ntSecurityDescriptor" and (winlog.event_data.AttributeValue like~ ("*1131f6ad-9c07-11d1-f79f-00c04fc2dcd2*", "*1131f6aa-9c07-11d1-f79f-00c04fc2dcd2*", "*89e95b76-444d-4c62-991a-0facbeda640c*"))) and (not (winlog.event_data.ObjectClass like~ ("dnsNode", "dnsZoneScope", "dnsZone"))))
