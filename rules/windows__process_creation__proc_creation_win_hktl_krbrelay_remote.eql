any where (process.executable:"*\\RemoteKrbRelay.exe" or process.pe.original_file_name:"RemoteKrbRelay.exe") or (process.command_line:"* -clsid *" and process.command_line:"* -target *" and process.command_line:"* -victim *") or (process.command_line:"*-rbcd *" and (process.command_line like~ ("*-cn *", "*--computername *"))) or (process.command_line:"*-chp *" and (process.command_line:"*-chpPass *" and process.command_line:"*-chpUser *")) or (process.command_line:"*-addgroupmember *" and process.command_line:"*-group *" and process.command_line:"*-groupuser *") or ((process.command_line:"*-smb *" and process.command_line:"*--smbkeyword *") and (process.command_line like~ ("*interactive*", "*secrets*", "*service-add*")))
