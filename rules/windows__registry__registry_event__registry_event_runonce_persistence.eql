any where (registry.path:"*\\Microsoft\\Active Setup\\Installed Components*" and registry.path:"*\\StubPath") and (not ((winlog.event_data.Details:"*C:\\Program Files\\Google\\Chrome\\Application\*" and winlog.event_data.Details:"*\\Installer\\chrmstp.exe\" --configure-user-settings --verbose-logging --system-level*") or ((winlog.event_data.Details like~ ("*C:\\Program Files (x86)\\Microsoft\\Edge\\Application\*", "*C:\\Program Files\\Microsoft\\Edge\\Application\*")) and winlog.event_data.Details:"*\\Installer\\setup.exe\" --configure-user-settings --verbose-logging --system-level --msedge --channel=stable")))
