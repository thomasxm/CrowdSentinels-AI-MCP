any where powershell.file.script_block_text:"SigmaRegularExpression(regexp=SigmaString(['cmd.{0,5}(', <SpecialChars.WILDCARD_SINGLE: 2>, ':/c|/r)(', <SpecialChars.WILDCARD_SINGLE: 2>, ':\\s|)\"set\\s[a-zA-Z]{3,6}.', <SpecialChars.WILDCARD_MULTI: 1>, '(', <SpecialChars.WILDCARD_SINGLE: 2>, ':\\{\\d\\}){1,}\\\\\"\\s+', <SpecialChars.WILDCARD_SINGLE: 2>, '-f(', <SpecialChars.WILDCARD_SINGLE: 2>, ':.', <SpecialChars.WILDCARD_MULTI: 1>, '\\)){1,}.', <SpecialChars.WILDCARD_MULTI: 1>, '\"']), flags=set())"
