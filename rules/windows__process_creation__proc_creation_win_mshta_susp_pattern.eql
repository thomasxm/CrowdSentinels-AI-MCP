any where ((process.executable:"*\\mshta.exe" or process.pe.original_file_name:"MSHTA.EXE") and ((process.parent.executable like~ ("*\\cmd.exe", "*\\cscript.exe", "*\\powershell.exe", "*\\pwsh.exe", "*\\regsvr32.exe", "*\\rundll32.exe", "*\\wscript.exe")) and (process.command_line like~ ("*\\AppData\\Local\*", "*C:\\ProgramData\*", "*C:\\Users\\Public\*", "*C:\\Windows\\Temp\*")))) or ((process.executable:"*\\mshta.exe" or process.pe.original_file_name:"MSHTA.EXE") and (not ((process.executable like~ ("C:\\Windows\\System32\*", "C:\\Windows\\SysWOW64\*")) or (process.command_line like~ ("*.htm*", "*.hta*")) or (process.command_line like~ ("*mshta.exe", "*mshta")))))
