any where ((process.executable:"*\\AnyDesk.exe" or process.pe.description:"AnyDesk" or process.pe.product:"AnyDesk" or process.pe.company:"AnyDesk Software GmbH") and (process.pe.file_version like~ ("7.0.*", "7.1.*", "8.0.1*", "8.0.2*", "8.0.3*", "8.0.4*", "8.0.5*", "8.0.6*", "8.0.7*"))) and (not (process.command_line like~ ("* --remove*", "* --uninstall*")))
