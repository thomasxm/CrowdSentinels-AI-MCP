any where winlog.channel:"Security" and ((event.code:"4661" and (winlog.event_data.ObjectType like~ ("SAM_USER", "SAM_GROUP"))) and ((winlog.event_data.ObjectName like~ ("*-512", "*-502", "*-500", "*-505", "*-519", "*-520", "*-544", "*-551", "*-555")) or winlog.event_data.ObjectName:"*admin*") and (not user.name:"*$"))
