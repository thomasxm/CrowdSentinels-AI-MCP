any where ((process.command_line:"*sc *" and process.command_line:"*config *" and process.command_line:"*binpath=*") or (process.command_line:"*sc *" and process.command_line:"*failure*" and process.command_line:"*command=*")) or (((process.command_line:"*reg *" and process.command_line:"*add *" and process.command_line:"*FailureCommand*") or (process.command_line:"*reg *" and process.command_line:"*add *" and process.command_line:"*ImagePath*")) and (process.command_line like~ ("*.sh*", "*.exe*", "*.dll*", "*.bin$*", "*.bat*", "*.cmd*", "*.js*", "*.msh$*", "*.reg$*", "*.scr*", "*.ps*", "*.vb*", "*.jar*", "*.pl*")))
