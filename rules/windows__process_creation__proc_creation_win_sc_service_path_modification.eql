any where process.executable:"*\\sc.exe" and (process.command_line:"*config*" and process.command_line:"*binPath*") and (process.command_line like~ ("*powershell*", "*cmd *", "*mshta*", "*wscript*", "*cscript*", "*rundll32*", "*svchost*", "*dllhost*", "*cmd.exe /c*", "*cmd.exe /k*", "*cmd.exe /r*", "*cmd /c*", "*cmd /k*", "*cmd /r*", "*C:\\Users\\Public*", "*\\Downloads\*", "*\\Desktop\*", "*\\Microsoft\\Windows\\Start Menu\\Programs\\Startup\*", "*C:\\Windows\\TEMP\*", "*\\AppData\\Local\\Temp*"))
