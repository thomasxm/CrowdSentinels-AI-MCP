any where ((process.executable:"*\\schtasks.exe" and (process.command_line like~ ("* /change *", "* /create *"))) and process.command_line:"*/ru *" and (process.command_line like~ ("*NT AUT*", "* SYSTEM *"))) and (not ((process.executable:"*\\schtasks.exe" and (process.command_line:"*/TN TVInstallRestore*" and process.command_line:"*\\TeamViewer_.exe*")) or (process.command_line:"*Subscription Heartbeat*" and process.command_line:"*\\HeartbeatConfig.xml*" and process.command_line:"*\\Microsoft Shared\\OFFICE*") or (process.command_line like~ ("*/Create /F /RU System /SC WEEKLY /TN AviraSystemSpeedupVerify /TR *", "*:\\Program Files (x86)\\Avira\\System Speedup\\setup\\avira_speedup_setup.exe*", "*/VERIFY /VERYSILENT /NOSTART /NODOTNET /NORESTART\" /RL HIGHEST*"))))
