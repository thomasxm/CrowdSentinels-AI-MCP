any where (process.command_line like~ ("*lsass.dmp*", "*lsass.zip*", "*lsass.rar*", "*Andrew.dmp*", "*Coredump.dmp*", "*NotLSASS.zip*", "*lsass_2*", "*lsassdump*", "*lsassdmp*")) or (process.command_line:"*lsass*" and process.command_line:"*.dmp*") or (process.command_line:"*SQLDmpr*" and process.command_line:"*.mdmp*") or (process.command_line:"*nanodump*" and process.command_line:"*.dmp*")
