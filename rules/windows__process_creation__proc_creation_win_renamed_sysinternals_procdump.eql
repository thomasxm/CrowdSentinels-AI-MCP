any where (process.pe.original_file_name:"procdump" or ((process.command_line like~ ("* -ma *", "* /ma *", "* –ma *", "* —ma *", "* ―ma *") or process.command_line like~ ("* -mp *", "* /mp *", "* –mp *", "* —mp *", "* ―mp *")) and process.command_line like~ ("* -accepteula*", "* /accepteula*", "* –accepteula*", "* —accepteula*", "* ―accepteula*"))) and (not (process.executable like~ ("*\\procdump.exe", "*\\procdump64.exe")))
