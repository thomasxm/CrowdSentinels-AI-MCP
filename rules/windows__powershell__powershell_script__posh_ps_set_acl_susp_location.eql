any where (powershell.file.script_block_text:"*Set-Acl *" and powershell.file.script_block_text:"*-AclObject *") and (powershell.file.script_block_text like~ ("*-Path \"C:\\Windows*", "*-Path \"C:/Windows*", "*-Path 'C:\\Windows*", "*-Path 'C:/Windows*", "*-Path C:\\Windows*", "*-Path C:/Windows*", "*-Path $env:windir*", "*-Path \"$env:windir*", "*-Path '$env:windir*")) and (powershell.file.script_block_text like~ ("*FullControl*", "*Allow*"))
