any where ((process.executable like~ ("*\\squirrel.exe", "*\\update.exe")) and (process.command_line like~ ("*--processStart*", "*--processStartAndWait*", "*--createShortcut*"))) and (not (((process.command_line:"*:\\Users\*" and process.command_line:"*\\AppData\\Local\\Discord\\Update.exe*" and process.command_line:"*Discord.exe*") and (process.command_line like~ ("*--createShortcut*", "*--processStart*"))) or ((process.command_line:"*:\\Users\*" and process.command_line:"*\\AppData\\Local\\GitHubDesktop\\Update.exe*" and process.command_line:"*GitHubDesktop.exe*") and (process.command_line like~ ("*--createShortcut*", "*--processStartAndWait*"))) or ((process.command_line:"*:\\Users\*" and process.command_line:"*\\AppData\\Local\\Microsoft\\Teams\\Update.exe*" and process.command_line:"*Teams.exe*") and (process.command_line like~ ("*--processStart*", "*--createShortcut*"))) or ((process.command_line:"*:\\Users\*" and process.command_line:"*\\AppData\\Local\\yammerdesktop\\Update.exe*" and process.command_line:"*Yammer.exe*") and (process.command_line like~ ("*--processStart*", "*--createShortcut*")))))
