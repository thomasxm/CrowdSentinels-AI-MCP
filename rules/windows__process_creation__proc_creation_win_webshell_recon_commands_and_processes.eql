any where ((process.parent.executable like~ ("*\\w3wp.exe", "*\\php-cgi.exe", "*\\nginx.exe", "*\\httpd.exe", "*\\caddy.exe", "*\\ws_tomcatservice.exe")) or ((process.parent.executable like~ ("*\\java.exe", "*\\javaw.exe")) and (process.parent.executable like~ ("*-tomcat-*", "*\\tomcat*"))) or ((process.parent.executable like~ ("*\\java.exe", "*\\javaw.exe")) and (process.command_line like~ ("*catalina.jar*", "*CATALINA_HOME*")))) and (((process.pe.original_file_name like~ ("net.exe", "net1.exe")) and (process.command_line like~ ("* user *", "* use *", "* group *"))) or (process.pe.original_file_name:"ping.exe" and process.command_line:"* -n *") or (process.command_line like~ ("*&cd&echo*", "*cd /d *")) or (process.pe.original_file_name:"wmic.exe" and process.command_line:"* /node:*") or ((process.executable like~ ("*\\cmd.exe", "*\\powershell.exe", "*\\pwsh.exe")) and (process.command_line like~ ("* -enc *", "* -EncodedCommand *", "* -w hidden *", "* -windowstyle hidden*", "*.WebClient).Download*"))) or ((process.executable like~ ("*\\dsquery.exe", "*\\find.exe", "*\\findstr.exe", "*\\ipconfig.exe", "*\\netstat.exe", "*\\nslookup.exe", "*\\pathping.exe", "*\\quser.exe", "*\\schtasks.exe", "*\\systeminfo.exe", "*\\tasklist.exe", "*\\tracert.exe", "*\\ver.exe", "*\\wevtutil.exe", "*\\whoami.exe")) or (process.pe.original_file_name like~ ("dsquery.exe", "find.exe", "findstr.exe", "ipconfig.exe", "netstat.exe", "nslookup.exe", "pathping.exe", "quser.exe", "schtasks.exe", "sysinfo.exe", "tasklist.exe", "tracert.exe", "ver.exe", "VSSADMIN.EXE", "wevtutil.exe", "whoami.exe"))) or (process.command_line like~ ("* Test-NetConnection *", "*dir \*")))
