any where (process.executable:"*\\cmstp.exe" and network.direction:"true") and (not (cidrMatch(destination.ip, "127.0.0.0/8") or cidrMatch(destination.ip, "10.0.0.0/8") or cidrMatch(destination.ip, "172.16.0.0/12") or cidrMatch(destination.ip, "192.168.0.0/16") or cidrMatch(destination.ip, "169.254.0.0/16") or cidrMatch(destination.ip, "::1/128") or cidrMatch(destination.ip, "fe80::/10") or cidrMatch(destination.ip, "fc00::/7")))
