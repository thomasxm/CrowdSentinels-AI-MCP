any where (((process.executable like~ ("*\\powershell.exe", "*\\pwsh.exe")) or (process.pe.original_file_name like~ ("PowerShell.Exe", "pwsh.dll"))) and (process.command_line like~ ("* -e *", "* -en *", "* -enc *", "* -enco*")) and (process.command_line like~ ("* JAB*", "* SUVYI*", "* SQBFAFgA*", "* aWV4I*", "* IAB*", "* PAA*", "* aQBlAHgA*"))) and (not (process.parent.executable like~ ("*C:\\Packages\\Plugins\\Microsoft.GuestConfiguration.ConfigurationforWindows\*", "*\\gc_worker.exe*")))
