any where (((process.executable like~ ("*\\find.exe", "*\\findstr.exe")) or (process.pe.original_file_name like~ ("FIND.EXE", "FINDSTR.EXE"))) and (process.command_line like~ ("*\"Everyone\"*", "*'Everyone'*", "*\"BUILTIN\\\"*", "*'BUILTIN\\'*"))) or (process.command_line:"*icacls *" and process.command_line:"*findstr *" and process.command_line:"*Everyone*")
