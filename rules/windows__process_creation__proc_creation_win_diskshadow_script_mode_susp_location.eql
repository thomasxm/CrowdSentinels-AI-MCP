any where (process.pe.original_file_name:"diskshadow.exe" or process.executable:"*\\diskshadow.exe") and process.command_line like~ ("*-s *", "*/s *", "*–s *", "*—s *", "*―s *") and (process.command_line like~ ("*:\\Temp\*", "*:\\Windows\\Temp\*", "*\\AppData\\Local\*", "*\\AppData\\Roaming\*", "*\\ProgramData\*", "*\\Users\\Public\*"))
