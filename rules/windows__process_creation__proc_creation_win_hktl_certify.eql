any where (process.executable:"*\\Certify.exe" or process.pe.original_file_name:"Certify.exe" or process.pe.description:"*Certify*") or ((process.command_line like~ ("*.exe cas *", "*.exe find *", "*.exe pkiobjects *", "*.exe request *", "*.exe download *")) and (process.command_line like~ ("* /vulnerable*", "* /template:*", "* /altname:*", "* /domain:*", "* /path:*", "* /ca:*")))
