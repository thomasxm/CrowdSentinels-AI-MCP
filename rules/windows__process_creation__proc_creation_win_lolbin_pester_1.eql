any where ((process.executable like~ ("*\\powershell.exe", "*\\pwsh.exe")) and (process.command_line:"*Pester*" and process.command_line:"*Get-Help*")) or ((process.executable:"*\\cmd.exe" and (process.command_line:"*pester*" and process.command_line:"*;*")) and (process.command_line like~ ("*help*", "*\?*")))
