any where process.executable:"*\\svchost.exe" and (not (process.command_line like~ ("SigmaRegularExpression(regexp=SigmaString(['-k\\s\\w{1,64}(\\s', <SpecialChars.WILDCARD_SINGLE: 2>, '(-p|-s))', <SpecialChars.WILDCARD_SINGLE: 2>]), flags=set())", "", "<sigma.types.SigmaNull object at 0x7f4130b89160>"))) and (not ((process.parent.executable:"*\\MsMpEng.exe" and process.command_line:"*svchost.exe*") or (process.parent.executable:"*\\MRT.exe" and process.command_line:"svchost.exe")))
