any where (registry.path like~ ("*\\Microsoft\\Windows\\PowerShell\*", "*\\Microsoft\\PowerShellCore\*")) and (registry.path like~ ("*\\ModuleLogging\\EnableModuleLogging", "*\\ScriptBlockLogging\\EnableScriptBlockLogging", "*\\ScriptBlockLogging\\EnableScriptBlockInvocationLogging", "*\\Transcription\\EnableTranscripting", "*\\Transcription\\EnableInvocationHeader", "*\\EnableScripts")) and winlog.event_data.Details:"DWORD (0x00000000)"
