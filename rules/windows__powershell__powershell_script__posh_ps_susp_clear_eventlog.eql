any where (powershell.file.script_block_text like~ ("*Clear-EventLog *", "*Remove-EventLog *", "*Limit-EventLog *", "*Clear-WinEvent *")) or (powershell.file.script_block_text:"*Eventing.Reader.EventLogSession*" and powershell.file.script_block_text:"*ClearLog*") or (powershell.file.script_block_text:"*Diagnostics.EventLog*" and powershell.file.script_block_text:"*Clear*")
