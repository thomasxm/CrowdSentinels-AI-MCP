any where ((process.command_line like~ ("* /AutoIt3ExecuteScript*", "* /ErrorStdOut*")) or (winlog.event_data.Hashes like~ ("*IMPHASH=FDC554B3A8683918D731685855683DDF*", "*IMPHASH=CD30A61B60B3D60CECDB034C8C83C290*", "*IMPHASH=F8A00C72F2D667D2EDBB234D0C0AE000*")) or (process.pe.original_file_name like~ ("AutoIt3.exe", "AutoIt2.exe", "AutoIt.exe"))) and (not (process.executable like~ ("*\\AutoIt.exe", "*\\AutoIt2.exe", "*\\AutoIt3_x64.exe", "*\\AutoIt3.exe")))
