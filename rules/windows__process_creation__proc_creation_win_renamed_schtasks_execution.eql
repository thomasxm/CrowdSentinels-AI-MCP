any where (((process.command_line like~ ("* -create *", "* /create *", "* –create *", "* —create *", "* ―create *") or process.command_line like~ ("* -delete *", "* /delete *", "* –delete *", "* —delete *", "* ―delete *") or process.command_line like~ ("* -query *", "* /query *", "* –query *", "* —query *", "* ―query *") or process.command_line like~ ("* -change *", "* /change *", "* –change *", "* —change *", "* ―change *") or process.command_line like~ ("* -run *", "* /run *", "* –run *", "* —run *", "* ―run *") or process.command_line like~ ("* -end *", "* /end *", "* –end *", "* —end *", "* ―end *")) and (process.command_line like~ ("* -tn *", "* /tn *", "* –tn *", "* —tn *", "* ―tn *") or process.command_line like~ ("* -tr *", "* /tr *", "* –tr *", "* —tr *", "* ―tr *") or process.command_line like~ ("* -sc *", "* /sc *", "* –sc *", "* —sc *", "* ―sc *") or process.command_line like~ ("* -st *", "* /st *", "* –st *", "* —st *", "* ―st *") or process.command_line like~ ("* -ru *", "* /ru *", "* –ru *", "* —ru *", "* ―ru *") or process.command_line like~ ("* -fo *", "* /fo *", "* –fo *", "* —fo *", "* ―fo *"))) and (not process.command_line:"*schtasks*")) or (process.pe.original_file_name:"schtasks.exe" and (not process.executable:"*\\schtasks.exe"))
