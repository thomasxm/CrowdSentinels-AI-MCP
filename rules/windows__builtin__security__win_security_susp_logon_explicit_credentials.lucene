winlog.channel:Security AND ((event.code:4648 AND (process.executable:(*\\cmd.exe OR *\\powershell.exe OR *\\pwsh.exe OR *\\winrs.exe OR *\\wmic.exe OR *\\net.exe OR *\\net1.exe OR *\\reg.exe))) AND (NOT (winlog.event_data.TargetServerName:localhost OR (user.name:*$ AND winlog.event_data.TargetUserName:*$))))
