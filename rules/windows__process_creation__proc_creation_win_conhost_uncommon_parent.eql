any where (process.executable:"*\\conhost.exe" and (process.parent.executable like~ ("*\\explorer.exe", "*\\lsass.exe", "*\\regsvr32.exe", "*\\rundll32.exe", "*\\services.exe", "*\\smss.exe", "*\\spoolsv.exe", "*\\svchost.exe", "*\\userinit.exe", "*\\wininit.exe", "*\\winlogon.exe"))) and (not (process.parent.command_line like~ ("*-k apphost -s AppHostSvc*", "*-k imgsvc*", "*-k localService -p -s RemoteRegistry*", "*-k LocalSystemNetworkRestricted -p -s NgcSvc*", "*-k NetSvcs -p -s NcaSvc*", "*-k netsvcs -p -s NetSetupSvc*", "*-k netsvcs -p -s wlidsvc*", "*-k NetworkService -p -s DoSvc*", "*-k wsappx -p -s AppXSvc*", "*-k wsappx -p -s ClipSVC*", "*-k wusvcs -p -s WaaSMedicSvc*"))) and (not (process.parent.command_line like~ ("*C:\\Program Files (x86)\\Dropbox\\Client\*", "*C:\\Program Files\\Dropbox\\Client\*")))
