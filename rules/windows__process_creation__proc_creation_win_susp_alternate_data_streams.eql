any where process.command_line:"*txt:*" and ((process.command_line:"*type *" and process.command_line:"* > *") or (process.command_line:"*makecab *" and process.command_line:"*.cab*") or (process.command_line:"*reg *" and process.command_line:"* export *") or (process.command_line:"*regedit *" and process.command_line:"* /E *") or (process.command_line:"*esentutl *" and process.command_line:"* /y *" and process.command_line:"* /d *" and process.command_line:"* /o *"))
