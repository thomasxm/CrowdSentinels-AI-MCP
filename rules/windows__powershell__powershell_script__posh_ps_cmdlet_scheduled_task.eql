any where ((powershell.file.script_block_text like~ ("*New-ScheduledTaskAction*", "*New-ScheduledTaskTrigger*", "*New-ScheduledTaskPrincipal*", "*New-ScheduledTaskSettingsSet*", "*New-ScheduledTask*", "*Register-ScheduledTask*")) or (powershell.file.script_block_text:"*Invoke-CimMethod*" and powershell.file.script_block_text:"*-ClassName*" and powershell.file.script_block_text:"*PS_ScheduledTask*" and powershell.file.script_block_text:"*-NameSpace*" and powershell.file.script_block_text:"*Root\\Microsoft\\Windows\\TaskScheduler*")) and (not (powershell.file.script_block_text:"*Microsoft.PowerShell.Core\\Export-ModuleMember*" and powershell.file.script_block_text:"*Microsoft.Management.Infrastructure.CimInstance*" and powershell.file.script_block_text:"*__cmdletization_methodParameter*"))
