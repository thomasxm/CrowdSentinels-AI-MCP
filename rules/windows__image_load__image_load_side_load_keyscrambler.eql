any where ((process.executable like~ ("*\\KeyScrambler.exe", "*\\KeyScramblerLogon.exe")) and file.path:"*\\KeyScramblerIE.dll") and (not (((process.executable like~ ("*C:\\Program Files (x86)\\KeyScrambler\*", "*C:\\Program Files\\KeyScrambler\*")) and (file.path like~ ("*C:\\Program Files (x86)\\KeyScrambler\*", "*C:\\Program Files\\KeyScrambler\*"))) or (winlog.event_data.Signature:"QFX Software Corporation" and file.code_signature.status:"Valid")))
