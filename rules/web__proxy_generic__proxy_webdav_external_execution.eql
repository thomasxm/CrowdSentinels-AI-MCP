any where ((c-useragent:"Microsoft-WebDAV-MiniRedir/*" and cs-method:"GET") and (c-uri like~ ("*.7z", "*.bat", "*.dat", "*.cmd", "*.exe", "*.js", "*.lnk", "*.ps1", "*.rar", "*.url", "*.vbe", "*.vbs", "*.zip"))) and (not (cidrMatch(dst_ip, "127.0.0.0/8") or cidrMatch(dst_ip, "10.0.0.0/8") or cidrMatch(dst_ip, "172.16.0.0/12") or cidrMatch(dst_ip, "192.168.0.0/16") or cidrMatch(dst_ip, "169.254.0.0/16") or cidrMatch(dst_ip, "::1/128") or cidrMatch(dst_ip, "fe80::/10") or cidrMatch(dst_ip, "fc00::/7")))
