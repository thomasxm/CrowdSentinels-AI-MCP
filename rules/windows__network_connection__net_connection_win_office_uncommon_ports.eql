any where (network.direction:"true" and (process.executable like~ ("*\\excel.exe", "*\\outlook.exe", "*\\powerpnt.exe", "*\\winword.exe", "*\\wordview.exe"))) and (not ((destination.port like~ (53, 80, 139, 389, 443, 445, 3268)) or (process.executable:"*:\\Program Files\\Microsoft Office\*" and process.executable:"*\\OUTLOOK.EXE" and (destination.port like~ (143, 465, 587, 993, 995)))))
