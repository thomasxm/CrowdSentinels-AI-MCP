# ============================================================
# Elasticsearch Connection Configuration
# ============================================================
# Copy this file to .env and update with your actual values

# Elasticsearch Hosts (comma-separated list)
ELASTICSEARCH_HOSTS=https://localhost:9200

# Authentication - Option 1: API Key (Recommended for production)
# ELASTICSEARCH_API_KEY=your-api-key-here

# Authentication - Option 2: Username/Password
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=changeme

# SSL/TLS Configuration
# Set to "true" in production!
VERIFY_CERTS=false

# Request Timeout (optional, in seconds)
# REQUEST_TIMEOUT=30

# ============================================================
# Risk Management - IMPORTANT FOR THREAT HUNTING
# ============================================================
# Disable write operations for security/IR workloads
# Recommended: Set to "true" when using threat hunting tools
DISABLE_HIGH_RISK_OPERATIONS=true

# Custom operation disabling (optional)
# Comma-separated list of specific operations to disable
# DISABLE_OPERATIONS=create_index,delete_index,delete_by_query

# ============================================================
# OpenSearch Configuration (if using OpenSearch instead)
# ============================================================

# OpenSearch Hosts
OPENSEARCH_HOSTS=https://localhost:9200

# OpenSearch Authentication
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=admin

# ============================================================
# Quick Start with Docker Compose
# ============================================================
# For testing, use the provided Docker Compose file:
#
# docker-compose -f docker-compose-elasticsearch.yml up -d
#
# Default credentials:
#   Username: elastic
#   Password: changeme
#   Host: https://localhost:9200
#
# Or for OpenSearch:
# docker-compose -f docker-compose-opensearch.yml up -d
