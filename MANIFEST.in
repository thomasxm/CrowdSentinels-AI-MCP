include LICENSE
include README.md
include CHANGELOG.md

recursive-include rules *.eql *.lucene
include src/py.typed
recursive-include src *.json *.yaml *.yml

exclude .gitignore
exclude .env
exclude .env.example
prune tests
prune docs
prune implementation-plan
prune mcp_client
prune __pycache__
prune .git
prune .worktrees
global-exclude *.pyc
global-exclude *.pyo
global-exclude __pycache__
global-exclude .DS_Store
